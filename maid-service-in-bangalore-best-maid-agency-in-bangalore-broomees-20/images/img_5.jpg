        $('.estimate-salary').html('Monthly charge');
        // $('.estimate-desc').html('* inc. all charges (0 subscription fee)');
    }







    // PAID BOOKING

    if (dataMain.serviceId == 15 && (cityIdData == 4 || cityIdData == 6)) {
        $('.japaCard').addClass('d-none');
        $('#serviceLimit').html('Select only 1 out of 4 services');
    } else if (dataMain.serviceId == 15 && cityIdData != 4 && cityIdData != 6) {
        $('.japaCard').removeClass('d-none');
        $('#serviceLimit').html('Select only 1 out of 5 services');
    } else {

    }


    if (cityIdData == 4) {
        $('.puneCard').removeClass('d-none');

        if (dataMain.serviceId == 39) {
            $('#service .parent-category .category-desc:eq(0)').html('Select only 1 out of 5 services');
        }

        // $('.japaCard').addClass('d-none');
        // $('.card3:eq(1)').addClass('d-none');
        // // $('#religiousPreference').prop('checked',false); 
        // if ($('#religiousPreference').prop('checked')) {
        //     $('#religiousPreference').trigger('click');
        // }
        // $('.ta').addClass('d-none');
        // $('#billing-summary').addClass('d-none');            
    } else {
        $('.puneCard').addClass('d-none');

        if (dataMain.serviceId == 39) {
            $('#service .parent-category .category-desc:eq(0)').html('Select only 1 out of 4 services');
        }

        // $('.japaCard').removeClass('d-none');            
        // $('.card3:eq(1)').removeClass('d-none');
        // $('.ta').removeClass('d-none');
        // $('#billing-summary').removeClass('d-none');
    }

    // if (dataMain.serviceId == 41 || dataMain.serviceId == 42 || dataMain.serviceId == 43) {
    //     $('.ta').addClass('d-none');
    //     $('#billing-summary').addClass('d-none');
    // } else {
    //     $('.ta').removeClass('d-none');
    //     $('#billing-summary').removeClass('d-none');
    // }


    // console.log("City Id : ", cityIdData);

    // if(dataMain.serviceId == 15 && dPrice == 24000 && dMinutes == 120){
    //     return parseInt($price);
    // }


    // if(dataMain.serviceId == 15 && dName == "Yes, I need a 24hrs Japa Maid"){
    //     return parseInt($price);
    // }


    // pune discount  Ranchi discount
    if (cityIdData == 3 && dataMain.serviceId == 14) {
        if (via == 1) {
            $('.starting-active').each(function() {
                
                // let price = $(this).attr('serStartPrice');
                // $(this).html("₹" + Math.round(price * 0.90));
            });
        }

        return parseInt($price) * 0.90;
        // return parseInt($price);

    } else if (cityIdData != 3 && dataMain.serviceId == 14) {
        if (via == 1) {
            $('.starting-active').each(function() {
                let price = $(this).attr('serStartPrice');
                $(this).html("₹" + price);
            });
        }
        return parseInt($price);

    } else if (cityIdData == 5 && (dataMain.serviceId == 44 || dataMain.serviceId == 45)) {
        if (via == 1) {
            $('.starting-active').each(function() {
                let price = $(this).attr('serStartPrice');
                $(this).html("₹" + Math.round(price * 0.70));
            });

            return parseInt($price) * 0.70;
        }
        return parseInt($price);

    } else if (cityIdData != 5 && (dataMain.serviceId == 44 || dataMain.serviceId == 45)) {
        if (via == 1) {
            $('.starting-active').each(function() {
                let price = $(this).attr('serStartPrice');
                $(this).html("₹" + price);
            });
        }
        return parseInt($price);

    } else {
        return parseInt($price);
    }


}

// // // // // // // // // //
// START DATE PICKER  // //
// // // // // // // // //

function initDate() {
    $('#datePicker').datepicker('destroy');
    // console.log("INNNN", dataMain.maxDate);
    const today = new Date();
    let nextThreeDays = new Date(today);
    // Check if there is a Sunday within the next three days
    let extendDays = false;
    for (var i = 0; i < parseInt(dataMain.maxDate); i++) {
        if (nextThreeDays.getDay() === 0) { // 0 represents Sunday
            extendDays = true;
            break;
        }
        nextThreeDays.setDate(nextThreeDays.getDate() + 1);
    }

    

    $('#datePicker').datepicker({
        format: 'd-M',
        //autoclose: true,
        // startDate:'0d',                
        startDate: '+' + (extendDays ? (parseInt(dataMain.maxDate) + 1) : dataMain.maxDate) + 'd',
        //title : 'Service Starts On',
        todayHighlight: true,
        daysOfWeekDisabled: [0],
        //endDate:'+'+data.maxDate+'d'
    });



    $('#datePicker').on('changeDate', function(e) {
        var date = e.date;
        var day = ('0' + date.getDate()).slice(-2);
        var month = ('0' + (date.getMonth() + 1)).slice(-2);
        var year = date.getFullYear();
        sStartDate = year + '-' + month + '-' + day;        
        // console.log(sStartDate);
        $(this).datepicker('hide');
        $("#datePicker").children('input').removeClass('form-error-input');
        // $("#wizardErr").html("");
        $("#sShiftErr").html("");
        //$(this).next('input[type=hidden]').val(year + '-' + month + '-' + day);        
    });
}

