$(document).ready(function() {
    $('#babyDob').datepicker({
        format: 'dd-mm-yyyy', // Set format to yyyy-mm-dd
        startDate: '2012-01-01', // Minimum date (Jan 1, 2012)
        endDate: new Date(), // Maximum date (today)
        autoclose: true,
        todayHighlight: true
    })
});

async function submitBabyDob() {
    const babyDob = $("#babyDob").val();
    let parts = babyDob.split("-"); // Split into [dd, mm, yyyy]
    let formattedDate = new Date(parts[2], parts[1] - 1, parts[0]) // Convert to Date object
        .toLocaleDateString("en-GB", {
            day: "2-digit",
            month: "short",
            year: "numeric"
        });

    $("#dob-display").html(formattedDate);
    if (babyDob) {
        const [day, month, year] = babyDob.split('-');
        const dob = new Date(`${year}-${month}-${day}`); // Convert to ISO format
        const today = new Date();

        // Calculate age in years, months, and days
        let ageYears = today.getFullYear() - dob.getFullYear();
        let ageMonths = today.getMonth() - dob.getMonth();
        let ageDays = today.getDate() - dob.getDate();

        // Adjust if months or days are negative
        if (ageDays < 0) {
            ageMonths--;
            ageDays += new Date(today.getFullYear(), today.getMonth(), 0).getDate();
        }

        if (ageMonths < 0) {
            ageYears--;
            ageMonths += 12;
        }

        console.log('ageYears', ageYears, 'ageMonths', ageMonths, 'ageDays', ageDays)
        const activeCard = $('.service .card-main-v3 .active');
        if (activeCard.length) {
            const sign = activeCard.find('.sign');
            const button = activeCard.find('button');
            if (sign.text().trim() === '-') {
                console.log('Clicking button...');
                //event.stopPropagation();
                minusclick(activeCard)
                button.click();
            }
        }
        console.log(activeCard)
        $('.service .card-main-v3').hide();
        if (ageYears == 0 && (ageMonths < 2 || (ageMonths == 2 && ageDays == 0))) {
            var element = $("[id='0-2 months (Japa maid is required)Btn']");
            if (element.length) {
                $("[id='0-2 months (Japa maid is required)Btn']").show();
                console.log("Element found:", element);
            } else {
                otherServices(1)
                let serviceData = await


                console.log("Element not found");
            }

        } else if (ageYears == 0 && ageMonths >= 2) {
            $("[id='2-12 monthsBtn']").show();
        } else if (ageYears == 1 || (ageYears == 2 && ageMonths == 0 && ageDays == 0)) {
            $("[id='1-2 yearsBtn']").show();
        } else if (ageYears == 2 || ageYears <= 3 || (ageYears == 4 && ageMonths == 0 && ageDays == 0)) {
            $("[id='2-4 yearsBtn']").show();
        } else {
            $("[id='More than 4 yearsBtn']").show();
        }
        // Close the modal
        $('#babyDobModal').modal('hide');

    } else {
        alert("Please enter a valid date.");
    }
}

//Risabh
function openDobModal() {
    $('#babyDobModal').modal({
        backdrop: 'static',
        keyboard: false
    });
}

function openMakePaymentModal() {
    continuePayment(1);

    $('#makePayment').modal({
        backdrop: 'static',
        keyboard: false
    });

    setTimeout(() => {
        let slideCount = $('.price-con .pricing-card-item').length;

        // destroy old slick if exists
        if ($('.price-con').hasClass('slick-initialized')) {
            $('.price-con').slick('unslick');
        }

        if (slideCount > 1) {
            // initialize slick only if more than 1 package
            $('.price-con').slick({
                slidesToShow: 2.3,
                slidesToScroll: 1,
                infinite: false,
                arrows: true,
                dots: false,
                prevArrow: `
                    <button type="button" class="slick-prev custom-prev">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
                            <path d="M16 1a15 15 0 1 0 15 15A15.017 15.017 0 0 0 16 1zm2.707 20.293a1 1 0 1 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 1.414L13.414 16z" fill="#ffc91c"></path>
                        </svg>
                    </button>`,
                nextArrow: `
                    <button type="button" class="slick-next custom-next">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
                            <path d="M16 1a15 15 0 1 0 15 15A15.017 15.017 0 0 0 16 1zm2.707 20.293a1 1 0 1 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 1.414L13.414 16z" fill="#ffc91c"></path>
                        </svg>
                    </button>`,
                responsive: [
                    { breakpoint: 1024, settings: { slidesToShow: 2 } },
                    { breakpoint: 600, settings: { slidesToShow: 1.1 } }
                ]
            });

            $('.price-con').css("overflow", "inherit");
            $('.price-con').slick('setPosition');

            // handle click slide
            $('.price-con').on('click', '.slick-slide', function () {
                let index = $(this).data('slick-index');
                $('.price-con').slick('slickGoTo', index);
            });
        } else {
            // when only 1 card, make sure it takes 100% width
            $('.price-con').css({
                "overflow": "inherit",
                "display": "flex",
                "justify-content": "center"
            });

            $('.price-outer-con').css({
                "margin-right": "auto"
            });

            $('.price-con .pricing-card-item').css({
                "flex": "0 0 100%"
            });
        }
    }, 300);
}


