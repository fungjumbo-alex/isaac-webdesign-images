<script>
function detectDevice() {
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;

    // Detect mobile devices
    const isMobile = /android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini/i.test(userAgent.toLowerCase());

    // Detect browser name
    let browserName = "Unknown";
    if (/chrome|crios|crmo/i.test(userAgent)) {
        browserName = "Chrome";
    } else if (/firefox|fxios/i.test(userAgent)) {
        browserName = "Firefox";
    } else if (/safari/i.test(userAgent) && !/chrome|crios|crmo/i.test(userAgent)) {
        browserName = "Safari";
    } else if (/opr|opera/i.test(userAgent)) {
        browserName = "Opera";
    } else if (/msie|trident/i.test(userAgent)) {
        browserName = "Internet Explorer";
    } else if (/edg/i.test(userAgent)) {
        browserName = "Edge";
    }

    // Detect OS
    let osName = "Unknown OS";
    if (/windows phone/i.test(userAgent)) {
        osName = "Windows Phone";
    } else if (/windows/i.test(userAgent)) {
        osName = "Windows";
    } else if (/macintosh|mac os x/i.test(userAgent)) {
        osName = "MacOS";
    } else if (/android/i.test(userAgent)) {
        osName = "Android";
    } else if (/linux/i.test(userAgent)) {
        osName = "Linux";
    } else if (/iphone|ipad|ipod/i.test(userAgent)) {
        osName = "iOS";
    }

    return {
        isMobile: isMobile,
        browserName: browserName,
        osName: osName
    };
}


let screenshotLocation = document.getElementById('screenshotLocation')
let deviceDetail = detectDevice()
if (deviceDetail.isMobile) {
    if (deviceDetail.browserName == 'Safari') {
        let deskHtml =
            `<p style="margin: 6px 0;">Follow the steps below to enable location services</p>
                <ol style="padding-inline-start: 30px;">
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Click "Allow" under the Location section.</li>
                  </ol>
                  <img style="width: 50%; height: auto; border-radius: 4px; margin: 10px auto; position: relative; transform: translateX(50%);" src="https://broomees.com/assets/images/toshitgif.gif" alt="Screenshot">`

        document.getElementById('screenshotLocation').innerHTML = deskHtml

    } else {
        if (deviceDetail.browserName == 'Chrome' && deviceDetail.osName == 'MacOS') {
            let deskHtml =
                `<p style="margin-bottom: 6px;">Follow the steps below to enable location services</p>
                  <ol style="padding-inline-start: 30px;">
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Open phone settings.</li>
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Scroll down to Chrome and click on it.</li>
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Click on Location.</li>
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Select 'While Using the App.'</li>
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Visit broomees.com.</li>
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Click on Pricing from the menu.</li>
                  <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Allow location access.</li>
                  </ol>
                  <img style="width: 50%; height: auto; border-radius: 4px; margin: 0 auto; position: relative; transform: translateX(50%);" src="https://broomees.com/assets/images/IOSMacLocationEnable.jpg" alt="Screenshot">`

            document.getElementById('screenshotLocation').innerHTML = deskHtml
        } else {
            let deskHtml =
                `<p style="margin-bottom: 6px;">Follow the steps below to enable location services</p>
                    <ol style="padding-inline-start: 30px;">
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Open your browser (such as Chrome).</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Go to the browser settings.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Navigate to site settings.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Under permissions, open the location settings.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Find broomees.com.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Select "Allow" to give permission.</li>
                    </ol>
                    <img style="width: 50%; height: auto; border-radius: 4px; margin: 0 auto; position: relative; transform: translateX(50%);" src="https://broomees.com/assets/images/Screenshot_20240620_164737_Chromeq1.jpg" alt="Screenshot">`
            document.getElementById('screenshotLocation').innerHTML = deskHtml
        }

    }

} else {
    if (deviceDetail.browserName == 'Safari') {
        let deskHtml = `<p style="margin-bottom: 6px;">Follow the steps below to enable location services</p>
                    <ol style="padding-inline-start: 30px;">
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Click on the Safari Menu in the top left corner of the screen.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Select "Settings".</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Go to the "Websites" tab.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Select "Location" from the side menu.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Find the website "broomees.com" in the list.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Click on the dropdown menu next to "broomees.com" and select "Allow."</li>
                    </ol>
                    <div style="overflow: hidden;">
                    <img id="screenshotPcSafariLocation" style="width: 100%; height: auto; border-radius: 4px;" src="https://broomees.com/assets/images/toshit2.png" alt="Screenshot">
                    </div>
                    `

        document.getElementById('screenshotLocation').innerHTML = deskHtml
    } else {
        let deskHtml = `<p style="margin-bottom: 6px;">Follow the steps below to enable location services</p>
                    <ol style="padding-inline-start: 30px;">
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">Click on the pin icon in the address bar of your browser.</li>
                    <li style="font-weight: 400; color: gray; margin-bottom: 6px;">In the popup that appears, select "Allow".</li>
                    </ol>
                    <div style="overflow: hidden;">
                    <img id="screenshotPcLocation" style="width: 100%; height: auto; border-radius: 4px;" src="https://broomees.com/assets/images/Screenshot-2024-06-20-1183437.jpg" alt="Screenshot">
                    </div>
                    `

        document.getElementById('screenshotLocation').innerHTML = deskHtml

    }
}
</script>


