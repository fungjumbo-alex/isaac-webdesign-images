    //     }
    // }       


    if (($(".box-img.active").children('.box-img-child').attr('data-city-name')).toLowerCase() != (
            currentAddressData.city).toLowerCase()) {

        confirmLocationBasedCharges('1');
        return false;
    }

    var service_not_availaible = false;
    // if (($(".box-img.active").children('.box-img-child').attr('data-city-id') == 4 || currentAddressData.city == 'Pune') && dataMain.pincodeDiscount != '' && dataMain.pincodeDiscount != null) {
    //     let pincodeArray = JSON.parse(dataMain.pincodeDiscount);
    //     matchingLocations = pincodeArray.filter(elem => elem.pincode == currentAddressData.pincode);
    //     if (matchingLocations.length == 0) {
    //         showNotifier('This service is not available at your pincode, we have received your request and will get back to you shortly!');
    //         service_not_availaible = true;
    //         // return false;
    //     }

    //     if($("#religiousPreference").is(':checked')){
    //         showNotifier('Religious preference option is not available in your city');
    //         return false;
    //     }
    // }

    if (($(".box-img.active").children('.box-img-child').attr('data-city-id') == 4 || currentAddressData.city ==
            'Pune')) {

        // if ($("#religiousPreference").is(':checked')) {
        //     showNotifier('Religious preference option is not available in your city');
        //     return false;
        // }
    }

    // ZONES NOT AVAILABLE
    if (
        (
            (
                ($(".box-img.active").children('.box-img-child').attr('data-city-id') == 6 || currentAddressData
                    .city ==
                    'Bengaluru') ||
                ($(".box-img.active").children('.box-img-child').attr('data-city-id') == 4 || currentAddressData
                    .city ==
                    'Pune')
            ) ||
            (
                (
                    $(".box-img.active").children('.box-img-child').attr('data-city-id') == 3 || currentAddressData
                    .city == 'Noida'
                ) &&
                (
                    dataMain.serviceId == 14 || dataMain.serviceId == 15 || dataMain.serviceId == 19 || dataMain
                    .serviceId == 39
                )
            ) ||
            (
                (
                    $(".box-img.active").children('.box-img-child').attr('data-city-id') == 2 || currentAddressData
                    .city == 'Gurgaon' || currentAddressData.city == 'gurgaon'
                ) &&
                (
                    dataMain.serviceId == 14 || dataMain.serviceId == 15 || dataMain.serviceId == 19 || dataMain
                    .serviceId == 39
                )
            ) ||
            (
                (
                    $(".box-img.active").children('.box-img-child').attr('data-city-id') == 7 || currentAddressData
                    .city == 'Ghaziabad' || currentAddressData.city == 'ghaziabad'
                ) &&
                (
                    dataMain.serviceId == 15 || dataMain.serviceId == 39 || dataMain.serviceId == 19 || dataMain
                    .serviceId == 14
                )
            ) ||
            (
                (
                    $(".box-img.active").children('.box-img-child').attr('data-city-id') == 1 || currentAddressData
                    .city == 'Delhi' || currentAddressData.city == 'delhi'
                ) &&
                (
                    dataMain.serviceId == 14 || dataMain.serviceId == 15 || dataMain.serviceId == 19 || dataMain
                    .serviceId == 39
                )
            )
        ) &&

        dataMain.zonesData[0]

    ) {

        if (!currentAddressData.latlng) {
            // showNotifier('Address in invalid, please edit to proceed!');
            showNotifier('Oops! There seems to be an issue with the address. Could you retry adding it?');
            return false;
        }

        // const zonesLocations = JSON.parse(dataMain.zonesData[0].locations);
        // console.log('zonesLocations => ',zonesLocations);
        // // Check if the point is within the polygon
        // const isWithinPolygon = pointInPolygon({lat:currentAddressData.latlng.split(",")[0],lng:currentAddressData.latlng.split(",")[1]}, zonesLocations);
        // console.log("isWithinPolygon",isWithinPolygon); // Output: true/false


        let inclusionZones = JSON.parse(dataMain.zonesData[0].inclusions);
        let exclusionZones = JSON.parse(dataMain.zonesData[0].exclusions);

        // console.log('inclusion', inclusionZones)
        // console.log('exclusion', exclusionZones)

        let isNotWithinPolygon = inclusionZones.every((incZone) => {
            if (pointInPolygon({
                    lat: currentAddressData.latlng.split(",")[0],
                    lng: currentAddressData.latlng.split(",")[1]
                }, incZone)) {
                // if lat lng exist in green zone
                return false
            }
            // if lat lng not exist in green zone
            return true

        })


        console.log('GreenZone :' + isNotWithinPolygon);

        let isWithinPolygon = false

        if (!isNotWithinPolygon) {
            isWithinPolygon = exclusionZones.every((excZone) => {
                if (pointInPolygon({
                        lat: currentAddressData.latlng.split(",")[0],
                        lng: currentAddressData.latlng.split(",")[1]
                    }, excZone)) {
                    // if lat lng exist in red zone
                    return false
                }
                // if lat lng not exist in red zone
                return true
            })
        }

        console.log('RedZone :' + isWithinPolygon);

        if (!isWithinPolygon) {
            // showNotifier('This service is not available at your location!');
            showNotifier(
                'This service is not available at your location, we have received your request and will get back to you shortly!',
                5000);

            otherServices();

            if (outsideZone == false) {
                outsideZone = true;
                service_not_availaible = true;
            } else {
                return false;
            }
        }

    }

    if (redZoneReligiousPreference == '1' && $("#religiousPreference").is(':checked')) {
        swal("oops!", "Religious Preference is not available in your area", "warning");
        // showNotifier('Religious Preference is not available in your area');
        return false;
    }

    if (redZoneLanguagePreference == '1' && $("#languagePreference").is(':checked')) {
        swal("oops!", "Hindi/English-speaking workers are currently unavailable in your area, only Kannada-speaking workers are available", "warning");
        // showNotifier('Hindi/English-speaking workers are currently unavailable in your area, only Kannada-speaking workers are available');
        return false;
    }

    

    if (
        $(".box-img.active").children('.box-img-child').attr('data-city-id') == 7 &&
        (dataMain.serviceId == 14 || dataMain.serviceId == 19) &&
        currentAddressData.city == 'Ghaziabad' &&
        $('#dropdownShifts').val() == 2
    ) {
        // Show a notification that 2 shifts are not allowed in Ghaziabad
        showNotifier('2 Shifts is not allowed in your city');
        return false; // Prevent further execution
    }


    if ($(".box-img.active").children('.box-img-child').attr('data-city-id') == 4 && dataMain.serviceId == 39 && (
