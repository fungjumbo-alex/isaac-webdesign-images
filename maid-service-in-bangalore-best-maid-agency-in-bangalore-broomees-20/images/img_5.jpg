// CalcDynamic

function roundTime(time) {
    let totalMinutes = time * 60;
    let roundedMinutes = Math.round(totalMinutes / 30) * 30;
    return roundedMinutes / 60;
}

function formatTimeToHoursMinutes(time) {
    const hours = Math.floor(time);
    const minutes = Math.round((time - hours) * 60);
    const hourStr = hours > 0 ? `${hours} hr${hours > 1 ? 's' : ''}` : '';
    const minuteStr = minutes > 0 ? `${minutes} min${minutes > 1 ? 's' : ''}` : '';
    return [hourStr, minuteStr].filter(Boolean).join(' ');
}

function divideTime(time) {
    const roundedTime = Math.round(time * 2) / 2;
    const halfTime = Math.round((roundedTime / 2) * 2) / 2;
    const firstPart = halfTime;
    const secondPart = roundedTime - firstPart;
    return [firstPart, secondPart];
}

function generateTimeIntervalForShift2(estimatedHours) {
    let roundedTime = roundTime(estimatedHours);
    let maxHours = roundedTime - 0.5;
    let currentHours = 0.5;
    let dividedTime = divideTime(estimatedHours);
    let durations = [];
    while (true) {
        if (maxHours < currentHours)
            break;
        durations.push({
            display: `${formatTimeToHoursMinutes(currentHours)}`,
            value: currentHours,
            remainingDisplay: `${formatTimeToHoursMinutes(roundedTime - currentHours)}`,
            remainingValue: roundedTime - currentHours,
            default: currentHours == dividedTime[1]
        });
        currentHours += 0.5;
    }
    return durations;
}

function generateTimeIntervalForShift1(estimatedHours) {
    let roundedTime = roundTime(estimatedHours);
    let maxHours = roundedTime - 1;
    let currentHours = 0.5;
    let dividedTime = divideTime(estimatedHours);
    let durations = [];
    while (true) {
        if (maxHours < currentHours)
            break;
        durations.push({
            display: `${formatTimeToHoursMinutes(currentHours)}`,
            value: currentHours,
            remainingDisplay: `${formatTimeToHoursMinutes(roundedTime - currentHours)}`,
            remainingValue: roundedTime - currentHours,
            default: currentHours == dividedTime[1]
        });
        currentHours += 0.5;
    }
    return durations;
}

