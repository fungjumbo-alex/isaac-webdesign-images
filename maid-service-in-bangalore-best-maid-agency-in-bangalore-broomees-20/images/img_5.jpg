        showNotifier(
            'This service is not available in your city, we have received your request and will get back to you shortly!'
        );
        service_not_availaible = true;
        // return false;
    }




    if (payVia == 'unlockProfile') {

        if (service_not_availaible == true) {
            showNotifier('This service is not available at your pincode');
            return false;
        }

        $('#staticBackdrop').modal('show');
        $('#w-loading').addClass('d-none');
        $('#pay-btn').removeClass('d-none');
        $('.w-profile-amount').removeClass('p-select');
        $('#pay-btn').addClass('d-none')
        $('.payment-btn').addClass('d-none')
        return false;
    }

    if (payVia == 'self') {
        // toggleLoader(1);
        $('#w-loading').removeClass('d-none');
        $('#pay-btn').addClass('d-none')

        $('.w-profile-amount').css('pointer-events', 'none')
        $('.calcAmount').css('pointer-events', 'none')

        $('#staticBackdrop .close').css('pointer-events', 'none');

        // console.log("card disable");
        // $('.card-section').css('cursor','none');
        $.ajax({
            type: 'GET',
            url: "/api/getMatchWorker",
            data: {
                serviceId: dataMain.serviceId,
                address: JSON.stringify(currentAddressData),
                preference: JSON.stringify(currentPreferenceData),
            },
            dataType: 'json',
            beforeSend: function() {},
            success: function(data, status, xhr) {
