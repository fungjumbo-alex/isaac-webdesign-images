let toggleBottomSheet = (via) => {
    //Prefill changes 03/06/2025
    if (prefillDone === true) {
        if (via == 1) {
            $(".popup-back").show();
            $(".popup-page-1").animate({
                top: '20%'
            });
            $(".card-footer-main").hide();
            $(".card-footer-pop").show();
        } else {
            $('.popup-page-1').animate({
                top: '100%'
            });
            $('.popup-back').fadeOut();
            $(".card-footer-pop").hide();
            $(".card-footer-main").show();
        }
    }
};

