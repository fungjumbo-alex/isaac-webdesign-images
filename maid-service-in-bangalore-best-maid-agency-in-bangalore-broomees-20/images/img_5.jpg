                    <input style='border:none;' class='form-control' type='text' placeholder='Mobile No. / Email ' id='mobile1'
                        oninput='checkInput(this.value)'  />
                </li>
                <span id='mobile1Err' class='form-error-msg error'></span>
                <li class='password' style='display:none' id='otpVal'>
                    <div class='otp-sec-main'>
                        <label>Enter OTP</label>
                        <div id='otp-input' class='otp-sec-child'>
                            <input type='number' id='digit-1' step='1' data-next='digit-2' min='0' max='9'
                                autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digit-2' step='1' data-next='digit-3' data-previous='digit-1'
                                min='0' max='9' autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digit-3' step='1' data-next='digit-4' data-previous='digit-2'
                                min='0' max='9' autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digit-4' step='1' data-next='digit-5' data-previous='digit-3'
                                min='0' max='9' autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digit-5' step='1' data-next='digit-6' data-previous='digit-4'
                                min='0' max='9' autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digit-6' step='1' data-previous='digit-5' min='0' max='9'
                                autocomplete='no' pattern='\d*' class='otp-slot'>
                        </div>
                        <input type='hidden' name='otp'>
                        <!-- <div class = 'otp-sec-child' id = 'loginOtpsec'>
<input type = 'tel' id = 'digit-1' name = 'digit-1' data-next = 'digit-2' class = 'otp-slot'>
<input type = 'tel' id = 'digit-2' name = 'digit-2' data-next = 'digit-3' data-previous = 'digit-1' class = 'otp-slot' />
<input type = 'tel' id = 'digit-3' name = 'digit-3' data-next = 'digit-4' data-previous = 'digit-2' class = 'otp-slot' />
<input type = 'tel' id = 'digit-4' name = 'digit-4' data-next = 'digit-5' data-previous = 'digit-3' class = 'otp-slot' />
<input type = 'tel' id = 'digit-5' name = 'digit-5' data-next = 'digit-6' data-previous = 'digit-4' class = 'otp-slot' />
<input type = 'tel' id = 'digit-6' name = 'digit-6' data-previous = 'digit-5' class = 'otp-slot' />
</div> -->
                        <span id='otpErr' class='form-error-msg'></span>
                        <div class='d-flex mt-4' style='gap:10px;justify-content: right;'>
                            <p id='timertext'> Resend OTP in <span id='countdowntimer'>30 </span> Seconds</p>
                            <p onclick='sendOtp()' id="reSendOtpLoginBtn" class='otp-content reSendOtpButton'>Re-send OTP</p>
                            <!-- <p onclick='sendOtp(1)' class='otp-content reSendOtpButton'>Re-send WhatsApp OTP</p> -->
                        </div>

                    </div>

                <li class='text-center d-flex justify-content-center' style='flex-wrap: wrap;gap:10px;'>
                    <a href='javascript:void(0)' id="sendOtpLoginBtn" onclick='sendOtp()' class='button2 sendOtpButton'>Send OTP</a>
                    <!-- <a href='javascript:void(0)' style='background: #18d26e;color:#fff !important;' onclick='sendOtp(1)'
                        class='button2 sendOtpButton'>Send WhatsApp OTP</a> -->
                </li>
                <li class='text-center' style='display:none' id='loginButton'>
                    <a href='javascript:void(0)' onclick='loginOtp()' class='button2'>Login</a>
                </li>
                <li class='text-center'>
                    <a href='javascript:void(0)' onclick='showSignupModal()' class='or-sign-up'><span>Or</span> Sign up
                    </a>
                </li>
            </ul>
        </form>
    </div>
</div>
<!-- new Login Modal  end-->

<!-- SIGNUP -->

</div>

<!-- new Signup Modal -->
<div class='login-modal' id='signupModal'>
    <div class='inner-box'>
        <img class='login-cross' src='/assets/Badges/cross.svg' class='cross-btn'></img>
        <h3 style='text-align:center'>Sign Up</h3>
        <form method='post' class='form1' action='#'>
            <ul>
                <li>
                    <input class='form-control' type='text' placeholder='Name' id='name' maxlength='24'
                        autocomplete='off' />
                    <span id='nameErr' class='form-error-msg'></span>
                </li>
                <li>
                    <input class='form-control' type='email' placeholder='Email' id='email' maxlength='64'
                        autocomplete='off' />
                    <span id='emailErr' class='form-error-msg'></span>
                </li>
                <li class='otp'>
                    <input class='form-control' type='number' placeholder='Mobile No.' id='mobile' name='mobile'
                        oninput='javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);'
                        autocomplete='off' maxLength='10' />
                    <span id='mobileErr' class='form-error-msg'></span>
                    <span id='mobileSucc' style='color:green'></span>
                </li>
                <li>
                    <div class='otp-sec-main' style='display:none'>
                        <label>Enter OTP</label>
                        <div id='signupOtpsec' class='otp-sec-child'>
                            <input type='number' id='digitSignup-1' step='1' name='digitSignup-1'
                                data-next='digitSignup-2' min='0' max='9' autocomplete='no' pattern='\d*'
                                class='otp-slot'>
                            <input type='number' id='digitSignup-2' step='1' name='digitSignup-2'
                                data-next='digitSignup-3' data-previous='digitSignup-1' min='0' max='9'
                                autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digitSignup-3' step='1' name='digitSignup-3'
                                data-next='digitSignup-4' data-previous='digitSignup-2' min='0' max='9'
                                autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digitSignup-4' step='1' name='digitSignup-4'
                                data-next='digitSignup-5' data-previous='digitSignup-3' min='0' max='9'
                                autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digitSignup-5' step='1' name='digitSignup-5'
                                data-next='digitSignup-6' data-previous='digitSignup-4' min='0' max='9'
                                autocomplete='no' pattern='\d*' class='otp-slot'>
                            <input type='number' id='digitSignup-6' step='1' name='digitSignup-6'
                                data-previous='digitSignup-5' min='0' max='9' autocomplete='no' pattern='\d*'
                                class='otp-slot'>
                        </div>
                        <!-- <div class = 'otp-sec-child' id = 'signupOtpsec'>
<input type = 'tel' id = 'digitSignup-1' name = 'digitSignup-1' data-next = 'digitSignup-2' class = 'otp-slot'>
<input type = 'tel' id = 'digitSignup-2' name = 'digitSignup-2' data-next = 'digitSignup-3' data-previous = 'digitSignup-1' class = 'otp-slot' />
<input type = 'tel' id = 'digitSignup-3' name = 'digitSignup-3' data-next = 'digitSignup-4' data-previous = 'digitSignup-2' class = 'otp-slot' />
<input type = 'tel' id = 'digitSignup-4' name = 'digitSignup-4' data-next = 'digitSignup-5' data-previous = 'digitSignup-3' class = 'otp-slot' />
<input type = 'tel' id = 'digitSignup-5' name = 'digitSignup-5' data-next = 'digitSignup-6' data-previous = 'digitSignup-4' class = 'otp-slot' />
<input type = 'tel' id = 'digitSignup-6' name = 'digitSignup-6' data-previous = 'digitSignup-5' class = 'otp-slot' />
</div> -->
                        <span id='otpErrSignup' class='form-error-msg'></span>

                    </div>
                    <!-- <p style = 'text-decoration:underline;text-align:center'><a class = 'send-otp button2' href = 'javascript:void(0)' onclick = 'return sentOtp()'>Send OTP</a></p> -->

                    <div class='d-flex mt-4' style='gap:10px;justify-content: right;'>
                        <p id='timertextSignup'> Resend OTP in <span id='countdowntimerSignup'>30 </span> Seconds</p>
                        <p onclick='sentOtp()' class='otp-content resend-otp'>Re-send OTP</p>
                        <!-- <p onclick='sentOtp(1)' class='otp-content resend-otp'>Re-send WhatsApp OTP</p> -->
                        <p onclick='sentOtp(2)' class='otp-content resend-otp'>Re-send Email OTP</p>
                    </div>

                <li class='text-center d-flex justify-content-center' style='flex-wrap: wrap;gap:10px;'>
                    <a href='javascript:void(0)' onclick='sentOtp()' class='button2 send-otp'>Send OTP</a>
                    <!-- <a href='javascript:void(0)' style='background: #18d26e;color:#fff !important;' onclick='sentOtp(1)'
                        class='button2 send-otp'>Send WhatsApp OTP</a> -->
                    <a href='javascript:void(0)' style='background: #0056b3;color:#fff !important;' onclick='sentOtp(2)' class='button2 send-otp'>Send Email OTP</a>
                </li>

                <!-- <p style = 'text-decoration:underline;text-align:right'><a class = 'resend-otp' href = 'javascript:void(0)' onclick = 'return sentOtp()' style = 'display:none'>Resend OTP</a></p> -->
                <!-- <p id = 'timertextSignup' style = 'display:none;text-align: right;margin-top:4px;color:#fadd6d'> Resend OTP in <span id = 'countdowntimerSignup'>30 </span> Seconds</p> -->

                <li class='text-center'>
                    <a href='javascript:void(0)' class='button2 proceedBtn' style='display:none'
                        onclick='return signupOtp()'>Sign
                        Up</a>
                </li>
                <li class='text-center'>
                    <a href='javascript:void(0)' onclick='showLoginModal()' class='or-sign-up'><span>Or</span> Login
                    </a>
                </li>
            </ul>
        </form>
    </div>
</div>
<!-- new Signup Modal /-->
<!-- POST SIGNUP -->

</div>
