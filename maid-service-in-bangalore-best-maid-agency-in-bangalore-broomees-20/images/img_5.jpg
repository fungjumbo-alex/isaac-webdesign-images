            '2 hours per day') && currentAddressData.city != 'Pune') {
        showNotifier('This service is not available in your city');
        return false;
    }

    // if ($(".box-img.active").children('.box-img-child').attr('data-city-id') != 4 && dataMain.serviceId == 15 && (currentPreferenceData.workType[0] == '0-2 months (Japa maid is required)') && currentAddressData.city == 'Pune') {
    //     showNotifier('This service is not available in your city');
    //     return false;
    // }

    if (($(".box-img.active").children('.box-img-child').attr('data-city-id') != 4 && $(".box-img.active").children(
            '.box-img-child').attr('data-city-id') != 6) && dataMain.serviceId == 15 && (currentPreferenceData
            .workType[
                0] == '0-2 months (Japa maid is required)') && (currentAddressData.city == 'Pune' ||
            currentAddressData
            .city == 'Bengaluru')) {
        showNotifier('This service is not available in your city');
        return false;
    }



    if (hsrPincode == 1 && dataMain.serviceId == '39' && JSON.stringify(workTypeArr).includes('10 hours per day')) {
        showNotifier('10-hours service is not available at your address');
        return false;
    }

    if (hsrPincode == 1 && dataMain.serviceId == '15' && (JSON.stringify(workTypeArr).includes('10 hours') || JSON
            .stringify(workTypeArr).includes('12 hours'))) {
        showNotifier('10-hours & 12-hours service is not available at your address');
        return false;
    }


    if (hsrPincode == 1) {

        shiftEndTime = (currentPreferenceData.shift.split('-').pop()).trim();
        // console.log(shiftEndTime);

        if (shiftEndTime == '19:30' || shiftEndTime == '20:00') {
            showNotifier('The last available shift time at this address is 7 PM');
            return false;
        }

    }



    // if(dataMain.serviceId == 45 ){
    //     showNotifier('This service is not at this time, please try later');
    //     return false;
    // }


    if ((dataMain.serviceId != 44 && dataMain.serviceId != 45) && (currentAddressData.city == 'Ranchi' ||
            currentAddressData.city == 'Faridabad')) {
        showNotifier('This service is not available in your city');
        return false;
        // showNotifier('This service is not available in your city, we have received your request and will get back to you shortly!');
        // service_not_availaible=true;
    }

    if ((dataMain.serviceId != 15 && dataMain.serviceId != 39 && dataMain.serviceId != 44 && dataMain.serviceId !=
            45) && (currentAddressData.city == 'Ghaziabad' || currentAddressData.city == 'ghaziabad')) {
        // showNotifier('This service is not available in your city');
        // return false;
        // showNotifier('This service is not available in your city, we have received your request and will get back to you shortly!');
        // service_not_availaible=true;
    }


    if ((dataMain.serviceId == 44 || dataMain.serviceId == 45) && currentAddressData.city == 'Bengaluru') {
        showNotifier('This service is not available in your city');
        return false;
        // showNotifier('This service is not available in your city, we have received your request and will get back to you shortly!');
        // service_not_availaible=true;
    }


    if (dataMain.serviceId == 15 && (currentAddressData.city == 'Bengaluru' || currentAddressData.city == 'Pune') &&
        workTypeArr[0].catName == '0-2 months (Japa maid is required)') {
        showNotifier('This service is not available in your city');
        return false;
    }

    if ((dataMain.serviceId == 44 || dataMain.serviceId == 45) && (currentAddressData.city == 'Bengaluru' ||
            currentAddressData.city == 'Pune')) {
        if (workTypeArr[0].catName == 'Babysitter') {
            if (workTypeArr[0].catData[0].opt[0].name == '0-2 months (Japa maid is required)') {
                showNotifier('This service is not available in your city');
                return false;
            }
        }
    }



    if ((dataMain.serviceId == 44 || dataMain.serviceId == 45) && currentAddressData.city == 'Pune') {
