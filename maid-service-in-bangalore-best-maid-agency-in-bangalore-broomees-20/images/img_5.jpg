#workShiftContainer>div.shift>div>div:nth-child(1)>span>span.irs-bar::before {
    position: absolute;
    content: url('https://broomees.com/assets/images/V3/slide.svg')"Drag";
    top: 24px;
    left: calc(50% - 20px);
    cursor: initial;
    font-size: 13px;
    padding: 0px 7px;
    border-radius: 2px;
    text-align: center;
    -webkit-animation-name: wobble;
    animation-name: wobble;
    -webkit-animation-duration: 5s;
    animation-duration: 5s;
    -webkit-animation-fill-mode: both;
    animation-fill-mode: both;
    animation-iteration-count: 1;
    z-index: 9999999;

}

/* .irs-bar::before {
        position: absolute;
        content: url('https://broomees.com/assets/images/V3/slide.svg')"Drag";
        top: 24px;
        left: calc(50% - 20px);
        cursor: initial;
        font-size: 13px;
        padding: 0px 7px;
        border-radius: 2px;
        text-align: center;
        -webkit-animation-name: wobble;
        animation-name: wobble;
        -webkit-animation-duration: 5s;
        animation-duration: 5s;
        -webkit-animation-fill-mode: both;
        animation-fill-mode: both;
        animation-iteration-count: 1;
        z-index: 9999999;

    } */

.no-before::before {
    content: none !important;
}

span.irs-bar::after {
    content: url('https://broomees.com/assets/images/V3/dots5.svg');
    position: absolute;
    top: -13px;
    left: calc(50% - 15.3px);
    /* background: #f7a22d; */
    border-radius: 4px;
    height: 29px;
    cursor: grabbing;
    box-shadow: rgb(0 0 255 / 40%) 0 1px 3px 0;
}

@-webkit-keyframes wobble {
    0% {
        -webkit-transform: none;
        transform: none;
        /* transform: scale(1.1); */
    }

    15% {
        -webkit-transform: translate3d(-45%, 0, 0) rotate3d(0, 0, 0, -5deg);
        transform: translate3d(-55%, 0, 0) rotate3d(0, 0, 0, -5deg);
        scale: 1.2;
    }

    30% {
        -webkit-transform: translate3d(35%, 0, 0) rotate3d(0, 0, 0, 3deg);
        transform: translate3d(35%, 0, 0) rotate3d(0, 0, 0, 3deg);
        scale: 1.2;

    }

    45% {
        -webkit-transform: translate3d(-30%, 0, 0) rotate3d(0, 0, 1, -3deg);
        transform: translate3d(-30%, 0, 0) rotate3d(0, 0, 1, -3deg);
        scale: 1.2;
    }

    60% {
        -webkit-transform: translate3d(25%, 0, 0) rotate3d(0, 0, 1, 2deg);
        transform: translate3d(25%, 0, 0) rotate3d(0, 0, 1, 2deg);
        scale: 1.2;
    }

    75% {
        -webkit-transform: translate3d(-20%, 0, 0) rotate3d(0, 0, 1, -1deg);
        transform: translate3d(-20%, 0, 0) rotate3d(0, 0, 1, -1deg);
        scale: 1.2;
    }

    100% {
        -webkit-transform: none;
        transform: none;
        /* scale: 1.2; */
    }
}

