//////////Pricing//////////////////
function calculatePercent1(price, percent, extraOff = 0) {
    // console.log(price,percent);
    var perc = "";
    if (isNaN(price) || isNaN(percent)) {
        perc = " ";
    } else {        
        perc = (parseFloat(price) * (100 - parseFloat(percent))) / 100;
    }

    return Math.round(parseFloat(perc) - parseFloat(extraOff));        
}

function calculateTotal(price, period) {
    return Math.round(price / period);
}

function checkUserStatus(){
    $.ajax({
        type: 'GET',
        url: '/api/userStatus',
        async: false,                     
        success: function(data, status, xhr) {
            if (status == "success") {
                // console.log('userStatusResponse',data.data);
                if(data.data == '2'){
                    logout();
                    return false;
                }
            }
        },
        error: function(jqXhr, textStatus, errorMessage) {
            reject(jqXhr.responseJSON?.message || errorMessage);
        }
    });
}

$('.chatbot-widget').hide()

// Moonis 01-10-2025 
const getServiceFromUrl = ()=> {
  const path = window.location.pathname;
  const parts = path.split('/').filter(Boolean); // removes empty segments
  const slug = parts[parts.length - 1]; // service slug is last segment
  return slug;
}

function goToStepGA4(stepNumber) {
    try{
        // GA4 event tracking
        gtag('event', 'booking_step_view_pro', {
        step_number: stepNumber,
        service_name: getServiceFromUrl()
      });
        // console.log({step_number: stepNumber,service_name: getServiceFromUrl()});
    }catch(e){
        console.log(e);
    }
  
}



