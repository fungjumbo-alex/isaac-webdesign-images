let bId = 0;

 function createBooking(transactionId, payId) {
  console.log('>>>>>>>>>>CompleteRegistration')
    triggerMetaEvent('CompleteRegistration',total)
    toggleLoader(1);

    // SOCKETS NODE JS
    const socket = io("wss://broomees.com", {
        query: {
            role: 'customer',
            id: userId
        },
        path: "/node/socket.io/",
        transports: ['websocket']
    });
    // Remove Item From Local Storage After Successfull Booking
    if (localStorage.getItem('tbroomBookSer' + dataMain.serviceId) != null) {
        localStorage.removeItem('tbroomBookSer' + dataMain.serviceId);
    }

    if (payId.includes('_') == true) {
        autoGeneratedBookingId = payId.split("_")[1];
    } else {
        autoGeneratedBookingId = payId.split("-")[4];
    }

    //  let bookingId = payId.split("_")[1];
    let bookingId = autoGeneratedBookingId;

    callGTag4();

    // Cart
    if (!acValue) {
        updateCart({
            status: '1',
        });
    } else {
        closeCart({
            status: '1',
            bookingId: bookingId,
            edit: acValue,
        });
    }


    $.ajax({
        type: 'POST',
        url: "/apibooking/createBooking",
        data: {
            transactionId: transactionId,
            bookingId: bookingId,
            serviceId: dataMain.serviceId,
            address: JSON.stringify(currentAddressData),
            preference: JSON.stringify(currentPreferenceData),
            startDate: sStartDate,
            basePrice: addZ(basePrice),
            tax: addZ(tax),
            total: addZ(total),
            offerId: (isApplied ? offer.id : '0'),
            couponAdminId: (isApplied ? offer.linkedAdminUserId : '0'),
            estimatedSalary: ul,
            workHours: hr,
            cityId: $(".box-img.active").children('.box-img-child').attr('data-city-id'),
            isLifetime: lifetimeMultiplier == 1 ? 0 : 1,
            workerCards: $('#workerCardPackageIds').val(),
            userAadhar: userAadhar,
            pro: dataMain.pro,
        },
        dataType: 'json',
        success: async function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");
            if (status == "success") {
                if (data.status) {
                   
                    showNotifier(data.message);
                    toggleLoader(0);
                    bId = data.bId;
                    sid = dataMain.serviceId;
                    // Emit new booking
                    try {
                        socket.emit("bookingGenerated", {
                            userId: userId,
                            serviceId: sid,
                            bookingId: bId,
                            address: JSON.stringify(currentAddressData),
                            preference: JSON.stringify(currentPreferenceData),
                            startDate: sStartDate,
                            estimatedSalary: ul,
                            workHours: hr,
                            workerCards: $('#workerCardPackageIds').val(),
                        });
                    } catch (e) {
                        console.log(e);
                    }

                    // if (performanceresponseID != 0) {
                    //     let x = await updatePerformanceParameter(bId);
                    // }

                    if (localStorage.getItem('performanceID') != undefined) {
                        let x = await updatePerformanceParameter(bId);

                    }

                    //  wCard Start
                    if ($('#workerCardPackageIds').val() != '') {
                        location.href = `/mybookings/details/${btoa(bId)}}`;
                        return;
                    }
                    //  wCard End

                    if(subscriptionOrBooking !== '' && subscriptionOrBooking !== 0){
                        
                        location.href = "/mybookings";
                        return;
                        
                    }

                    if(dataMain.pro == '1'){
                        
                        location.href = `/booking-success-wallet?bid=${btoa(bId)}`;
                        return;
                        
                    }

                    if(dataMain.serviceId == '14' || dataMain.serviceId == '15' || dataMain.serviceId == '19' || dataMain.serviceId == '39'){
                        packageCityId = (cityIdData == '6' || currentAddressData.city == 'Bengaluru' || cityIdData == '2' || currentAddressData.city == 'Gurgaon') ? '6' : '1';
                    }else{
                        packageCityId = (cityIdData == '6' || currentAddressData.city == 'Bengaluru') ? '6' : '1';    
                    }

                    

                    switch (parseInt(sid)) {
                        case 14:
                            location.href =
                                `/booking-success-domestichelp?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 15:
                            location.href =
                                `/booking-success-babysitter?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 19:
                            location.href =
                                `/booking-success-chef-cook?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 39:
                            location.href =
                                `/booking-success-all-rounders?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 40:
                            location.href = `/mybookings`;
                            break;
                        case 41:
                            location.href =
                                `/booking-success?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 42:
                            location.href =
                                `/booking-success?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 43:
                            location.href =
                                `/booking-success?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;
                        case 44:
                            location.href =
                                `/booking-success?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;

                        case 46:
                            location.href =
                                `/booking-success?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                            break;

                        default:
                            location.href =
                                `/booking-success?sid=${btoa(dataMain.serviceId)}&bid=${btoa(bId)}&via=${btoa(secondaryServiceId)}&cid=${btoa(packageCityId)}`;
                    }

                    //fetchPackages(dataMain.serviceId, 0);
                    // location.href="https://broomees.com/bookingSuccess?sid="+btoa(dataMain.serviceId)+"&bid="+btoa(bId)+""
                    //  setTimeout(() => {
                    //     location.href = "/mybookings";
                    // }, 1500);
                }
            } else {
                console.log("ajax failed");
            }
        },
        error: function(xhr, textStatus, errorMessage) {
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            toggleLoader(0);
            alert(xhr.responseJSON.message);
        }
    });
}

function setPaymentError(response, transactionId) {
    $.ajax({
        type: 'POST',
        url: "/apibooking/setPaymentError",
        data: {
            transactionId: transactionId,
            error_code: response.error.code,
            error_source: response.error.source,
            error_reason: response.error.reason
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");
            if (status == "success") {
                if (data.status) {
                    toggleLoader(0);
                    //console.log(response.error.metadata);
                    //alert(response.error.description);
                    //alert(response.error.step);
                    $("#wizardErr").html(data.message);
                    //rzp1.close();
                }
            } else {
                console.log("ajax failed");
            }
        },
        error: function(xhr, textStatus, errorMessage) {
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            toggleLoader(0);
            alert(xhr.responseJSON.message);
        }
    });
}


let basePrice = 9999 * 100;
let gst = 0; //18 //Float
let tax = 9999;
let total = basePrice + tax;

// if (dataMain.pro == '1') {
//     total = 0;
// }

userId = `0`;
console.log("uId", userId);


function calcPrice() {
    console.log('sTimings : ' + $('#sTiming option:selected').val());
    targetData = "";
    JSON.parse(dataMain.timeData).forEach((item) => {
        if (item.key == $('#sTiming option:selected').val()) {
            targetData = item;
            console.log('targetData ', targetData);
            return;
        }
    });

    basePrice = parseFloat(targetData.price); //Float
    tax = calculatePercent(basePrice, gst); //Float
    $("#basePrice").text(addZ(basePrice));

     // if(dataMain.serviceId == '44' || dataMain.serviceId == '45'  || $(".box-img.active").children('.box-img-child').attr('data-city-id') == 2){     
    if(dataMain.serviceId == '44' || dataMain.serviceId == '45'){     
        $("#basePrice").text(addZ(basePrice));
        $("#tax").text(addZ(tax));          
    }else if(dataMain.cityId == '6' || (dataMain.cityId == '2' && (dataMain.serviceId == '14' || dataMain.serviceId == '15' || dataMain.serviceId == '19' || dataMain.serviceId == '39'))){
        $("#basePrice").text(addZ(basePrice));
        $("#tax").text(addZ(tax));          

        // $("#basePrice").html('<span class="discount-price">49</span><span>₹2.00</span>');
        // $("#tax").text(addZ(tax));
    }else{
        $("#basePrice").html('<span class="discount-price">49</span><span>₹2.00</span>');
        $("#tax").text(addZ(tax));
    }


    $("#tax").text(addZ(tax));
    console.log('tax ' + tax);
    total = basePrice + tax;

    // if (dataMain.pro == '1') {
    //     total = 0;
    // }

    //if coupon is applied
    if (isApplied) {
        let discount = 0;
        let tempDis = calculatePercent(basePrice, offer.amount);
        if (tempDis > offer.maxAmount) {
            discount = offer.maxAmount;
        } else {
            discount = tempDis;
        }
        //$("#couponContainer").children('.left').text("Discount ("+offer.amount+"%)");
        $("#couponPrice").text(addZ(discount));
        $("#couponContainer").show();
        total = total - discount;        
        
    }

    // if(dataMain.serviceId != '44' && dataMain.serviceId != '45' && $(".box-img.active").children('.box-img-child').attr('data-city-id') != 2){
    if(dataMain.serviceId != '44' && dataMain.serviceId != '45'){


        if(dataMain.cityId == '6' || (dataMain.cityId == '2' && (dataMain.serviceId == '14' || dataMain.serviceId == '15' || dataMain.serviceId == '19' || dataMain.serviceId == '39'))){

        }else{
            if(isApplied){
                total = 0;
            }else{
                total = 2;    
            }    
        }

        
        
    }


    //Prefill changes 03/06/2025
    if (applyPrefillCoupon) {
        // let discount = (10 * basePrice) / 100
        let discount = (10 * total) / 100
        total = total - discount;
        // $("#couponPrice").text(addZ(discount));
        // $("#couponContainer").show();
    }

    

    if (isSurveyed) {
        let discount = total - 2;
        $("#couponPrice").text(addZ(discount));
        $("#couponContainer").show();
        total = 2;
    }

    

    if(total < 0){
        total = 0;
    }

    $("#total").text('₹' + addZ(total));
    $("#totalSimpl").text('₹' + addZ(total));
    // $("#total").text('₹'+0.0);


    // new popup modal
    $("#bookAmount").text(`₹` + addZ(total));

    
    if(subscriptionOrBooking == 0){
        paymentAmount = addZ(total);
        $('#package-Amount').html(`₹` + addZ(total));        
    }   


}

function calculatePercent(price, percent) {
    var perc = "";
    if (isNaN(price) || isNaN(percent)) {
        perc = " ";
    } else {
        perc = (parseFloat(price) * parseFloat(percent)) / 100;
    }
    return parseFloat(perc);
}

function addZ(num) {
    return Number(num).toFixed(2);
}


