var formBuilder = "";
var formRenderInstance = "";
var formId = ""

function RenderForm(formData, id) {
    var container = document.getElementById('fb-rendered-form');
    var formRenderOpts = {
        container,
        formData,
        dataType: 'json'
    };
    formRenderInstance = $(container).formRender(formRenderOpts);
    formId = id;
}

const fbRender = document.getElementById("fb-render");
jQuery(function($) {
    $("#fb-rendered-form").attr("onSubmit", "return validateFormBuilder(event)");
});

function validateFormBuilder(e) {
    e.preventDefault();
    console.log("IN FS");
    var userInputs = JSON.stringify($(fbRender).formRender("userData"));
    userFormData(userInputs, formId);
}

function userFormData(userInputs, formId) {
    hideFormModal();
    $.ajax({
        type: 'POST',
        url: "/api/userFormData",
        data: {
            edit: 0,
            formId: formId,
            formInput: userInputs,
            userId: userId
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");
            if (status == "success") {
                if (data.status) {
                    $("#r2b").prop("disabled", true);
                    // toggleLoader(0);
                    //console.log(response.error.metadata);
                    //alert(response.error.description);
                    //alert(response.error.step);
                    // $("#wizardErr").html(data.message);
                    swal({
                        title: "Congratulations",
                        text: "The survey promotion code has been applied and redeemed successfully!!!",
                        icon: "success",

                    }).then(function(isConfirm) {
                        if (isConfirm) {
                            isSurveyed = true;
                            calcPrice();
                        }
                    });
                    //rzp1.close();
                }
            } else {
                console.log("ajax failed");
            }
        },
        error: function(xhr, textStatus, errorMessage) {
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            toggleLoader(0);
            alert(xhr.responseJSON.message);
        }
    });
}


