let bookData = {};

function confirmOrder(payVia = '') {
    if ($("#loginName").html() != '') {

        
        checkUserStatus();

        // local storage create code start ------
        bookingInfo = [];

        let workTime = "";
        if ($('#dropdownShifts').val() == 2) {
            workTime = $('#slider1').val();
            workTime += ",";
            workTime += $('#slider2').val();
        } else {
            workTime = $('#slider1').val();
        }


        if (dataMain.serviceId == 44 || dataMain.serviceId == 45 || dataMain.serviceId == 46) {
            userAadhar = Dropzone.forElement("#dataPhotos").getAcceptedFiles();
            if (userAadhar.length == 0) {
                $('.errorDisplay').html("Please upload your Aadhar pictures!");
                $('.errorDisplay').fadeIn();
                return false;
            } else if (userAadhar.length < 2) {
                $('.errorDisplay').html("Please upload both, front & back of your Aadhar pictures!");
                $('.errorDisplay').fadeIn();
                return false;
            } else if (userAadhar.length == 2) {
                userAadhar = userAadhar.map((i) => {
                    return i.sName;
                }).join(",");
            }
        } else {
            userAadhar = ''
        }


        // if (ul < 4000) {
        //     if ($('#religiousPreference').prop('checked')) {
        //         $('#religiousPreference').trigger('click');
        //     }
        //     currentPreferenceData.religiousPreference = $("#religiousPreference").is(':checked');
        // }
        //Risabh
        if (dataMain.serviceId == 15) {
            const babyDob = $("#babyDob").val();
            const [day, month, year] = babyDob.split('-');
            let formatedDOB = `${year}-${month}-${day}`
            console.log(formatedDOB);
            currentPreferenceData.dateOfBirth = babyDob;
        }


        bookData = {
            serviceId: dataMain.serviceId,            
            address: JSON.stringify(currentAddressData),
            preference: JSON.stringify(currentPreferenceData),
            startDate: sStartDate,
            basePrice: addZ(basePrice),
            tax: addZ(tax),
            total: addZ(total),
            offerId: (isApplied ? offer.id : '0'),
            couponAdminId: (isApplied ? offer.linkedAdminUserId : '0'),
            estimatedSalary: ul,
            workHours: hr,
            workTime: workTime,
            cityId: $(".box-img.active").children('.box-img-child').attr('data-city-id'),
            isLifetime: lifetimeMultiplier == 1 ? 0 : 1,
            userAadhar: userAadhar,
            pro: dataMain.pro,
        };

        let userLoginName = $.trim($('#loginName').text());
        let userBookingAddress = $.trim($('#uAddress').text());

        if ((userLoginName == 'Test Bookiiiingg' && userBookingAddress == 'Geeta Colony Delhi  110031')) {
            bookingInfo.push(bookData)
            localStorage.setItem("tbroomBookSer" + dataMain.serviceId, JSON.stringify(bookingInfo));

            // l = JSON.parse(localStorage.getItem("broomBook"));
            // console.log("lStorage : ",l);
            // console.log("lStorage : ",l[0].serviceId);
            // console.log("lStorage : ",JSON.parse(l[0].address));
            // console.log("lStorage : ",JSON.parse(l[0].preference));

            //return false;       // it is for testing purpose if user = Test Booking && address = Geeta Colony Delhi 110031 then booking will not execute
        }

        // local storage create code End ------


        // createOrder();
        createOrderNo(payVia);

        // 19/11/24 - Cart
        // updateCart({
        //     items: JSON.stringify(bookData)
        // });
    } else {
        showLoginModal();
    }
}

async function createOrderNo(payVia) {
    if (!$('#tncCheck1').is(':checked')) {
        showtncError();
        return false;
    }
    if ($('#uAddress').text() == "") {
        $('.errorDisplay').html("Please add your address!");
        $('.errorDisplay').fadeIn();
        addressVia = 1;
        setTimeout(() => {
            $('#addAddress').trigger('click');
            $('.errorDisplay').hide();
        }, 700);
        return false;
    }

    // if(dataMain.unservicablePincode != '' && dataMain.unservicablePincode != null){
    //     unservicablePincodes = dataMain.unservicablePincode.split(',');
    //     if(unservicablePincodes.includes(currentAddressData.pincode)){    
