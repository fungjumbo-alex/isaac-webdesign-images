    <script>
  // Ensure your PHP backend populates this correctly
  window.USER_DATA = null;

  function getActiveUserData() {
    const windowData = window.USER_DATA || {};
    
    return {
        name: windowData.name || $("#loginName").text().trim() || "Guest",
        email: windowData.email || "",
        contact: windowData.contact || $("#loginContact").val() || ""
    };
}

  // Standard SHA-256 Hashing Condition
  async function hashValue(value) {
      if (!value || value === "") return null;
      const msgUint8 = new TextEncoder().encode(value.trim().toLowerCase());
      const hashBuffer = await crypto.subtle.digest('SHA-256', msgUint8);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  // The main trigger design
async function triggerMetaEvent(eventName, amountS) {
   const user = getActiveUserData();

    // If you absolutely require a name or contact to proceed:
    if (!user.name && !user.contact) {
        console.warn("Meta Event skipped: No user identity found.");
        return;
    }

    // Design: Generate a unique ID for deduplication
    const eventID = 'evt_' + Date.now();

    /* 1. Browser Pixel */
    if (typeof fbq === 'function') {
        let pixelParams = {};
        if (eventName === "Purchase") {
            pixelParams = {
                currency: 'INR',
                value: amountS || 0
            };
        }
        fbq('track', eventName, pixelParams, { eventID: eventID });
    }

    /* 2. Conversions API Setup */
    const ACCESS_TOKEN = 'EAAVDNXstoScBQecoPVNPWDK7VRdoen1RSZBZCjNAsoFt4Bc2ulx44DrZCwy97jxUcBlZAczU1awPndpJnutly1mZABGOZA6Ve2jH7nZBAumg3GZCaVkzGR868FXQfZCGDXttDOMvu1VrP5UbhmQ5ft9epCfKPdqmgfU0zZCY1W0cNbYLIomgABIjsZAIBcZBPSDUAfymNwZDZD';
    const PIXEL_ID = '922624396218886';
    const URL = `https://graph.facebook.com/v18.0/${PIXEL_ID}/events?access_token=${ACCESS_TOKEN}`;

    /* 3. Safe Address Handling (Null-check design) */
    let city = "";
    let pincode = "";

    // Check if addressJsonData exists and the specific index is not null/undefined
    if (typeof addressJsonData !== 'undefined' && addressJsonData !== null && 
        typeof selectedAddressIndex !== 'undefined' && addressJsonData[selectedAddressIndex]) {
        city = addressJsonData[selectedAddressIndex].city || "";
        pincode = addressJsonData[selectedAddressIndex].pincode || "";
    }

    /* 4. Build the Payload Object */
    const eventData = {
        "event_name": eventName,
        "event_time": Math.floor(Date.now() / 1000),
        "action_source": "website",
        "event_id": eventID,
        "user_data": {
            "client_user_agent": navigator.userAgent,
            "em": [await hashValue(window.USER_DATA.email)],
            "ph": [await hashValue(window.USER_DATA.contact)],
            "fn": [await hashValue(window.USER_DATA.name)],
            "ln": [await hashValue(window.USER_DATA.lastName || "")],
            "ct": [await hashValue(city)],
            "zp": [await hashValue(pincode)]
        }
    };

    // --- CONDITION: Add custom_data ONLY for Purchase ---
    
        eventData.custom_data = {
            "currency": "INR",
            "value": amountS || 0
        };
    
    const payload = {
        "data": [eventData],
        "test_event_code": "TEST69713"
    };

    console.log(`Payload for ${eventName}:`, payload);

    /* 5. Execution */
    fetch(URL, { 
        method: 'POST', 
        headers: {'Content-Type': 'application/json'}, 
        body: JSON.stringify(payload) 
    })
    .then(res => res.json())
    .then(data => console.log('Meta API Response:', data))
    .catch(err => console.error('Meta API Error:', err));
}
</script>
