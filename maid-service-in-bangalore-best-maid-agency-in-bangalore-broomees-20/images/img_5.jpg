                numOfHrInShift1.innerHTML =
                    `<option disabled selected value="-1">Select duration for 1st shift</option>`
            }
            numOfHrInShift2.innerHTML +=
                `<option value="${intr.value}" data-remainingDisplay="${intr.remainingDisplay}" data-remainingValue="${intr.remainingValue}" >${intr.display}</option>`
            numOfHrInShift1.innerHTML +=
                `<option value="${intr.value}" data-remainingDisplay="${intr.remainingDisplay}" data-remainingValue="${intr.remainingValue}" >${intr.display}</option>`
