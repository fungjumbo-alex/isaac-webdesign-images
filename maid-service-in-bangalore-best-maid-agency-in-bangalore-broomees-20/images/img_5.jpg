function getServiceDetails(cityId) {
    // console.log("pNum", pNum)
    selectedCityId = cityId
    $.ajax({
        type: 'GET', // http method
        url: '/api/getServicesData',
        data: {
            slug: $("#slug").val(),
            cityId: cityId,
        },
        dataType: 'json',
        success: function(data, status, xhr) {
