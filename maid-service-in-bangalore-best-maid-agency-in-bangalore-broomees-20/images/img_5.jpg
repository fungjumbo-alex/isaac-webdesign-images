function handleShift1Change() {
    if ($('#dropdownShifts').val() == 1) {
        //Prefill changes 03/06/2025
        if (prefillDone == false) {
            renderPage(1)
            prefillDone = true
        }

    } else if ($('#dropdownShifts').val() == 2) {
        let shift2Hr = +document.querySelector('#numOfHrInShift2 option:checked').value
        let s1EndTime = +document.querySelector('#shift1Inp option:checked').getAttribute('data-endTime-value')

        let slots = generateShift2ForS2(shift2Hr, s1EndTime)
        let shift2InpEle = document.getElementById('shift2Inp')

        slots.map((slot, i) => {
            if (i == 0) shift2InpEle.innerHTML =
                `<option disabled selected value="-1">Select 2nd shift start time</option>`


            shift2InpEle.innerHTML +=
                `<option value="${slot.startTime.value}" data-endTime-display="${slot.endTime.display}" data-endTime-value="${slot.endTime.value}">${slot.startTime.display}</option>`



        })
        //Prefill changes 03/06/2025
        if (prefillDone == false) {
            let shift2Full = decodedPreference.shift.split(' ')[1]
            let shift2 = shift2Full.split('-')[0]
            const decimalValue = timeStringToDecimal(shift2)
            $('#shift2Inp').val(decimalValue);
            handleShift2Change()

        }
    }

    renderShifts()
    pricerefresh()
}

