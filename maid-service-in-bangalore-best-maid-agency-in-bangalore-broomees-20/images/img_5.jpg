function formBuilderShow() {
    $.ajax({
        type: 'GET', // http method
        url: '/api/getformBuilderShow',
        data: {},
        dataType: 'json',
        success: function(data, status, xhr) {
            if (status == "success") {
                if (data.status) {
                    let res = data.data;
                    let content = ``;
                    console.log("FB", res);
                    $("#surveyModalLabel").html(res[0].name);
                    res.forEach(element => {
                        RenderForm(element.formData, element.id);
                    });
                } else {
                    console.log(data.log);
                }
            } else {
                alert("Upload Failed");
            }
        },
        error: function(jqXhr, textStatus, errorMessage) {
            console.log(jqXhr.responseJSON.message);
        }
    });
}
