function offersList(pincode) {
    $.ajax({
        type: 'GET', // http method
        url: '/api/getOffersList',
        data: {
            pincode
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            if (status == "success") {
                if (data.status) {
                    let res = data.data;
                    let content = ``;
                    res.forEach(element => {
                        content += `<div class="announcement">
                            <div class="text">
                                <span class="is-desktop">
                                    Use Coupon Code for <strong>${element.name}</strong>. ${element.terms}
                                </span>
                                <span class="is-mobile">Use Coupon Code for <strong>${element.name}</strong></span>
                            </div>
                            <div class="coupon">
                                <input type="text" value="${element.code}" id="couponCode" readonly />
                                <div class="tooltip">
                                    <button data-attr="${element.code}" onclick="myFunction(this)">
                                        <span class="tooltiptext" id="myTooltip">Click to apply</span>
                                        Copy
                                    </button>
                                </div>
                            </div>
                            </div>`;
                    });
                    $("#couponDynamic").html(content);
                } else {
                    console.log(data.log);
                }
            } else {
                alert("Upload Failed");
            }
        },
        error: function(jqXhr, textStatus, errorMessage) {
            console.log(jqXhr.responseJSON.message);
        }
    });
}

function myFunction(curr) {
    console.log('myFunc', $(curr).attr("data-attr"));
    $("#code").val($(curr).attr("data-attr"));
    resetofferUI();
    if ($("#code").val() != '') {
        applyOfferCode(1);
    }
}

const resetofferUI = () => {
    $('#applyOffer').css({
        'border-color': '#f7d022',
        'color': '#f7d022'
    });
    $('#applyOffer').text('Apply');
    $('#code').css({
        'border-color': '#f7d022'
    });
    $("#codeTerms").text("");
    $("#couponContainer").hide();
    isApplied = false;
    calcPrice();
};



/*coupon code*/
function applyOfferCode(via) {
    var code = $("#code").val().toUpperCase().trim();
    if (code == "") {
        setCodeErr("Invalid coupon code!");
    } else {
        if (!isApplied || via == 1) {
            setCodeErr();
            toggleLoader(1);
            $.ajax({
                type: 'GET',
                url: "/api/checkOffer",
                data: {
                    code
                },
                dataType: 'json',
                success: function(data, status, xhr) {
                    console.log('status: ' + status + ', data: ' + ":" + data + ":");
                    if (status == "success") {
                        if (data.status) {
                            toggleLoader(0);
                            offer = data.data[0];
                            if (offer) {
                                if (total >= offer.minAmount) {
                                    console.log('IN', total);
                                    isApplied = true;
                                    $('#applyOffer').css({
                                        'border-color': 'green',
                                        'color': 'green'
                                    });
                                    $('#applyOffer').text('Applied');
                                    $('#code').css({
                                        'border-color': 'green'
                                    });
                                    $("#codeTerms").html("<strong>" + offer.name + "</strong><br>" + offer
                                        .terms);
                                    setTimeout(() => {
                                        $('#myModal').modal('hide');
                                    }, 1200);
                                    calcPrice();
                                } else {
                                    setCodeErr("Offer valid on the min amount of ₹" + offer.minAmount +
                                        "!");
                                }
                            } else {
                                setCodeErr("Invalid coupon code!");
                            }
                        }
                    } else {
                        console.log("ajax failed");
                    }
                },
                error: function(xhr, textStatus, errorMessage) {
                    console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
                    toggleLoader(0);
                    alert(xhr.responseJSON.message);
                }
            });
        }

    }
}
/*applycoupon end*/

