async function checkZoneForCook() {

    return new Promise((resolve, reject) => {

        $.ajax({
            type: 'GET', // http method
            url: '/api/getZoneDataByCityService',
            data: {
                serviceId: '19',
                cityId: dataMain.cityId
            },
            dataType: 'json',
            success: function(data, status, xhr) {
                if (status == "success") {
                    if (data.status) {
                        let dataMain = data.data[0];
                        console.log('zones => ', dataMain);

                        let inclusionZones = JSON.parse(dataMain.inclusions);
                        let exclusionZones = JSON.parse(dataMain.exclusions);

                        console.log('inclusion', inclusionZones)
                        console.log('exclusion', exclusionZones)


                        let isNotWithinPolygon = inclusionZones.every((incZone) => {
                            if (pointInPolygon({
                                    lat: currentAddressData.latlng.split(",")[0],
                                    lng: currentAddressData.latlng.split(",")[1]
                                }, incZone)) {
                                return false
                            }
                            return true

                        })

                        console.log("isNotWithinPolygon", isNotWithinPolygon)

                        let isWithinPolygon = false

                        if (!isNotWithinPolygon) {
                            isWithinPolygon = exclusionZones.every((excZone) => {
                                if (pointInPolygon({
                                        lat: currentAddressData.latlng.split(",")[
                                            0],
                                        lng: currentAddressData.latlng.split(",")[1]
                                    }, excZone)) {
                                    return false
                                }
                                return true
                            })
                        }

                        console.log("isNotWithinPolygon", isNotWithinPolygon)


                        if (!isWithinPolygon) {
                            // showNotifier('This service is not available at your location!');
                            // showNotifier('2 shift is not allowed in this location',5000);
                            console.log("reject false")
                            resolve(false)
                        } else {
                            console.log("resolv true")

                            resolve(true)

                        }

                    } else {
                        console.log("Error, Please Rerty!");

                        resolve(false)
                    }
                } else {
                    alert("Upload Failed");
                    resolve(false)

                }
            },
            error: function(jqXhr, textStatus, errorMessage) {
                console.log(jqXhr.responseJSON.message);
                resolve(false)

            }
        });

    })



}


function simplTransaction() {
    toggleLoader(1);
    $.ajax({
        type: 'POST',
        url: "/api/simplTransaction",
        data: {
            userId: userId,
            total: simplBookingAmount,
            bookingData: JSON.stringify(bookData),
            token: $('#simplToken').val(),
            tId: $('#simplTransactionId').val(),
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");

            if (status == "success") {
                // simplTransactionRes = JSON.parse(data.data);
                // console.log('simplTransactionRes : ',simplTransactionRes);    
                toggleLoader(0);

                if (data.message == 'Transaction Created') {
                    simplPayRes = JSON.parse(data.data);
                    console.log(data.transactionId);
                    console.log(simplPayRes.data.transaction.id);
                    // alert('Transaction Done');            
                    createBooking(data.transactionId, simplPayRes.data.transaction.id);
                } else {
                    console.log(data.message);
                }

            } else {
                toggleLoader(0);
                console.log("ajax failed");
            }

        },
        error: function(xhr, textStatus, errorMessage) {
            toggleLoader(0);
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            $("#otpErr").html(xhr.responseJSON.message);
            $("#loginOtpsec input").addClass('form-error-input');
        }
    });
}


function simplIframe() {
    toggleLoader(1);
    $.ajax({
        type: 'POST',
        url: "/api/getTransactionId",
        data: {
            userId: userId,
            total: simplBookingAmount, //this should be dynamic - Moonis
            bookingData: JSON.stringify(bookData),
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");

            if (status == "success") {

                toggleLoader(0);

                if (data.message == 'Transaction Added') {



                    console.log(data.transactionId);
                    $('#simplTransactionId').val(data.transactionId);


                    $('#simplIframeModal').modal('show');
                    sUrl = $('#simplRedirectionUrl').val();
                    sUrl = sUrl + '&merchant_payload=' + data.transactionId + ',' + window.location.href;
                    var iframe = document.getElementById('simplIframe');
                    console.log('sUrl : ', sUrl);
                    iframe.src = sUrl;

                    iframeInterval = setInterval(checkIframeContent, 1000)

                    simplTokenInterval = setInterval(findSimplToken, 3000);





                } else {
                    console.log(data.message);
                }

            } else {
                toggleLoader(0);
                console.log("ajax failed");
            }

        },
        error: function(xhr, textStatus, errorMessage) {
            toggleLoader(0);
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            $("#otpErr").html(xhr.responseJSON.message);
            $("#loginOtpsec input").addClass('form-error-input');
        }
    });

    // $('#simplIframeModal').modal('show');    
    // sUrl =  $('#simplRedirectionUrl').val();
    // var iframe = document.getElementById('simplIframe');
    // console.log('sUrl : ',sUrl);
    // iframe.src = sUrl;    
}


function checkIframeContent() {
    if ($("#simplIframe").contents().find("body").is(':empty')) {
        $('#simplIframeModal').modal('hide');
        clearInterval(iframeInterval);
    }
}

function findSimplToken() {
    $.ajax({
        type: 'POST',
        url: "/api/findSimplToken",
        data: {
            tId: $('#simplTransactionId').val(),
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");

            if (status == "success") {
                if (data.message == 'Found') {
                    if (data.data[0].razorpay_signature != null) {
                        // console.log(data.data[0].razorpay_signature);
                        $('#simplIframeModal').modal('hide');
                        clearInterval(simplTokenInterval);
                        $('#simplToken').val(data.data[0].razorpay_signature);
                        simplTransaction();
                    } else {
                        console.log('Not Found Token');
                    }


                } else {
                    console.log(data.message);
                }

            } else {
                console.log("ajax failed");
            }

        },
        error: function(xhr, textStatus, errorMessage) {
            toggleLoader(0);
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            $("#otpErr").html(xhr.responseJSON.message);
            $("#loginOtpsec input").addClass('form-error-input');
        }
    });
}


// STEP 1
function createOrder() {    

    if(subscriptionOrBooking !== '' && subscriptionOrBooking !== 0){
        // Booking & Subscription;    
        if(!bookData.hasOwnProperty('paidFor')){
            bookData.paidFor = subscriptionOrBooking;
            bookData.paymentFor = 'Booking & Subscription';
        }
    }else{
        // only booking        
        if(!bookData.hasOwnProperty('paidFor')){
            bookData.paidFor = subscriptionOrBooking;
            bookData.paymentFor = 'Booking';            
        }        
    }

    if (!$('#tncCheck1').is(':checked')) {
        showtncError();
        return false;
    }
    // if (!$(".three-column").children().find('.box').hasClass('active-border')) {
    //     $('#tncErr').html("<p class='form-error-message'>Please select an address to proceed!!!</p>");
    //     return false;
    // }
    toggleLoader(1);

    $.ajax({
        type: 'POST',
        url: "/apibooking/createOrder",
        data: {
            // total: Math.round(total * 100),
            total: Math.round(paymentAmount * 100),            
            bookingData: JSON.stringify(bookData)
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            console.log('status: ' + status + ', data: ' + ":" + data + ":");
            if (status == "success") {
                if (data.status) {
                    toggleLoader(0);
                    initPayment(data);
                    // callGTagF3(Math.round(total * 100));
                }
            } else {
                console.log("ajax failed");
            }
        },
        error: function(xhr, textStatus, errorMessage) {
            console.log('Error:' + errorMessage + ":::" + xhr.responseJSON.message);
            toggleLoader(0);
            alert(xhr.responseJSON.message);
        }
    });
}
var rzp1 = "";
// STEP 2
function initPayment(o) {

    if(subscriptionOrBooking !== '' && subscriptionOrBooking !== 0){
        payFor = " Booking & Subscription";          
    }else{
        payFor = " Booking";
    }
    

    var options = {
        "key": o.apiKey, // Enter the Key ID generated from the Dashboard
        "amount": o
            .total, // Amount is in currency subunits. Default currency is INR. Hence, 50000 refers to 50000 paise
        "currency": "INR",
        "name": "Broomees",
        "description": dataMain.name + payFor,
        //"image": "https://example.com/your_logo",
        "order_id": o.orderId, //This is a sample Order ID. Pass the `id` obtained in the response of Step 1
        "handler": function(response) {

            console.log(response);

            validateOrder(response, o.transactionId);


        },
        "prefill": {
            "name": `` != '' ? `` : $("#loginName").text(),
            "email": ``,
            "contact": `` != '' ? `` : $("#loginContact")
                .val()
        },
        "notes": {
            "address": "Broomees Office, Hauz Khas"
        },
        // "theme": {
        //     "color": "#F7D022"
        // }
    };
    rzp1 = new Razorpay(options);
    rzp1.on('payment.failed', function(response) {
        setPaymentError(response, o.transactionId);
    });
    //Main call
    rzp1.open();

}

