offset = 0;
function loadChat() {
    if (!localStorage.getItem("axval")) {
         addBotMessage(
        "Hello! How can I assist you today with Broomees services?"
      );
        return;
    }
  try {
    const myHeaders = new Headers();
    myHeaders.append("Content-Type", "application/json");
    myHeaders.append("x-session-id", sessionId);
    myHeaders.append("token", localStorage.getItem("axval"));

    fetch(aibaseurl + "/api/conversatation?offset=" + offset, {
      method: "GET",
      headers: myHeaders,
    })
      .then((response) => response.json())
      .then((result) => {
        if (result) {
          if (result.messages.length > 0) {
            populatePreviousMessage(result.messages);
          } else {
            $("#lodeButton")
              .html("No message")
              .css({ visibility: "visible", background: "#ffffff" })
              .off("click");
          }
        }
      })
      .catch((error) => console.error(error));
    if (offset == 0)
      addBotMessage(
        "Hello! How can I assist you today with Broomees services?"
      );
  } catch (err) {
    console.error("Error loading chat:", err);
  }
}


function loadFirstChat() {
    if (!localStorage.getItem("axval")) {
         addBotMessage(
        "Hello! How can I assist you today with Broomees services?"
      );
        return;
    }
  try {
    const myHeaders = new Headers();
    myHeaders.append("Content-Type", "application/json");
    myHeaders.append("x-session-id", sessionId);
    myHeaders.append("token", localStorage.getItem("axval"));

    fetch(aibaseurl + "/api/conversatation", {
      method: "PUT",
      headers: myHeaders,
    })
      .then((response) => response.json())
      .then((result) => {
        if (result) {
          if (result.messages.length > 0) {
            $('#messages').html('')
            populatePreviousMessage(result.messages);
          }
        }
      })
      .catch((error) => console.error(error));
  } catch (err) {
    console.error("Error loading chat:", err);
  }
}

