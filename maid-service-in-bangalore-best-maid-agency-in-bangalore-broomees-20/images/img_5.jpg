$('#address-body .addCheck').attr('onclick', 'addressSelect(this)');

function addressSelect(elem) {


    //purple zone code
    purpleZoneMultiplier = 1;
    redZoneReligiousPreference = 0;
    redZoneLanguagePreference = 0;

    //pCode Discount
    selectedAddressIndex = $(elem).attr('id');
    selectedAddressIndex = selectedAddressIndex.charAt(selectedAddressIndex.length - 1);
    // console.log('elem : ', selectedAddressIndex);

    $('.addCheck').prop('checked', false);
    $(elem).prop('checked', true);

    $('.text-add').removeClass('border-address');
    $(elem).parent().addClass('border-address');

    i = $(elem).val();
    $('#addressId').val(i);
    selectedAdd = $('#textAddress_' + i).html();
    $('#uAddress').html(selectedAdd);
    currentAddressData = addressJsonData.filter((a) => {
        return a.id == i
    })[0];

    //pCode Discount
    pincodeDiscountSet();

    showNotifier('Address Selected');
    setTimeout(() => {
        $(".close").trigger('click');
    }, 300);


}

$('.edit-address').attr('onclick', 'editAdd(this)');

function editAdd(elem) {
    $('#addAddress').click();
    $('#address-form #form-title').html("Edit Address");
    $('#address-form #address-save-btn').html("Update");
    addId = $(elem).attr('addressId');
    address = $(elem).attr('address');
    pincode = $(elem).attr('pincode');
    city = $(elem).attr('city');
    $('#addressId').val(addId);
    $('#address').val(address);
    $('#pincode').val(pincode);
    $('#city').val(city);
}

