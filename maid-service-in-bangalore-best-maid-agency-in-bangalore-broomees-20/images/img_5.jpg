/*  Hourglass  */
/* */
/* Animation */
/* */
#hourglass {
    opacity: 1;
    color: #6a1b9a;
}

#hourglass i {
    opacity: 0;
    animation: hourglass 2.4s ease-in infinite, hourglass-spin 2.4s ease-out infinite;
}

#hourglass>i:nth-child(1) {
    color: #ffc400;
    animation-delay: 0s, 0s;
}

#hourglass>i:nth-child(2) {
    color: #ffc400;
    animation-delay: 0.6s, 0s;
}

#hourglass>i:nth-child(3) {
    color: #ffab00;
    animation-delay: 1.2s, 0s;
}

#hourglass>i:nth-child(4) {
    color: #ffc400;
    animation-delay: 1.8s, 0s;
}

#hourglass>i:nth-child(4) {
    animation: hourglass-end 2.4s ease-in infinite, hourglass-spin 2.4s ease-out infinite;
}

#hourglass>i:nth-child(5) {
    color: #006064;
    opacity: 1;
    animation: hourglass-spin 2.4s ease-out infinite;
}

#numOfHrInShift2::-ms-expand {
    display: none;
}

#numOfHrInShift2 {
    -webkit-appearance: none;
    -moz-appearance: none;
    text-indent: 1px;
    text-overflow: '';
}

@keyframes hourglass {
    0% {
        opacity: 1;
    }

    24% {
        opacity: 0.9;
    }

    26% {
        opacity: 0;
    }
}

@keyframes hourglass-end {
    0% {
        opacity: 0;
    }

    70% {
        opacity: 0;
    }

    75% {
        opacity: 1;
    }

    100% {
        opacity: 1;
    }
}

@keyframes hourglass-spin {
    75% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(180deg);
    }
}

#sliderdd .irs--round .irs-handle {
    border: 4px solid #ccd3cc;
    pointer-events: none;
}

.timelable {
    font-size: 14px;
    color: #868686;
    font-weight: 400;

}

.time_container {
    display: flex;
    /* align-items: center; */
    align-items: flex-end;
    gap: 20px;
    padding-top: 0px;
}

.duration_text {
    font-size: 14px;
    color: #868686;
    font-weight: 400;
    margin: 0;
    margin-bottom: 5px;
}

select {
    color: #ff0000;
}

.hidden {
    display: none !important
}

.date {
    cursor: pointer;
}

input#babyDob {
    cursor: pointer;
}

span.discount-price {
    text-decoration: line-through;
    color: grey;
    margin-right: 4px;
}

.container-main .container-main-section:nth-child(1) {
    width: 65%;
}

.container-main .container-main-section:nth-child(2) {
    margin-left: 20px;
    text-align: right
}

.container-main {
    display: flex;
    justify-content: space-between;
}

.d-flex.align-items-center.orange-con-title-con {
    width: fit-content;
}

.pricing-card-item.active {
    border: 4px solid #684e25d4;
    transform: scale(1.02);
   
}

span#discount-Amount {
    color: #ffffffcc;
    font-weight: 400;
    text-decoration: line-through;
}

span#package-Amount {
    color: white;
text-decoration: none;
    font-weight: 600;
}
#container{
    overflow-y: hidden;
}
