//Prefill changes 03/06/2025
let decodedPreference = {};
let decodedItem = {};
let currCityId
let prefillDone = true
let applyPrefillCoupon = false
async function decodeAcParameter() {
    try {
        const url = new URL(window.location.href);
        acValue = url.searchParams.get('ac');

        if (!acValue) {
            await getServiceDetails('1');
            prefillDone = true
            applyPrefillCoupon = false
            return {
                error: 'No "ac" parameter found in URL'
            };
        }

        const decoded = atob(acValue);

        // Wrap AJAX in Promise for async/await
        const data = await new Promise((resolve, reject) => {
            $.ajax({
                type: 'GET',
                url: '/api/abandoned_paginated',
                data: {
                    id: decoded
                },
                dataType: 'json',
                success: function(data, status, xhr) {
                    if (status == "success") {
                        resolve(data);
                    } else {
                        reject(new Error("Request failed"));
                    }
                },
                error: function(jqXhr, textStatus, errorMessage) {
                    reject(jqXhr.responseJSON?.message || errorMessage);
                }
            });
        });

        if (data.status) {
            revealBookingSection('bookingV3Container');
            const res = data.data[0];
            prefillDone = false
            applyPrefillCoupon = true
            const item = JSON.parse(res.items);
            const preference = JSON.parse(item.preference);
            decodedPreference = preference;
            decodedItem = item
            currCityId = currCityId
            getServiceDetails(item.cityId);

            // $('#datePicker').children('input').val(item.startDate)

            // if (item.serviceId === '15') { // Fixed assignment (=) to comparison (===)
            //     await submitBabyDob(preference.dateOfBirth);
            // } 

            console.log('Preference:', preference);
            console.log('Item:', item);
        } else {
            alert("Error, Please Retry!");
        }

        console.log("Decoded:", decoded);
    } catch (e) {
        alert(e.message);
        console.error(e);
        return {
            error: e.message
        };
    }
}

