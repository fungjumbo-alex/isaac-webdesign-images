function renderShifts() {
    let numOfHrInShift2Ele = document.getElementById('numOfHrInShift2')
    let shift1InpEle = document.getElementById('shift1Inp')
    let numOfShiftsEle = document.getElementById('dropdownShifts')
    let shift2InpEle = document.getElementById('shift2Inp')

    $('.errorDisplay').hide();

    if (numOfShiftsEle.value == 1) {
        $('#numOfHrInShift2Container').hide()
        $('#numOfHrInShift2Con').hide()
        $('.shift1InputContainer').show()
        $('.shift2InputContainer').hide()
        // $('#totalEstimatedHoursContainer').hide()
        $('#totalEstimatedHoursContainer').show()

        if (shift1InpEle.value == -1) {
            $('#s1EndTime').hide()
            $('#startTimeLable').hide()
            $('.shift2InputContainer').hide()
            document.getElementById('endTimeForS1').innerText = ''
        } else {
            let endTimeS1 = document.querySelector('#shift1Inp option:checked').getAttribute('data-endTime-display')
            document.getElementById('endTimeForS1').innerText = endTimeS1
            $('#s1EndTime').show()
            $('#startTimeLable').show()
        }
    } else {
        $('#numOfHrInShift2Container').show()
        $('#totalEstimatedHoursContainer').show()
        if (numOfHrInShift2Ele.value == -1) {
            $('#totalEstimatedHoursContainer').show()
            $('.shift1InputContainer').hide()
            $('.shift2InputContainer').hide()
            $('#s1EndTime').hide()
            $('#startTimeLable').hide()
            $('#numOfHrInShift2Con').hide()
            $('#numOfHrInShift1Dur').hide()

        } else {
            // $('#totalEstimatedHoursContainer').hide()
            $('.shift1InputContainer').show()
            $('#numOfHrInShift2Con').show()
            $('#numOfHrInShift1Dur').show()
            if (shift1InpEle.value == -1) {
                $('#s1EndTime').hide()
                $('#startTimeLable').hide()
                $('.shift2InputContainer').hide()
                document.getElementById('endTimeForS1').innerText = ''
            } else {
                let endTimeS1 = document.querySelector('#shift1Inp option:checked').getAttribute('data-endTime-display')
                document.getElementById('endTimeForS1').innerText = endTimeS1
                $('#s1EndTime').show()
                $('#startTimeLable').show()
                $('.shift2InputContainer').show()

                if (shift2InpEle.value == -1) {
                    $('#s2EndTime').hide()
                    $('#start2TimeLable').hide()
                    document.getElementById('endTimeForS2').innerText = ''
                } else {
                    let endTimeS2 = document.querySelector('#shift2Inp option:checked').getAttribute(
                        'data-endTime-display')
                    document.getElementById('endTimeForS2').innerText = endTimeS2
                    $('#s2EndTime').show()
                    $('#start2TimeLable').show()
                }

            }
        }
    }
}

function calcDynamicPrice() {

    // console.log("calcDynamicPrice");
    // $(".dynamic-price-container").fadeIn();
    dynamicPrice = 0;
    dynamicMinutes = 0;
    console.log("calcDynamicPrice", workTypeArr);
    workTypeArr.forEach((c) => {
        let dp1 = 0;
        let dm1 = 0;

        // bengaluru changes
        if (dataMain.serviceId == 15 && cityIdData == '6' && c.catName !=
