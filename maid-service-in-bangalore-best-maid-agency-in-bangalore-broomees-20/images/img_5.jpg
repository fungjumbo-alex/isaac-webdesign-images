function handleNumOfHrInShift1Change(sf1Val = '') {
    let numOfHrInShift1 = document.getElementById('numOfHrInShift1')
    let numOfHrInShift2 = +document.querySelector('#numOfHrInShift1 option:checked').getAttribute('data-remainingvalue')

    document.getElementById('numOfHrInShift2').value = numOfHrInShift2
    let shift1InpEle = document.getElementById('shift1Inp')
    let slots = generateShift1ForS2(+numOfHrInShift2, +hr)
    let selected2ndShiftOptionEle = document.querySelector('#numOfHrInShift2 option:checked')
    // let numOfHrInShift1 = document.getElementById('numOfHrInShift1')

    // $('#numOfHrInShift1').html(`<option selected value="-1">${selected2ndShiftOptionEle.getAttribute('data-remainingdisplay')}</option>`)
    numOfHrInShift1.value = +selected2ndShiftOptionEle.getAttribute('data-remainingvalue')

    slots.map((slot, i) => {
        if (i == 0) shift1InpEle.innerHTML =
            `<option disabled selected value="-1">Select 1st shift start time</option>`
        shift1InpEle.innerHTML +=
            `<option value="${slot.startTime.value}" data-endTime-display="${slot.endTime.display}" data-endTime-value="${slot.endTime.value}">${slot.startTime.display}</option>`
    })
    //Prefill changes 03/06/2025
    if (prefillDone == false) {
        $('#shift1Inp').val(sf1Val);
        handleShift1Change()
    }
    renderShifts()
}

function generateShift1ForS1(estimatedHours, startTime = new Date(new Date().setHours(7, 0, 0, 0)), endTime = new Date(
    new Date().setHours(20, 0, 0, 0)), slotIntervalInMin = 30) {
    let roundedEstimatedHours = roundTime(estimatedHours);

    //Risabh
    let maxStartTime;
    if (roundedEstimatedHours == 0.5) {
        maxStartTime = new Date(new Date().setHours(19, 0, 0, 0))
    } else {
        maxStartTime = new Date(new Date(endTime).setMinutes(endTime.getMinutes() - (roundedEstimatedHours * 60)));
    }

    let currentSlotTime = new Date(startTime);
    let slots = [];
    while (true) {
        if (currentSlotTime > maxStartTime)
            break;
        let currentEndTime = new Date(currentSlotTime);
        currentEndTime = new Date(currentEndTime.setMinutes(currentEndTime.getMinutes() + (roundedEstimatedHours *
            60)));
        slots.push({
            startTime: {
                display: Intl.DateTimeFormat('en-IN', {
                    timeStyle: 'short'
                }).format(currentSlotTime).toUpperCase(),
                value: (currentSlotTime.getHours() * 100) + (currentSlotTime.getMinutes() / 60 * 100)
            },
            endTime: {
                display: Intl.DateTimeFormat('en-IN', {
                    timeStyle: 'short'
                }).format(currentEndTime).toUpperCase(),
                value: (currentEndTime.getHours() * 100) + (currentEndTime.getMinutes() / 60 * 100)
            }
        });
        currentSlotTime = new Date(new Date().setHours(currentSlotTime.getHours(), currentSlotTime.getMinutes() +
            slotIntervalInMin, 0, 0));
    }
    return slots;
}

function generateShift1ForS2(shift2Hr, estimatedHours, startTime = new Date(new Date().setHours(7, 0, 0, 0)), endTime =
    new Date(new Date().setHours(20, 0, 0, 0)), slotIntervalInMin = 30) {
    let roundedShift2Hr = roundTime(shift2Hr);
    let roundedEstimatedHours = roundTime(estimatedHours);
    let shift1Hr = roundedEstimatedHours - roundedShift2Hr;
    let gapHr = 2


    shiftGaps.every((gap) => {
        if (gap.serviceId == dataMain.serviceId) {
            gapHr = gap.gapInMinutes / 60
            return false
        }
        return true
    })

    let maxEndHr = roundTime(shift2Hr + gapHr);
    let maxStartTime;
    //Risabh
    if (shift2Hr == 0.5) {
        maxStartHour = 17 - shift1Hr;
        maxStartMin = ((shift1Hr / 0.5) % 2) === 1 ? 30 : 0;
        maxStartTime = new Date(new Date().setHours(maxStartHour, maxStartMin, 0, 0))
    } else {
        maxStartTime = new Date(endTime.setMinutes(endTime.getMinutes() - (maxEndHr * 60) - (shift1Hr * 60)));
    }
    let currentSlotTime = new Date(startTime);
    let slots = [];
    // console.log(shift2Hr, shift1Hr, maxEndHr)
    while (true) {
        if (currentSlotTime > maxStartTime)
            break;
        let currentEndTime = new Date(currentSlotTime);
        currentEndTime = new Date(currentEndTime.setMinutes(currentEndTime.getMinutes() + (shift1Hr * 60)));
        slots.push({
            startTime: {
                display: Intl.DateTimeFormat('en-IN', {
                    timeStyle: 'short'
                }).format(currentSlotTime).toUpperCase(),
                value: (currentSlotTime.getHours() * 100) + (currentSlotTime.getMinutes() / 60 * 100)
            },
            endTime: {
                display: Intl.DateTimeFormat('en-IN', {
                    timeStyle: 'short'
                }).format(currentEndTime).toUpperCase(),
                value: (currentEndTime.getHours() * 100) + (currentEndTime.getMinutes() / 60 * 100)
            }
        });
        currentSlotTime = new Date(new Date().setHours(currentSlotTime.getHours(), currentSlotTime.getMinutes() +
            slotIntervalInMin, 0, 0));
    }
    return slots;
}

function generateShift2ForS2(shift2Hr, s1EndTime, endTime = new Date(new Date().setHours(20, 0, 0, 0)),
    slotIntervalInMin = 30) {

    let gapInMin = 120
    console.log(shift2Hr, s1EndTime)
    shiftGaps.every((gap) => {
        if (gap.serviceId == dataMain.serviceId) {
            gapInMin = gap.gapInMinutes
            return false
        }
        return true
    })
    let maxStartTime;
    //Risabh
    if (shift2Hr == 0.5) {
        maxStartTime = new Date(new Date().setHours(19, 0, 0, 0))
    } else {
        maxStartTime = new Date(endTime.setMinutes(endTime.getMinutes() - (shift2Hr * 60)));
    }

    let currentSlotTime = new Date(new Date().setHours(0, 0 + (s1EndTime / 100 * 60) + gapInMin, 0, 0));
    let slots = [];
    while (true) {
        if (currentSlotTime > maxStartTime)
            break;
        let currentEndTime = new Date(currentSlotTime);
        currentEndTime = new Date(currentEndTime.setMinutes(currentEndTime.getMinutes() + (shift2Hr * 60)));
        slots.push({
            startTime: {
                display: Intl.DateTimeFormat('en-IN', {
                    timeStyle: 'short'
                }).format(currentSlotTime).toUpperCase(),
                value: (currentSlotTime.getHours() * 100) + (currentSlotTime.getMinutes() / 60 * 100)
            },
            endTime: {
                display: Intl.DateTimeFormat('en-IN', {
                    timeStyle: 'short'
                }).format(currentEndTime).toUpperCase(),
                value: (currentEndTime.getHours() * 100) + (currentEndTime.getMinutes() / 60 * 100)
            }
        });
        currentSlotTime = new Date(new Date().setHours(currentSlotTime.getHours(), currentSlotTime.getMinutes() +
            slotIntervalInMin, 0, 0));
    }
    return slots;
}

