<div class='login-modal ' id='pricingModal'>
    <div class='container package-popup myOut'>
        <div class='row'>
            <div class='col btn-cross d-none d-sm-flex  justify-content-between'>
                <div class='row align-items-center mr-4'>
                    <p class='m-0'>Select a service below to continue</p>
                </div>
                <img src='/assets/Badges/cross.svg' class='cross-btn'></img>
            </div>
        </div>
        <div id='package-MVP' class='row justify-content-center '>
            <!-- <img id = 'cross-MVP' class = 'd-block d-sm-none cross-btn my-clg' src = '/assets/Badges/cross.svg'> -->
            <div id='package-2' class='col-12 col-sm-6  package-div order-2 order-sm-1'>
                <div class='row video-slider row-MFB '>
                    <div class='col-12 col-lg-4 col-md-4 p-2 mb-2 o-video'>
                        <div class='myOuterr p-2 p-md-1 ' style='background: #fff; border-radius: 15px;  '>
                            <div packageData='19' class='package-box-2' style='text-align: center;'>
                                <img src='attachments/services/Cook-2.png' class='MFB-img'>
                                <img src='/assets/Badges/CheckCircle.svg' class='img-hide-2 d-none'
                                    style='width: auto;'>
                            </div>
                            <p class='MFB-text text-center m-0 mt-2' style='font-size:12px;'>Cooks & Chefs</p>
                            <button onclick="getpackage(event,'viewPack','19')" class=' my-2 myy-btnn d-sm-block'
                                style='cursor: pointer;'>View Pricing</button>
                        </div>
                    </div>
                    <div class='col-12 col-lg-4 col-md-4 p-2 mb-2 o-video'>
                        <div class='myOuterr p-2 p-md-1' style='background: #fff; border-radius: 15px;'>
                            <div packageData='14' class='package-box-2' style='text-align: center;'>
                                <img src='attachments/services/House Help-2.png' class='MFB-img'>
                                <img src='/assets/Badges/CheckCircle.svg' class='img-hide-2 d-none'
                                    style='width: auto;'>
                            </div>
