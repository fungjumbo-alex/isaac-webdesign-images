function calculateTime(t) {
    time = t;
    timeEnd = 0;
    var timeFloor = Math.floor(time)
    var decimalTime = time - timeFloor;
    if (decimalTime != 0) {
        time = decimalTime > 0.5 ? Math.ceil(time) : timeFloor + 0.5;
        if (decimalTime < 0.5)
            timeEnd = time + 1;
        else
            timeEnd = time + 2;
    } else
        timeEnd = time + 2;
}

