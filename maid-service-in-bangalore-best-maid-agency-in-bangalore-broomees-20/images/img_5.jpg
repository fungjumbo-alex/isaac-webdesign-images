                    $(this).removeClass('active');
                    if ($(this).text() == lsPreference.gender) {
                        $(this).addClass('active');
                    }
                });

                // console.log("lsPreference : ", lsPreference);

                // set gender from local storage
                $('#sGender button').each(function() {
                    $(this).removeClass('active');
                    if ($(this).text() == lsPreference.gender) {
                        $(this).addClass('active');
                    }
                });



                // set services and options from local storage

                $('.parent-category .service .card-main-v3 .card-body-v3 h6').each(function() {
                    let index = (lsPreference.workType).indexOf($(this).text());
                    if (index != -1) {
                        // $(this).parent().parent().addClass('active');                    
                        // lspopup = $(this).parent().siblings('.popup').children('button').addClass('active');
                        // lspopup = $(this).parent().siblings('.popup').children('button').children('span').text('-');  
                        $(this).parent().siblings('.popup').children('button').click();
                        //$('.popup-page').addClass('d-none');

                        let lsMenuTypes = $('.size-main-body .size .size-option').length;

                        for (let i = 0; i < lsMenuTypes; i++) {
                            let lsMenuOptions = $('.size-main-body .size .size-option .seroption')
                                .eq(i);
                            //console.log("Length : ",$(lsMenuOptions).children('button').length);
                            $(lsMenuOptions).children('button').each(function() {
                                //console.log($(this).text());
                                //console.log(lsPreference.details[index][i]);
                                lsSelectedOption = (lsPreference.details[index][i]).split(
                                    '-').pop();
                                if ($(this).text() == lsSelectedOption) {
                                    //console.log($(this).text());
                                    $(this).click();
                                }

                            })
                        }
                        $('#done').click();

                    }

                })

                $('#next').click();
                setTimeout(function() {
                    $('#next').click();
                }, 2000);

                let notes = lsPreference.note != 'NA' ? lsPreference.note : '';

                $('#sNote').html(notes);
                $('#condCheck').prop('checked', true);


                if ((ls[0].workTime).includes(",") == true) {
                    sArr = (ls[0].workTime).split(",");
                    shiftTempArr = sArr[0].split(";");
                    shiftArr = [];
                    shiftArr.push(shiftTempArr[0]);
                    shiftArr.push(shiftTempArr[1]);
                    shiftTempArr = sArr[1].split(";");
                    shiftArr.push(shiftTempArr[0]);
                    shiftArr.push(shiftTempArr[1]);
                    // console.log("ShiftArr : ", shiftArr);
                } else {
                    shiftArr = (ls[0].workTime).split(";");
                    // console.log("ShiftArr : ", shiftArr);
                }


                let date = new Date(ls[0].startDate);
                let monthDay = date.getDate();
                let month = date.toLocaleString('default', {
                    month: 'short'
                });
                $('#datePicker').children('input').val(monthDay + "-" + month);
                //$('#datePicker').datepicker("setDate", new Date(2008,9,03) );    
                // console.log("Date : ", $('#datePicker').val());
                sStartDate = ls[0].startDate;

                setTimeout(function() {
                    $('#next').click();
                }, 3000);


                lsAddress = JSON.parse(ls[0].address);
                // console.log('lsAddress : ', lsAddress);
                let address = lsAddress.address + ' ' + lsAddress.city + ' ' + lsAddress.pincode;
                $('#uAddress').html(address);

                $('#tncCheck1').prop('checked', true);
            }
            localStorageAccess = "";
            // local storage Prefill code End ------       
        },
        error: function(jqXhr, textStatus, errorMessage) {
            console.log(jqXhr.responseJSON.message);
        }
    });

}

function showPack() {
    fetchPackages(dataMain.serviceId, 1);
    // showPricingModal();
}

let workTypeArr = [];
let activeWorkType = '';
// let lockRefresh = true;

function minusclick(curr) {

    console.log("btn minus click")
    if (dataMain.serviceId == '39' || dataMain.serviceId == '15' || dataMain.serviceId == '44' || dataMain.serviceId ==
        '45') {
        $('.card-main-v3').removeClass('d-card');
    }

    $(curr).parents('.card-main-v3').removeClass('active');
    $(curr).removeClass('active');
    $(curr).find('button').removeClass('active');
    $(curr).find('.sign').text('+');


    if ($(curr).parents('.card-main-v3').attr('data-cat-name') == undefined) {
        workTypeArr = workTypeArr.filter(val => val.catName != $(curr).attr('data-cat-name'))
    } else {
        workTypeArr = workTypeArr.filter(val => val.catName != $(curr).parents('.card-main-v3').attr('data-cat-name'))
    }

    console.log("work", workTypeArr)
    calcDynamicPrice();
}



function selectWorkType(curr) {

    // TOSHIT FIX - GENDER
    let isGenderSelected = !Array.from(document.getElementById('sGender').querySelectorAll('button')).every((
        btnEle) => {
        if (btnEle.classList.contains('active')) {
            return false
        }
        return true
    })


    if (isGenderSelected) {
        console.log("card click")
        $('.errorDisplay').hide();
        if (false) {
            // console.log("minus button click")
            // if (dataMain.serviceId == '39' || dataMain.serviceId == '15' || dataMain.serviceId == '44' || dataMain.serviceId == '45') {
            //     $('.card-main-v3').removeClass('d-card');
            // }
            // $(curr).removeClass('active');
            // $(curr).find('button').removeClass('active');
            // $(curr).find('.sign').text('+');
            // workTypeArr = workTypeArr.filter(val => val.catName != $(curr).attr('data-cat-name'))

        } else {
            console.log("plus button click")

            if (dataMain.serviceId == '39' || dataMain.serviceId == '15' || dataMain.serviceId == '44' || dataMain
                .serviceId == '45') {
                if (!$(curr).hasClass('active')) {
                    minusclick($(activeWorkType))
                }
                $('.card-main-v3').addClass('d-card');
                $('.card-main-v3').find('button').removeClass('active');
                $('.card-main-v3').find('.sign').text('+');
                $('.card-main-v3').removeClass('active');
                $(curr).removeClass('d-card');
            }

            $(curr).addClass('active');
            $(curr).find('button').addClass('active');
            $(curr).find('.sign').text('-');




            console.log("category", $(curr).attr('data-cat-name'), workTypeArr)
            let foundObject = workTypeArr.find(element => element.catName == $(curr).attr('data-cat-name'));

            if (foundObject !== undefined) {
                console.log("Value is present in the array.");
                activeWorkType = curr;
                popup($(curr).attr('data-parent-index'), $(curr).attr('data-self-index'));
                prefillWorkType($(curr).attr('data-cat-name'), workTypeArr);
            } else {
                console.log("Value is not present in the array.");
                workTypeArr.push({
                    catName: $(curr).attr('data-cat-name'),
                    price: $(curr).attr('data-work-price'),
                    minutes: $(curr).attr('data-work-minutes'),
                    catData: []
                });
                activeWorkType = curr;
                popup($(curr).attr('data-parent-index'), $(curr).attr('data-self-index'));
            }

            $(`#serviceCategories`).animate({
                scrollTop: 0
            }, 0);

        }
        calcDynamicPrice();
    } else {
        console.log("*Please select worker's gender first")
        $('.errorDisplay').html("*Please select worker's gender first");
        $('.errorDisplay').fadeIn();
    }

}

function prefillWorkType(catname, data) {
    console.log("prefilled ----------", catname, data)
    data.forEach((ele) => {
        // console.log(ele,ele.catName)
        if (ele.catName == catname) {
            // console.log("matched",ele.catData)
            let data = ele.catData
            data.forEach((ele1) => {
                // console.log(ele1)   
                let question = ele1.name
                let ans = ele1.opt[0].name
                //console.log("selected options",question,ans)
                $(`.dropdownSelect[value="${ans}"][data-parent-name="${question}"]`).trigger('click');

            })
        }
    })
}

let selectedOptionData = [];
let videotag = '';

function popup(ci, i) {
    console.log("popupstart")
    if (localStorageAccess == '') {
        toggleBottomSheet(1);
    }

    let catDD = (categories[ci].service[i].dropdown);
    let menu = ('menu' in categories[ci].service[i]) == true ? categories[ci].service[i].menu : [];
    let content = ``;
    fullJapaLink = '';
    if (categories[ci].service[i].val == '0-2 months (Japa maid is required)') {
        fullJapaLink =
            `<p style="display:none; position: absolute;right: 25px;top: 15px;">If you are looking for 24 hrs japa <a style="font-weight:600; color:#ffa726;" href='/24-hrs-live-in'>Click Here</a></p>`;
    } else {
        fullJapaLink = '';
    }

    content += `
        <div class="main-text-head">
            <h6>${categories[ci].service[i].val}
            ${fullJapaLink}</h6>
        </div>
        <div class="size-main-body ${categories[ci].service[i].val.replace(/[^a-zA-Z]/g, "")}Group" id="${categories[ci].service[i].val.replace(/[^a-zA-Z]/g, "")}Group">
            <div class="size">`
    categories[ci].service[i].dropdown.forEach((cat) => {

        let isHide = '';
        // if(cityIdData=='3' && cat.data[0].value=='How many people are there at home?' && categories[ci].service[i].val=='Dish-washing'){
        if (dataMain.serviceId == '19' && cat.data[0].value == 'How many people are there at home?' &&
            categories[ci].service[i].val == 'Dish-washing') {
            console.log("Hide service option")
            isHide = 'd-none';
        }

        content +=
            `<h6 class="${isHide}" >${cat.data[0].value} ${cat.data[0].value == 'Select house size' ? '<span style="font-size:11px; font-weight:400px;" > (Please describe the area of ONLY 1 floor)</span>' : ''} ${cat.data[0].value == 'For how many bathrooms?' ? '<span style="font-size:11px; font-weight:400px;" > (Pots will NOT be cleaned by Broomees)</span>' : ''}  ${cat.data[0].value == 'Bathroom cleaning' ? '<span style="font-size:11px; font-weight:400px;" > (Pots will NOT be cleaned by Broomees)</span>' : ''}</h6>`
        let len = (cat.data).length;

        let extraLabel = ``;
        if (cat.data[0].value == 'Do you have pets at home ?' || cat.data[0].value == 'Do you have pets at home ?') {
            extraLabel =
                '<small style="margin-top:-3px;margin-bottom:3px;color:#bdbdbd;">This would help us search for a pet friendly worker (if needed)</small>';
        }else if(cat.data[0].value == 'Veg/Non Veg?' || cat.data[0].value == 'Food type' || cat.data[0].value == 'Food type (if cooking selected)'){
            extraLabel =
                '<small style="margin-top:-3px;margin-bottom:3px;color:#bdbdbd;">For eggs, please select ‘Veg + Non Veg’</small>';
        }else{

        }




        content +=
            `<p class="${isHide}" >Select 1 out of ${len - 1} options</p>
                                    ${extraLabel}
                                    <div class="size-option ${isHide} ">
                                <div class="option seroption ${(cat.data[0].value == 'Cooking work' || cat.data[0].value == 'Food type (if cooking selected)') ? 'cookWork' : `${categories[ci].service[i].val.replace(/[^a-zA-Z]/g, "")}option`}">`
        for (let r = 1; r < len; r++) {
            let d = cat.data[r];
            if ((cat.data[0].value == 'Do you have pets at home ?' || cat.data[0].value == 'Do you have pets at home ?') &&
                cat.data[r].value == 'No') {
                isActive = 1;
            } else if (cat.data[0].value == "Child's Age" && cat.data[r].value == 'Not Applicable') {
                isActive = 1;
            } else if (cat.data[0].value == "Watching over a child" && cat.data[r].value == 'Not required') {
                isActive = 1;
            } else {
                isActive = 0;
            }
            // if(dataMain.serviceId == 45){
            //     if(cat.data[0].value == "Please select your baby's age" && cat.data[r].value == '0-2 months'){
            //         isActive = 1;
            //     }   
            // }
            content +=
                `<button class="dropdownSelect checked ${isActive == 1 ? 'active' : ''}" id="opt_${ci}_${i}" data-grand-parent-name="${categories[ci].service[i].val}" data-parent-name="${cat.data[0].value}" data-opt-price="${d.price}" data-opt-multiplier="${d.multiplier || 1}" data-opt-minutes="${d.minutes || 0}" value="${d.value}">${d.value}<span class="option-p"></span><span class="checked-selected"><img src="./assets/images/AA02.svg"></span></button>`
        }

        content += `</div></div>`
    });
    // MENU
    // console.log(menu);
    if (menu.length) {

        content += `<div class="inclusion-tab">
                        <h6>Inclusions</h6>
                        <div id="extraNote" style='font-size:12px; color:grey; margin-top:1px;'>${dataMain.serviceId == 19 && workTypeArr[0].catName ? '<b>Note</b> : Cook will cook 1-2 dish per meal' : ''}</div>
                        `
        if (dataMain.serviceId == 19) {
            if (cityIdData == '4') {
                menuVideoName = 'Punemenu.mp4';
            } else if (cityIdData == '6') {
                menuVideoName = 'Bangaloremenu.mp4';
            } else {
                menuVideoName = 'DelhiMenu2.mp4';
            }

            content += `<video id="menuVideo"  class="m-0 my-2 my-sm-4" width="375" height="211" preload="metadata" autoplay="" loop="" muted="" playsinline="" src="/attachments/menu_video/${menuVideoName}">
                            <source src="#" type="video/mp4">
                        </video>`
        }


        workTypeArr
        if (dataMain.serviceId == 44) {
            if (workTypeArr.length == 1) {
                if (workTypeArr[0].catName == 'Cook') {
                    menuVideoName = 'delhimenu.mp4';
                    content += `<video id="menuVideo"  class="m-0 my-2 my-sm-4" width="375" height="211" preload="metadata" autoplay="" loop="" muted="" playsinline="" src="/attachments/services/${menuVideoName}">
                            <source src="#" type="video/mp4">
                        </video>`
                }
            }
        }




        menu.forEach((m) => {
            content += `
                    <div class="subcat-tab">
                        <p style="font-weight:500">${m.subcat[0].value}</p>
                        <div class="subcat-btn"><p>`
            m.subcat[0].data.forEach((itm, i) => {
                // content += `<button type="button">${itm}</button>`
                content += `${itm} ${i < m.subcat[0].data.length - 1 ? ', ' : ''}`
            });
            content += `</p></div></div>`
        });




        content += `</div >`

        if (dataMain.serviceId == 39) {

        content += `<div class="inclusion-tab">
                        <div class="subcat-tab">
                            <p style="font-weight:500"><b>Please note:</b> You are booking for specific hours/slots and we do not guarantee all selected tasks to be completed in that time-frame. It is only an estimate of the tasks for us to ensure service quality. The worker will only complete tasks possible in the booked time slot</p>
                        </div>
                    </div>`
        }



        //party service
        if (dataMain.serviceId == 40) {
            switch (workTypeArr[0].catName) {
                case 'Morning':
                    content += `<div class="party-dec" >
                                                <h6>For Breakfast</h6>
                                                <ul>
                                                    <li>Pick any one from north indian</li>
                                                    <li>Pick any one from south indian</li>
                                                    <li>Any one from continental</li>
                                                </ul>
                                                </div>`;
                    break;
                case 'Afternoon':
                    content += `<div class="party-dec">
                                                <h6>For Afternoon</h6>
                                                <ul>
                                                    <li>Pick any 2 starters from the starter section</li>
                                                    <li>Pick any 2 from main course from main course section</li>
                                                    <li>Pick any 1 bread,  1 rice variation and 1 dessert</li>
                                                    </ul>
                                                </div>`;
                    break;

                case 'Evening + Night':
                    content += `<div class="party-dec">
                                                <h6>For Evening & Night</h6>                             
                                                <ul>
                                                    <li>For high tea
                                                        <ul>
                                                            <li>Any 2 snacks from high tea snacks section</li>
                                                            <li>Any 2 beverages</li>
                                                        </ul>
                                                    </li>
                                                    <li>For night
                                                        <ul>
                                                            <li>Pick any 2 starters from the starter section</li>
                                                            <li>Pick any 2 from main course from main course section</li>
                                                            <li>Pick any 1 bread,  1 rice variation and 1 dessert</li>
                                                        </ul>
                                                    </li>                                                    
                                                    </ul>
                                                </div>`;
                    break;

                case 'Night':
                    content += `<div class="party-dec">
                                                <h6>For Night</h6>
                                                    <ul>
                                                        <li>Pick any 2 starters from the starter section</li>
                                                        <li>Pick any 2 from main course from main course section</li>
                                                        <li>Pick any 1 bread,  1 rice variation and 1 dessert</li>
                                                    </ul>
                                                </div>`;
                    break;
            }
        }
    }
    content += `</div>`

    $("#serviceCategories").html(content).promise().done(function() {

        if (dataMain.serviceId == 39) {
            $('.cookWork:eq(0) button').click(function() {
                if ($(this).text() == 'Not required') {
                    $('.cookWork:eq(1) button:eq(3)').click();
                    $('.cookWork:eq(1) button:eq(3)').removeClass('d-none');
                    $('.cookWork:eq(1) button:eq(0),.cookWork:eq(1) button:eq(1),.cookWork:eq(1) button:eq(2)')
                        .addClass('d-none');
                } else {
                    $('.cookWork:eq(1) button:eq(3)').removeClass('active');
                    $('.cookWork:eq(1) button:eq(3)').addClass('d-none');
                    $('.cookWork:eq(1) button:eq(0),.cookWork:eq(1) button:eq(1),.cookWork:eq(1) button:eq(2)')
                        .removeClass('d-none');
                }
            })
        }


        // if (dataMain.serviceId == 19 && cityIdData=='3') {
        if (dataMain.serviceId == 19) {
            $('.Dishwashingoption:eq(1) button').click(function() {
                if ($(this).text() == 'Required') {

                    try {
                        findElement = workTypeArr.find(element => (element.catName ==
                            'Home-style food'));
                        serviceQuarterArr = (findElement.catData).find(element => element.name ==
                            'How many people are there at home?');
                        serviceQuarterName = serviceQuarterArr.opt[0].name

                        $('.Dishwashingoption:eq(0) button').filter(function() {
                            return $(this).text() === serviceQuarterName;
                        }).click();
                    } catch (e) {

                        $('.Dishwashingoption:eq(0) button:eq(0)').click();
                    }

                } else {
                    console.log("remove service")
                    $(".close-x").click();
                }
            })


            $('.Homestylefoodoption:eq(0) button').click(function() {
                try {
                    findElement = workTypeArr.find(element => (element.catName == 'Dish-washing'));
                    serviceQuarterArr = (findElement.catData).find(element => element.name ==
                        'Dish-washing?');
                    serviceQuarterName = serviceQuarterArr.opt[0].name

                    if (serviceQuarterName == 'Required') {

                        person = $(this).text();
                        let dishWashCategory = categories.find(item => item.category ===
                            "Dish-washing");
                        if (dishWashCategory) {
                            let cookSelectedPerson = dishWashCategory.service[0].dropdown[0].data.find(
                                item => item.value == person)
                            if (cookSelectedPerson) {

                                let filterData = workTypeArr.filter(val => val.catName !=
                                    'Dish-washing');
                                workTypeArr = filterData;
                                workTypeArr.push({
                                    catData: [{
                                            name: dishWashCategory.service[0].dropdown[0]
                                                .data[0].value,
                                            opt: [{
                                                name: cookSelectedPerson.value,
                                                price: cookSelectedPerson.price,
                                                minutes: cookSelectedPerson.minutes,
                                                multiplier: cookSelectedPerson
                                                    .multiplier
                                            }]
                                        },
                                        {
                                            name: "Dish-washing?",
                                            opt: [{
                                                name: "Required",
                                                price: "0",
                                                minutes: "0",
                                                multiplier: "1"
                                            }]
                                        }
                                    ],
                                    catName: dishWashCategory.category,
                                    minutes: dishWashCategory.service[0].minutes,
                                    price: dishWashCategory.service[0].price
                                });
                            }
                        }
                    }

                } catch (e) {
                    console.log("err", e)
                }
            })
        }


        $('.dropdownSelect').on('click', function() {
            $(this).siblings().removeClass('active');
            $(this).addClass('active');
            workTypeArr.forEach((cat) => {
                let set = false;
                if (cat.catName == $(this).attr('data-grand-parent-name')) {
                    cat.catData.forEach((ch) => {
                        // console.log(ch.name, $(this).attr('data-parent-name'))
                        if (ch.name == $(this).attr('data-parent-name')) {
                            ch.opt[0] = {
                                name: $(this).val(),
                                price: $(this).attr('data-opt-price'),
                                minutes: $(this).attr('data-opt-minutes'),
                                multiplier: $(this).attr('data-opt-multiplier')
                            };
                            set = true;
                            return;
                        }
                    });
                    if (!set) {
                        cat.catData.push({
                            name: $(this).attr('data-parent-name'),
                            opt: [{
                                name: $(this).val(),
                                price: $(this).attr('data-opt-price'),
                                minutes: $(this).attr('data-opt-minutes'),
                                multiplier: $(this).attr('data-opt-multiplier')
                            }]
                        });
                    }
                }
                return;
            });
            // console.log(workTypeArr);

            $('.errorDisplay').hide();
            calcDynamicPrice();

            // purple zone new code - 08-07-2025
            purpleZoneMultiplier = 1;
            console.log('purpleZoneMultiplier ::: ', purpleZoneMultiplier);

        });

        //Prefill changes 03/06/2025
        if (decodedPreference?.details && prefillDone == false) {
            console.log('decodedPreferencedecodedPreference', decodedPreference)
            decodedPreference.details.forEach(detailss => {
                setTimeout(() => {

                    detailss.forEach(detail => {
                        let splitIndex;

                        // Prefer splitting after the question mark if it exists
                        const questionMarkIndex = detail.indexOf('?');
                        if (questionMarkIndex !== -1) {
                            // Find the first hyphen after the `?`
                            splitIndex = detail.indexOf('-', questionMarkIndex + 1);
                        } else {
                            // Fall back to the first hyphen in the string
                            splitIndex = detail.indexOf('-');
                        }

                        if (splitIndex !== -1) {
                            const question = detail.slice(0, splitIndex).trim();
                            const answer = detail.slice(splitIndex + 1).trim();

                            // console.log("Question:", question);
                            // console.log("Answer:", answer);

                            $(`.dropdownSelect[value="${answer}"][data-parent-name="${question}"]`)
                                .trigger('click');
                        } else {
                            console.warn('No valid separator found in:', detail);
                        }
                    });

                    serviceDone()
                }, 100);


            });


        }

    });

    try {
        videotag = document.getElementById('menuVideo');
        // containerscroll = document.getElementById('selection_container')
        videotag.muted = false;
        // containerscroll.addEventListener('scroll',muteunmute);
    } catch (err) {
        console.log("err", err)
    }
    // service selection
    // $(".option .checked").on('click', function() {});
    // if ((servicesData["services"][ci]) != undefined) {
    //     $(".seroption .opt_" + ci + "_" + i).each(function() {
    //         for (v of servicesData["services"][ci][i]['details']) {
    //             if ($.trim($(this).text()) == v) {
    //                 $(this).addClass("active")
    //             }
    //         }
    //     });
    // }

}

function serviceDone() {
    let dropdownFlag = true;
    let x = $(activeWorkType).attr('data-cat-name').replace(/[^a-zA-Z]/g, "") + 'Group';
    console.log(x);
    $('#' + x).find('.seroption').each(function(i) {
        // console.log($(this).find(".dropdownSelect").hasClass('active'));
        if (!$(this).find(".dropdownSelect.active").hasClass('active')) {
            // $(this).addClass('form-error-input');
            $('.errorDisplay').html("Please select a value to proceed!!!");
            $('.errorDisplay').fadeIn();
            // $(".form-error-message").show();
            dropdownFlag = false;
            return false;
        }
    });
    if (dropdownFlag) {
        toggleBottomSheet(0);

        try {
            videotag.muted = true;
        } catch (err) {
            console.log("err", err)
        }
    }
}

