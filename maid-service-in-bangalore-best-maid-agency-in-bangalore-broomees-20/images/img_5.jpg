// PlusMinus
function workShift(type) {
    v = parseInt($('#dropdownShifts').val());

    if (type == "inc") {
        if (v < 2) {
            document.getElementById('dropdownShifts').value = v + 1;

            renderShifts()

            // Interval Change 2
            interval = interval / 2;
            $("#slider2").parent().show();
            calcDynamicPrice()
            updateMySlider(hr);
            $('.time_container').css('padding-top', '15px')
        }
    } else {
        if (v > 1) {
            document.getElementById('dropdownShifts').value = v - 1;
            // Interval Change 3
            interval = interval * 2;
            $("#slider2").parent().hide();
            calcDynamicPrice()
            updateMySlider();

            $('.time_container').css('padding-top', '0px')


        }
    }

    // purple zone new code - 08-07-2025
    purpleZoneMultiplier = 1;
    console.log('purpleZoneMultiplier : ', purpleZoneMultiplier);

}

