                    return false;
                }
            } else {
                hrc = (s1to - s1from);
                // console.log("HRC", hrc);
                if (hrc < parseInt(hr * 100)) {
                    // $("#sTiming").addClass('form-error-input');
                    $("#wizardErr").html(hrc > 1200 ? `Total work time should not exceed 12 hrs!!!` :
                        `Total work time should be at least ${hr.toFixed(2)} hrs!!!`);
                    return false;
                }
            }
            if (sStartDate == "") {
                $("#datePicker").children('input').addClass('form-error-input');
                $("#wizardErr").html("Select service starting date!!!");
                return false;
            }

            let dropdownFlag = true;
            $('select:visible').each(function(i) {
                // console.log($(this).find("option:selected").val() == 0);
                if (($(this).find("option:selected").val()) == 0) {
                    $(this).addClass('form-error-input');
                    $("#wizardErr").html("Please select a value to proceed!!!");
                    dropdownFlag = false;
                    return false;
                }
            });

            if (dropdownFlag) {
                if ($('#condCheckLabel').html().trim() != "" && !($("#condCheck").is(':checked'))) {
                    $("#wizardErr").html("Please check the checkbox to proceed!!!");
                    return false;
                }
            } else {
                return dropdownFlag;
            }
            callGTagF2();
        } else if (index == 3) {
            //return validateThirdStep();
        } //etc.
    },
    onTabClick: function(tab, navigation, index) {
        // Disable the posibility to click on tabs
        return false;
    },
    onTabShow: function(tab, navigation, index) {
        var total1 = navigation.find('li').length;
        var current = index + 0;

        var percent = (current / (total1 - 1)) * 100;
        var percentWidth = 100 - (100 / total1) + '%';

        navigation.find('li').removeClass('active');
        navigation.find('li').eq(current).addClass('active');
        navigation.find('li').removeClass('done');
        navigation.find('li.active').prevAll().addClass('done');

        $('#rootwizard1').find('.progress-bar').css({
            width: percent + '%'
        });
        $('.form-wizard-horizontal').find('.progress').css({
            'width': percentWidth
        });

        // CHECK LOGIC
        if (index == 2) {
            //asign slots
            let s1from = s1.result.from;
            let s1to = s1.result.to;
            // console.log(s1from, s1to);
            // console.log(toVal2,fromVal2);
            if ($('#dropdownShifts').val() != 2) {
                if (s1to - s1from < 800) {
                    if (s1from >= 700 && s1from <= 1150) {
                        $('#sTiming option[value="mor"]').prop("selected", true).trigger("change");
                    } else if (s1from >= 1200 && s1from <= 1650) {
                        $('#sTiming option[value="aft"]').prop("selected", true).trigger("change");
                    } else if (s1from >= 1700 && s1from <= 2050) {
                        $('#sTiming option[value="eve"]').prop("selected", true).trigger("change");
                    }
                } else {
                    $('#sTiming option[value="8-12"]').prop("selected", true).trigger("change");
                }
            } else {
                $('#sTiming option[value="mor-eve"]').prop("selected", true).trigger("change");
            }
            //fetch address
            addressJsonData.forEach((item) => {
                if (item.id == $('#addressId').val().trim()) {
                    currentAddressData = item;
                    return;
                }
            });

            offersList(currentAddressData.pincode);


            //fetch details
            let ddDetails = "";
            $('.dropdownSelect:visible').each(function(i) {
                ddDetails += $(this).find("option[value='0']").html() + " : " + $(this).find(
                        "option:selected").val() + "(" + $(this).parent().parent().parent().prev()
                    .html() + "), ";
            });
            $('.dropdownSelect1:visible').each(function(i) {
                ddDetails += $(this).find("option[value='0']").html() + " : " + $(this).find(
                        "option:selected").val() + "(" + $(this).parent().parent().parent().prev()
                    .html() + "), ";
            });

            let shift;
            if ($('#dropdownShifts').val() == 2) {
                shift = convertNumToTime($('#slider1').val().split(";")[0] / 100) + "-" + convertNumToTime(
                    $('#slider1').val().split(";")[1] / 100) + ", " + convertNumToTime($('#slider2')
                    .val().split(";")[0] / 100) + "-" + convertNumToTime($('#slider2').val().split(";")[
                    1] / 100)
            } else {
                shift = convertNumToTime($('#slider1').val().split(";")[0] / 100) + "-" + convertNumToTime(
                    $('#slider1').val().split(";")[1] / 100)
            }

            $("#addressConfirmation").html(
                `${currentAddressData.address}, ${currentAddressData.city} - ${currentAddressData.pincode}`
            );
            currentPreferenceData = {
                'serviceId':dataMain.serviceId,
                'workType': allSelected.join(','),
                'gender': $('#sGender option:selected').val(),
                'age': $('#sAge option:selected').val(),
                'experience': $('#sWorkEx option:selected').val(),
                'serviceTime': $('#sTiming option:selected').val(),
                'serviceTimeName': $('#sTiming option:selected').text(),
                'note': $("#sNote").val().trim() == "" ? 'NA' : $("#sNote").val().trim().replace(/"/g,
                    "'"),
                'religiousPreference': $("#religiousPreference").is(':checked'),
                'languagePreference': $("#languagePreference").is(':checked'),
                'details': ddDetails
            };
            //replace with new code - LATER
            $("#jobConfirmation").html(`Includes : ${allSelected.join(', ')}</br>
                                        Worker : ${$('#sGender option:selected').html()}</br>
                                        Hours of service : ${$('#sTiming option:selected').html()}</br>
                                        Start date : ${$('#datePicker').children('input').val()}</br>
                                        Details : ${currentPreferenceData.details}</br>
                                        Misc. Remarks: ${currentPreferenceData.note}`);
            //Aged ${$('#sAge option:selected').html()},
            $("#package").html($('#sTiming option:selected').attr('data-description'));
            calcPrice();
        }
    }
});

