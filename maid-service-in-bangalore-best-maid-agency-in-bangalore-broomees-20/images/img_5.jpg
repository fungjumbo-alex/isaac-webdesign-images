function changeSingleShiftPosition(min, max) {
    var slider1 = $("#slider1").data("ionRangeSlider");
    if (sliderToNew != sliderToPrevious) {
        if (sliderToNew < sliderToPrevious) {
            console.log("Abhi");
            if (sliderfromNew === min || sliderfromNew - (sliderToPrevious - sliderToNew) < min) {
                slider1.update({
                    to: sliderToPrevious
                })
            } else {
                slider1.update({
                    to: sliderToNew,
                    from: sliderfromNew - (sliderToPrevious - sliderToNew)
                })
            }
            sliderToPrevious = sliderToNew

        } else {
            slider1.update({
                from: sliderfromNew + sliderToNew - sliderToPrevious
            })
        }
    } else if (sliderfromNew != sliderfromPrevious) {
        if (sliderfromNew > sliderfromPrevious) {
            if (sliderToNew === max || (sliderfromNew - sliderfromPrevious) + sliderToNew > max) {
                slider1.update({
                    from: sliderfromPrevious
                })
            } else {
                slider1.update({
                    to: sliderToNew + sliderfromNew - sliderfromPrevious,
                    from: sliderfromNew
                })
            }
        } else {
            slider1.update({
                to: sliderToNew - (sliderfromPrevious - sliderfromNew)
            })
        }
    }
}

function changePosition() {
    var slider1 = $("#slider1").data("ionRangeSlider");
    var slider2 = $("#slider2").data("ionRangeSlider");
    if (sliderToNew != sliderToPrevious) {
        if (sliderfromNew < sliderToNew) {
            if (sliderToNew < sliderToPrevious) {
                slider2.update({
                    from: slider1fromNew - (sliderToPrevious - sliderToNew),
                });
                slider1.update({
                    to: sliderToNew,
                });
            } else if (sliderToNew > sliderToPrevious) {
                if (sliderToNew < slider1ToNew - 2) {

                    if ((sliderToNew - sliderToPrevious) + slider1fromNew < slider1ToNew) {
                        // console.log("Lie");
                        slider2.update({
                            from: slider1fromNew + (sliderToNew - sliderToPrevious)
                        })
                        slider1.update({
                            from: sliderToNew - (2 * time - (slider1ToNew - slider1fromNew))
                        })
                    } else if ((sliderToNew - sliderToPrevious) + slider1fromNew > slider1ToNew || slider1fromPrevious +
                        1 == slider1ToNew) {
                        slider2.update({
                            from: slider1ToNew - 1
                        })
                        slider1.update({
                            from: sliderToNew - (2 * time - (slider1ToNew - slider1fromNew))
                        })
                    } else {
                        slider1.reset();
                    }

                } else slider1.reset();
            } else {
                slider1.reset();
            }
        } else {
            slider1.reset();

        }
    } else if (slider1fromNew != slider1fromPrevious) {
        if (slider1fromNew > slider1fromPrevious) {
            if (slider1fromNew < slider1ToNew) {
                slider1.update({
                    to: sliderToNew + slider1fromNew - slider1fromPrevious,
                });
                slider2.update({
                    from: slider1fromNew,
                });
            } else slider2.reset();
        } else {
            if (slider1fromNew - 2 > sliderfromNew) {
                if (sliderToNew - (slider1fromPrevious - slider1fromNew) > sliderfromNew) {
                    slider1.update({
                        to: sliderToNew - (slider1fromPrevious - slider1fromNew)
                    })
                    slider2.update({
                        to: slider1fromNew + (2 * time - (sliderToNew - sliderfromNew))
                    })
                } else if (sliderToNew - (slider1fromPrevious - slider1fromNew) < sliderfromNew) {
                    slider1.update({
                        to: sliderfromNew + 1
                    })
                    slider2.update({
                        to: slider1fromNew + (2 * time - (sliderToNew - sliderfromNew))
                    })

                } else slider2.reset();
            } else slider2.reset();
        }
    }
}

function changeExtreme() {
    var slider1 = $("#slider1").data("ionRangeSlider");
    var slider2 = $("#slider2").data("ionRangeSlider");
    // console.log(slider1);
    if (sliderfromNew != sliderfromPrevious) {
        if (sliderfromNew < sliderToNew) {
            if (sliderfromNew - sliderfromPrevious < 0) {
                if (
                    sliderfromPrevious - sliderfromNew <
                    slider1ToNew - slider1fromNew
                ) {
                    slider2.update({
                        to: slider1ToNew - (sliderfromPrevious - sliderfromNew),
                    });
                    slider1.update({
                        from: sliderfromNew,
                    });
                } else {
                    slider2.update({
                        to: slider1fromNew + 1,
                    });
                    slider1.update({
                        to: sliderfromNew + 2 * time - 1,
                        from: sliderfromNew,
                    });
                }
            } else if (sliderfromNew - sliderfromPrevious > 0) {
                if (sliderfromNew - sliderfromPrevious <= max - slider1ToNew) {
                    slider2.update({
                        to: slider1ToNew + sliderfromNew - sliderfromPrevious,
                    });
                    slider1.update({
                        from: sliderfromNew,
                    });
                } else {
                    slider1.reset();
                }
            }
        } else if (sliderfromNew >= sliderToNew) {
            // console.log("Mehdi");
            slider1.update({
                from: sliderfromPrevious,
            });
        }
    } else if (slider1ToNew != slider1ToPrevious) {
        if (slider1ToNew > slider1fromNew) {
            if (slider1ToNew - slider1ToPrevious > 0) {
                if (
                    slider1ToNew - slider1ToPrevious <
                    sliderToNew - sliderfromNew
                ) {
                    slider1.update({
                        from: sliderfromNew + slider1ToNew - slider1ToPrevious,
                    });
                    slider2.update({
                        to: slider1ToNew,
                    });
                } else {
                    slider1.update({
                        from: sliderToNew - 1,
                    });
                    slider2.update({
                        to: slider1ToNew,
                        from: slider1ToNew - 2 * time + 1,
                    });
                }
            } else if (slider1ToNew - slider1ToPrevious < 0) {
                if (slider1ToPrevious - slider1ToNew < sliderfromNew - min + 1) {
                    slider1.update({
                        from: sliderfromNew - (slider1ToPrevious - slider1ToNew),
                    });
                    slider2.update({
                        to: slider1ToNew,
                    });
                } else {
                    slider2.reset();
                }
            }
        } else {
            slider2.reset();
        }
    }
}

function changeDoublePosition() {
    var slider2 = $("#slider2").data("ionRangeSlider");
    var slider1 = $("#slider1").data("ionRangeSlider");
    if (sliderToNew >= slider1fromNew - 1) {
        slider1.update({
            to: sliderToPrevious,
            from: sliderfromPrevious
        });
        slider2.update({
            to: slider1ToPrevious,
            from: slider1fromPrevious
        })
    }
}


