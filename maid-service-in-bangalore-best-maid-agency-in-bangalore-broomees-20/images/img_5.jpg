async function otherServices(type = 0) {
    $.ajax({
        type: 'GET', // http method
        url: '/api/otherServices',
        data: {
            latlng: '12,45'
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            if (status == "success") {
                if (data.status) {
                    if (type == 0) {


                        let res = data.data;

                        if (currentAddressData.latlng && currentAddressData.latlng != null &&
                            currentAddressData
                            .latlng != '') {


                            foundOtherService = 0;
                            otherServicesHtml = '<div>';
                            res.forEach((obj, ind) => {


                                let inclZones = JSON.parse(obj.inclusions);
                                let exclZones = JSON.parse(obj.exclusions);

                                let isNotWithinPolygonArea = inclZones.every((incZone) => {
                                    if (pointInPolygon({
                                            lat: currentAddressData.latlng.split(
                                                ",")[
                                                0],
                                            lng: currentAddressData.latlng.split(
                                                ",")[1]
                                        }, incZone)) {
                                        // if lat lng exist in green zone
                                        return false
                                    }
                                    // if lat lng not exist in green zone
                                    return true

                                })

                                let isWithinPolygonArea = false

                                if (!isNotWithinPolygonArea) {
                                    isWithinPolygonArea = exclZones.every((excZone) => {
                                        if (pointInPolygon({
                                                lat: currentAddressData.latlng
                                                    .split(
                                                        ",")[
                                                        0],
                                                lng: currentAddressData.latlng
                                                    .split(
                                                        ",")[1]
                                            }, excZone)) {
                                            // if lat lng exist in red zone
                                            return false
                                        }
                                        // if lat lng not exist in red zone
                                        return true
                                    })
                                }



                                if (isWithinPolygonArea) {
                                    // if find other services                                
                                    foundOtherService++;
                                    otherServicesHtml +=
                                        `<div class="mb-2 text-center h5"><a href="${obj.serviceUrl}">${obj.serviceName}</a><div>`;
                                    console.log(obj);
                                }




                            })

                            otherServicesHtml += '<div>';

                            if (foundOtherService > 0) {
                                $('#otherServicesUrl').html(otherServicesHtml);
                                // $('#otherServiceModal').show();
                                $('#otherServiceModal').modal('show');
                                // $('body').css({"filter": "blur(5px)"})
                                // $('#otherServiceModal').css({"filter": "none"})
                            }
                        }
                    } else {
                        console.log(selectedCityId, data.data)
                        let serviceData = data.data
                        let targetService = serviceData.find((item) => (item.serviceId === "45" && item
                            .cityId == selectedCityId));
                        console.log(targetService)
                        if (targetService) {
                            $('#japaServiceModal').modal('show')
                        } else {
                            $("#japaModalHead").html(
                                "Part time Japa Service(0-2 Month) is not available at your location"
                            );
                            $("#japaModalSubtext").html("Live services in your location");
                            $("#japaModalBtn1").addClass("hidden");
                            $("#japaModalBtn2").removeClass("hidden");
                            $('#japaServiceModal').modal('show')
                        }

                    }

                } else {
                    console.log(data.log);
                }
            } else {
                alert("Upload Failed");
            }
        },
        error: function(jqXhr, textStatus, errorMessage) {
            console.log(jqXhr.responseJSON.message);
        }
    });
}


