h3.decoration:before {
    content: "";
    width: 80px;
    height: 2px;
    background: #000;
    position: absolute;
    top: 50%;
    transform: translate(-90px, 50%);
}

h3.decoration:after {
    content: "";
    width: 80px;
    height: 2px;
    background: #000;
    position: absolute;
    top: 50%;
    transform: translate(10px, 50%);
}


.side-decoration {
    position: relative;
}

.side-decoration:after {
    content: "";
    position: absolute;
    width: 100%;
    height: 150%;
    background: url(/assets/images/yellow-blob@1.5x.png) no-repeat center;
    right: -51%;
    top: -4%;
    background-size: contain;
    z-index: -1;
    opacity: 0.6;
}

.over-strip {
    display: none;
    position: absolute;
    padding: 5px 10px;
    background: #673ab7;
    z-index: 9;
    color: #fff;
    right: 0;
    bottom: 0;
    text-align: center;
}

