// ON HOLD
let allSelected = [];

function showDropdown() {
    // allSelected = [];
    // $(".card-main-v3 button.active").each(function() {
    //     allSelected.push($(this).attr('data-cat-name'));
    // });
    let con = ``;
    categories.forEach((category) => {
        category.service.forEach((s, i) => {
            con += `<h6>For ${s.val}</h6>
                  <ul class="row">`;
            s.dropdown.forEach((dd, ind) => {
                con += `
                <li class="col-sm-6">
                <span class="select">
                <select class="dropdownSelect" id="dropdownSelect${s.val.replace(/[^a-zA-Z]/g, "")}${ind}">`;
                dd.data.forEach((d, index) => {
                    con +=
                        `<option data-opt-price="${d.price}" data-opt-multiplier="${d.multiplier || 1}" data-opt-minutes="${d.minutes || 0}" value="${index == 0 ? '0' : d.value}" ${index == 0 ? 'disabled selected' : ''}>${d.value}</option>`;
                });
                con += `</select>
                    </span>
                </li>`;
            });
            con += `</ul>`;

        });
    });
    $("#dropdownContainer").html(con).promise().done(function() {
        $('.dropdownSelect').on('change', function() {
            $(this).removeClass('form-error-input');
            $("#wizardErr").html("");
            calcDynamicPrice();
        });
    });
    calcDynamicPrice();
}


function showtncError() {
    $("#wizardErr").html("Please accept the Terms to proceed!");
}

$("#tncCheck").change(function() {
    if (this.checked) {
        $(".errorDisplay").hide("");
    } else {
        showtncError();
    }
});

$("#condCheck").change(function() {
    if (this.checked) {
        $(".errorDisplay").hide("");
    }
});

function showtncModal() {
    $("#tncModal").css({
        'display': 'flex'
    });
}

$(".header").click(function() {
    $(this).next().slideToggle(500);
    $(this).toggleClass('active');
});


if (typeof currentAddressData == 'undefined') {
    // overwriting in case of already login and then we came on booking page (for pincode discount calculate)
    var currentAddressData = "";
}

