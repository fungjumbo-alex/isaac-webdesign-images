<style>

    :root {
        --primary-blue: #c1f63b;
        --primary-blue-dark: #ebe525ff;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --white: #ffffff;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1),
            0 4px 6px -4px rgb(0 0 0 / 0.1);
        --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1),
            0 8px 10px -6px rgb(0 0 0 / 0.1);
    }
    .demo-content {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--gray-50) 0%, var(--gray-100) 100%);
        padding: 2rem;
    }


    .demo-content h1 {
    color: var(--gray-900);
    margin-bottom: 1rem;
    font-size: 2.5rem;
    font-weight: 700;
    }

    .demo-content h2 {
    color: var(--gray-800);
    margin: 1.5rem 0 1rem 0;
    font-size: 1.5rem;
    }

    .demo-content p {
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: var(--gray-600);
    }

    .demo-content ul {
    list-style: none;
    padding-left: 0;
    }

    .demo-content li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--gray-600);
    }

    .demo-content li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--primary-blue);
    font-weight: bold;
    }

    /* Chatbot Widget Styles */
    .chatbot-widget {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
        "Helvetica Neue", Arial, sans-serif;
    }

    /* Floating Chat Icon */
    .chat-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #ffeb3bff 0%, #ff9900ff 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
    transition: all 0.3s ease;
    position: relative;
    color: #555555;
    }

    .chat-icon:hover {
    transform: scale(1.1);
    box-shadow: var(--shadow-xl);
    }

    .lodeButton:focus, .chat-icon:focus {
    outline: none;
    /* box-shadow: var(--shadow-xl), 0 0 0 3px rgba(59, 130, 246, 0.3); */
    }

    .icon-content {
    position: relative;
    z-index: 2;
    display: flex;
    }

    /* Pulse Animation */
    .pulse-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    border: 2px solid var(--primary-blue);
    border-radius: 50%;
    opacity: 0;
    animation: pulse 2s infinite;
    }

    @keyframes pulse {
    0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(1);
    }
    50% {
        opacity: 0.3;
    }
    100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(1.4);
    }
    }

    /* Chat Window */
    .chat-window {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 430px;
    height: 70vh;
    background: var(--white);
    border-radius: 12px;
    box-shadow: var(--shadow-xl);
    display: none;
    flex-direction: column;
    overflow: hidden;
    animation: slideUp 0.3s ease-out;
    }

    .chat-window.open {
    display: flex;
    }

    @keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
    }

    /* Chat Header */
    .chat-header {
    background: linear-gradient(135deg, #ffeb3b87 0%, #ff980057 100%);
    color: #363636;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* background: #FFC107; */
    }

    .header-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    }

    .bot-avatar {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    }

    .header-info h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    }

    .status {
    font-size: 0.75rem;
    opacity: 0.8;
    }

    .minimize-btn {
    background: none;
    border: none;
    color: #444444;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
    
    }

    .minimize-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    }
    .minimize-btn:focus {
        outline: none !important;
    }

    /* Messages Container */
    .messages-container {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    }

    .messages {
    flex: 1;
    }

    /* Message Styles */
    .message {
    margin-bottom: 1rem;
    display: flex;
    animation: fadeIn 0.3s ease-in;
    }

    @keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
    }

    .message.user {
    justify-content: flex-end;
    }

    .message.bot {
    justify-content: flex-start;
    }

    .message-content {
    max-width: 70%;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    position: relative;
    }

    .message.user .message-content {
    background: #ffc1076b;
    color: #4b4b4b;
    border-bottom-right-radius: 4px;
    font-size: 14px;
    font-weight: 400;
    }

    .message.bot .message-content {
    background: var(--gray-100);
    color: #3d4b5f;
    border-bottom-left-radius: 4px;
    font-size: 14px;
    font-weight: 400;
    word-break: auto-phrase;
    white-space: pre-line;
    }

    .message-time {
    font-size: 0.7rem;
    opacity: 0.6;
    margin-top: 0.25rem;
    }

    /* Quick Replies */
    .quick-replies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    /* margin-top: 1rem; */
    /* padding-top: 1rem; */
    /* border-top: 1px solid var(--gray-200); */
    }

    .quick-reply {
    background: var(--white);
    border: 1px solid #ffc10799;
    color: #415b68;
    padding: 0.5rem 0.75rem;
    border-radius: 16px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    }

    .quick-reply:hover {
    background: #ffc1074d;
    color: #3f4e56;
    }
    .quick-reply:focus {
        outline: none;
    }

    /* Typing Indicator */
    .typing-indicator {
    display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  color: var(--gray-500);
  font-size: 0.8rem;
  background: var(--gray-50);
  /* margin: 0 1rem; */
  border-radius: 8px;
  width: 145px;
    }

    .typing-dots {
    display: flex;
    gap: 2px;
    }

    .dot {
    width: 4px;
    height: 4px;
    background: var(--gray-400);
    border-radius: 50%;
    animation: typing 1.4s infinite ease-in-out;
    }

    .dot:nth-child(1) {
    animation-delay: -0.32s;
    }
    .dot:nth-child(2) {
    animation-delay: -0.16s;
    }

    @keyframes typing {
    0%,
    80%,
    100% {
        transform: scale(0);
        opacity: 0.5;
    }
    40% {
        transform: scale(1);
        opacity: 1;
    }
    }

    /* Input Area */
    .input-area {
    padding: 1rem;
    border-top: 1px solid var(--gray-200);
    background: var(--white);
    }

    .input-container {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    }

    #messageInput {
    flex: 1;
    padding: 0.75rem;
    border: 1px solid var(--gray-300);
    border-radius: 8px;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s ease;
    }

    .send-btn {
    background: #ffc107;
    border: none;
    color: var(--white);
    padding: 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
    }

    .send-btn:hover {
    background: #ffc107;
        outline: none;
    }

    .send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    outline: none;
    }
    .quick-reply, .send-btn:focus{
            outline: none;
    }

    /* Mobile Responsiveness */
    @media (max-width: 480px) {
    .chatbot-widget {
        bottom: 35px;
        right: 35px;
    }

    .chat-window {
        width: calc(100vw - 20px);
        height: 70vh;
        bottom: 80px;
        right: -20px;
    }

    .chat-icon {
        width: 50px;
        height: 50px;
    }

    .pulse-ring {
        width: 50px;
        height: 50px;
    }
    }

    /* Scrollbar Styling */
    .messages-container::-webkit-scrollbar {
    width: 4px;
    }

    .messages-container::-webkit-scrollbar-track {
    background: var(--gray-100);
    }

    .messages-container::-webkit-scrollbar-thumb {
    background: var(--gray-300);
    border-radius: 2px;
    }

    .messages-container::-webkit-scrollbar-thumb:hover {
    background: var(--gray-400);
    }
    /* ----------- */

    .white-space {
    white-space: pre-line;
    }

    .chat-container {
    width: 100%;
    /* max-width: 800px; */
    height: 100vh;
    background: white;
    /* border-radius: 16px; */
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    }

    .chat-messages {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    }


    @keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
    }

    .user-message {
    align-self: flex-end;
    background: #ffc10787;
    color: #515151;
    border-bottom-right-radius: 4px;
    }

    .bot-message {
    align-self: flex-start;
    background: var(--light);
    color: var(--dark);
    border-bottom-left-radius: 4px;
    }

    .chat-input-container {
    padding: 16px;
    border-top: 1px solid #eee;
    display: flex;
    gap: 8px;
    }

    #chat-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 24px;
    outline: none;
    font-size: 1rem;
    transition: border 0.3s;
    }

    #chat-input:focus {
    border-color: var(--primary);
    }

    #send-button,
    #recordBtn {
    background: var(--primary);
    color: white;
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: background 0.3s;
    }

    #send-button:hover {
    background: var(--secondary);
    }

    #send-button svg,
    #recordBtn svg {
    width: 20px;
    height: 20px;
    }

    .timestamp {
    font-size: 0.7rem;
    color: #6c6c6c;
    margin-top: 4px;
    text-align: right;
    }

    @media (max-width: 600px) {
    .chat-container {
        height: 100vh;
        border-radius: 0;
    }

   
    }

    .bubble-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    font-size: 16px;
    background: #4fc3f7;
    color: white;
    border: none;
    border-radius: 40px;
    cursor: pointer;
    animation: bubble 1.5s infinite ease-in-out;
    }

    .bubble-btn svg {
    position: absolute;
    }

    @keyframes bubble {
    0%,
    100% {
        transform: scale(1);
    }
    30% {
        transform: scale(1.1);
    }
    60% {
        transform: scale(0.95);
    }
    }

    .booking-button {
    background: #ffdc74;
    padding: 5px 8px;
    border: none;
    border-radius: 6px;
    color: #393939;
    margin: 5px 6px;
    }
    .booking-buttons {
    display: flex;
    padding: 10px 0px;
    flex-wrap: wrap;
    }

    .button-container {
    padding: 0px 30px;
    display: flex;
    flex-wrap: wrap;
    max-height: 130px;
    overflow: hidden;
    overflow-y: scroll;
    }
   .lodeButton {
  padding: 7px 10px;
  border: none;
  border-radius: 5px;
  text-transform: capitalize;
  font-size: 12px;
  margin: 0px auto;
  color: #6d6d6d;
  text-align: center;
}
    .timeStampParent {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    margin-top: 5px;
    }

    .loadbtn-center {
  display: flex;
  margin-bottom: 10px;
}

</style>


<div class="chatbot-widget">
        <!-- Floating Icon -->
        <div class="chat-icon" id="chatIcon" role="button" tabindex="0" aria-label="Open AI Assistant">
            <div class="icon-content">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

                
                
            </div>
            <div class="pulse-ring"></div>
        </div>

        <!-- Chat Window -->
        <div class="chat-window" id="chatWindow">
            <!-- Chat Header -->
            <div class="chat-header">
                <div class="header-content">
                    <div class="bot-avatar">
                         <img style="border-radius: 50%;"
                        src="data:image/jpeg;base64,"
                        alt>
                    </div>
                    <div class="header-info">
                        <h3>Broomees Support</h3>
                        <span class="status">Online</span>
                    </div>
                </div>
                <button class="minimize-btn" id="minimizeBtn" aria-label="Minimize chat">
                    
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M18 6L6 18M6 6L18 18" stroke-width="2" stroke-linecap="round"/>
                </svg>
                </button>
            </div>

