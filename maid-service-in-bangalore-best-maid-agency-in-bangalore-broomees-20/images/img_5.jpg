$.ajax({
    type: 'GET', // http method
    url: '/api/servicableCity',
    data: {
        slug: $("#slug").val(),
    },
    // data to submit
    dataType: 'json',
    success: function(data, status, xhr) {
        // console.log('status: ' + status + ', data: ' + ":" + data + ":");
        if (status == "success") {
            if (data.status) {
                res = data.data;
                let show = '';
                let i = 0;
                res.forEach(e => {
                    show += `<div class="box-img" id="c${e.id}" onclick="getServiceDetails(${e.id});">
                                        <figure class="box-img-child" data-city-id="${e.id}" data-city-name="${e.name}">
                                            <img class="box-img-top" src="/attachments/city/${e.image}" alt="city image">
                                        </figure>
                                        <button type="button" class="btn btn-light btn-xs text-black" id="c${e.id}Name">${e.name}</button>
                                    </div>`;
                });
                // console.log(show);
                $("#selectCity").html(show);
                cityHide();
                // bookingSlider();
                // $(".location-container-child").children().first().addClass("active");
                // $(".location-container-child").click(function() {
                //     $(".location-container-child").children().removeClass("active");
                //     $(this).children().addClass("active");
                // });
                $(".box-img").on('click', function() {
                    $(".box-img").removeClass('active');
                    $(this).addClass('active');
                    renderPage(1);
                });
            } else {
                alert("Error, Please Rerty!");
                // console.log(data.log);
            }
        } else {
            alert("Upload Failed");
        }
    },
    error: function(jqXhr, textStatus, errorMessage) {
        alert(jqXhr.responseJSON.message);
        console.log(jqXhr.responseJSON.message);
    }
});

let secondaryServiceId = 0;

function renderPage(via) {
    if (via == 1) {
        pNum++;
    } else {
        pNum--;
    }
    goToStepGA4(`${pNum-1}`);
    // console.log('pNum', pNum)
    $('.errorDisplay').hide();
    switch (pNum) {
        case 1:
            $('.progress-bar-1').css("width", "30%");
            $('.page-2').hide();
            $('.page-1').fadeIn();
            $('.page-3').hide();
            $('.header').html(`<span>Select your city</span>`);
            $(".card-footer-1").hide();

            if (currCityId != 'undefined') {
                $('.box-img').removeClass('active');
                $(`#c${currCityId}`).addClass('active');
            }

            break;
        case 2:
            // cityDiscount(0, 1);
            calcDynamicPrice();
            setTimeout(() => {
                $('.progress-bar-1').css("width", "60%");
                $('.page-1').hide();
                $('.page-2').fadeIn();
                $('.page-3').hide();
                $('.span-footer1').hide();
                // $('.span-footer').show();
                $('.span-footer').css({
                    'display': 'flex'
                });
                $('.header').html(
                    `<button class="btn-img" onclick="renderPage(0)"><img src="./assets/images/back-arrow-navigation-svgrepo-com.svg" alt="back"></button><span>Select a Service</span>`
                );
                $(".card-footer-main").show();
            }, 200);
            break;
        case 3:
            workShift('dec'); // if back then auto shift set on only 1 shift
            if ($('#sGender').find('button.active').length == 0) {
                $('.errorDisplay').html("*Select worker's gender");
                $('.errorDisplay').fadeIn();
                pNum--;
                return;
            }

            if (workTypeArr.length == 0) {
                $('.errorDisplay').html("*Select a service to proceed!");
                $('.errorDisplay').fadeIn();
                pNum--;
                return;
            }

            let flag = true;
            let ct = {};
            categories.forEach(function(cat) {
                let minCounter = 0;
                allSelected = workTypeArr.map((c) => {
                    return c.catName
                });
                cat.service.forEach((s) => {
                    if (allSelected.indexOf(s.val) != -1) {
                        minCounter++;
                    }
                });
                if (minCounter < parseInt(cat.minService || 0)) {
                    flag = false;
                    ct = cat;
                    return false;
                }
                return flag;
            });

            if (flag == false) {
                $("#sWorkType").addClass('form-error-input');

                if (ct.category == 'Cleaning') {
                    $('.errorDisplay').html(`It is mandatory to select (Brooming, Mopping) service`);
                } else {
                    $('.errorDisplay').html(`Please select ${ct.minService} ${ct.category} services!!!`);
                }


                $('.errorDisplay').fadeIn();
                pNum--;
                return;
            }

            if (localStorage.getItem('tbroomBookSer' + dataMain.serviceId) != null) {
                // code start hide and show time slider when select cooking service and breakfast or dinner
                if (dataMain.serviceId == 19) {
                    findElement = workTypeArr.find(element => (element.catName == 'Home-style food' || element
                        .catName == 'Home-style multi-cuisine'));

                    serviceQuarterArr = (findElement.catData).find(element => element.name ==
                        'How many meals per day?');

                    serviceQuarterName = serviceQuarterArr.opt[0].name

                    // console.log("findElement : ",findElement);
                    // console.log("serviceQuarter : ",serviceQuarterArr);
                    // console.log("serviceQuarterName : ",serviceQuarterName);

                    // if($.trim($('#loginName').text())=='Test Booking'){
                    if (serviceQuarterName == 'Breakfast & Lunch' || serviceQuarterName == 'Dinner') {
                        workShift('dec');
                        $('.plusminus').attr("disabled", true);
                        $('.add-button').addClass('d-none');
                        //$('#slider2').css({"display":"none !important"});     

                        // if(serviceQuarterName == 'Dinner'){
                        //     fromVal = 1700;
                        //     toVal = fromVal+interval;
                        //     s1.update({
                        //         from: fromVal,
                        //         to: toVal,
