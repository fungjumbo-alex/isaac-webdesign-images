function pricerefresh() {
    // console.log("start.,.,.,.,.,.,.,.,.,.")

    // data = $("#slider1").data("ionRangeSlider").result;
    // console.log('sltot data', data)

    console.log('PRICING REFRESH', +document.querySelector('#shift1Inp option:checked').getAttribute('value'))
    slider1From = +document.querySelector('#shift1Inp option:checked').getAttribute('value');
    slider1To = +document.querySelector('#shift1Inp option:checked').getAttribute('data-endtime-value');

    let slots = JSON.parse(dataMain.slot);
    slotdp = 0;
    slots.forEach(function(slot) {
        if (slot.index >= slider1From && slot.index <= slider1To) {
            slotdp += parseInt(slot.price);
        }
    });

    slots.forEach(function(slot) {
        if (slider1From >= slot.index && slider1To <= slot.index) {
            slotdp *= parseInt(slot.multiplier);
        }
    });

    if ($('#dropdownShifts').val() == 2) {

        // data2 = $("#slider2").data("ionRangeSlider").result;
        // console.log('sltot1 data', data2)

        slider2From = +document.querySelector('#shift2Inp option:checked').getAttribute('value');
        slider2To = +document.querySelector('#shift2Inp option:checked').getAttribute('data-endtime-value')

        let slots = JSON.parse(dataMain.slot);
        slotdp1 = 0;
        slots.forEach(function(slot) {
            if (slot.index >= slider2From && slot.index <= slider2To) {
                slotdp1 += parseInt(slot.price);
            }
        });
        slots.forEach(function(slot) {
            if (slider2From >= slot.index && slider2To <= slot.index) {
                slotdp1 *= parseInt(slot.multiplier);
            }
        });
    }

    showFinalPricing()
}


