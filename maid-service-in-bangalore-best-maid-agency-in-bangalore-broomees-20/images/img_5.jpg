                        //     dataMain.pro = '0';    
                        // }
                        

                                                cityHide();
                        getZones();
                        $("#sImage").attr('src', '/attachments/services/' + dataMain.image);
                        if (dataMain.videoV && dataMain.videoV != "") {
                            $("#sImage").parent().hide();
                            var video = $("#sVideo")[0];
                            video.src = '/attachments/services/' + dataMain.videoV;
                            $("#sVideo").parent().show();
                        } else {
