            //     $("#wizardErr").html("Select worker's age!!!");
            //     $("#sAge").addClass('form-error-input');
            //     return false;
            // }

            if (categories) {
                let flag = true;
                let ct = {};
                categories.forEach(function(cat) {
                    let minCounter = 0;
                    cat.service.forEach((s) => {
                        if (allSelected.indexOf(s.val) != -1) {
                            minCounter++;
                        }
                    });
                    if (minCounter < parseInt(cat.minService || 0)) {
                        flag = false;
                        ct = cat;
                        return false;
                    }
                    return flag;
                });
                if (flag == false) {
                    $("#sWorkType").addClass('form-error-input');
                    $("#wizardErr").html(
                        `Please select at least ${ct.minService} ${ct.category} services!!!`);
                    return false;
                }
            }

            if (dataMain.minService) {
                if (allSelected.length < parseInt(dataMain.minService)) {
                    $("#sWorkType").addClass('form-error-input');
                    $("#wizardErr").html(
                        `Please select at least ${dataMain.minService} services to proceed!!!`);
                    return false;
                }
            }

            let s1from = s1.result.from;
            let s1to = s1.result.to;

            if ($('#dropdownShifts').val() == 2) {
                let s2from = s2.result.from;
                let s2to = s2.result.to;
                hrc = (s1to - s1from) + (s2to - s2from);
                // console.log("HRC", hrc);
                if (hrc < parseInt(hr * 100)) {
                    // $("#sTiming").addClass('form-error-input');
                    $("#wizardErr").html(hrc > 1200 ? `Total work time should not exceed 12 hrs!!!` :
