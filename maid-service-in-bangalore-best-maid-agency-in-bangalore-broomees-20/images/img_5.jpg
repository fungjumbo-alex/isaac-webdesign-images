function continuePayment(type, id = 0) {
    $('#makePayFooter').show();
    $("#pay-1-footer").show();



    if (type == 1) {

        $('.pricing-card-item').removeClass('active');
        $(`#pay-${type}`).css('border', '3px solid #FFC91C');
          $('#pay-2').css('border', '1px solid #8080806e');
        paymentAmount = addZ(total);
        $('#discount-Amount').addClass('d-none');
        $('#package-Amount').html(`₹` + addZ(total));            
        $("#pay-1-footer").show();        
        subscriptionOrBooking = 0

        $('#payNowTxt').text('');            

        if(!$('#simplBookNow').hasClass('d-none')){
            $('#simplBtn').removeClass('d-none')
        }


    } else {

        




        $('#pay-1').css('border', '1px solid #8080806e');
        $(`#pay-${type}`).css('border', '3px solid #FFC91C');
        // ✅ Fix: use .html() instead of .innerHtml
        // let am = parseInt($(`#amount${id}`).html()) ;
        let am = parseInt($(`#amount${id}`).attr('data-amount')) ;
        am = Math.ceil((am * 1.18) * 100) / 100;

        if(Number(bookData.estimatedSalary) <= Number('4500')){            
            paymentAmount = Math.round((am * 0.90) * 100)/100;
            paymentAmount = Math.round((paymentAmount * 0.95)*100)/100;
            
        }else{
            if(dataMain.serviceId == '44' || dataMain.serviceId == '45' || dataMain.pro == '1'){
                paymentAmount = Math.round(am * 100)/100;            
            }else{
                paymentAmount = Math.round((am * 0.95) * 100)/100;            
            }
        }
        
        if(dataMain.serviceId == '44' || dataMain.serviceId == '45' || dataMain.pro == '1'){
            $('#payNowTxt').text('');            
            $('#discount-Amount').html(`₹` + am);    
            $('#discount-Amount').addClass('d-none');   
         }else{
            $('#payNowTxt').text('Pay now and avail 5% extra instant discount!');                
            $('#discount-Amount').html(`₹` + am);    
            $('#discount-Amount').removeClass('d-none');   
         }
        

        
        
        $('#package-Amount').html(`₹` + paymentAmount);       
        subscriptionOrBooking = id



        if(!$('#simplBookNow').hasClass('d-none')){
            $('#simplBtn').addClass('d-none')
        }


    }




}

