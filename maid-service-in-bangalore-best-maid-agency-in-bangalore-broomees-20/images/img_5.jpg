                .name == 'How many hours per day?') {
                // console.log("MINUTES", cat.opt[0].minutes);
                switch (cat.opt[0].minutes) {
                    case '300':
                        dp += 11200;
                        break;
                    case '420':
                        dp += 13600;
                        break;
                    case '540':
                        dp += 16500;
                        break;
                    case '660':
                        dp += 18200;
                        break;
                    default:
                        dp += parseFloat(cat.opt[0].price) + 2400;
                }
                // console.log(dp);
                dm += parseFloat(cat.opt[0].minutes);
                dx *= 1;
                dName = cat.opt[0].name;
            } else {
                cat.opt.forEach((opt) => {
                    dp += parseFloat(opt.price);
                    dm += parseFloat(opt.minutes);
                    dx *= parseFloat(opt.multiplier);
                    // console.log("DX", dx);
                    dName = opt.name;
                });
            }

        });
        // console.log("D", dp + "," + dm);

        dPrice = dp;
        dMinutes = dm;

        dp1 += dp;
        dp1 *= dx;
        dm1 += dm;


        console.log('dxx = ',dx);

        if (dataMain.serviceId == 39 || dataMain.serviceId == 15) {
            // as per vaibhav founder requirement0
            dm1 *= 1;
        } else {
            dm1 *= dx;
        }


        dynamicPrice += dp1;
        dynamicMinutes += dm1;

        if (c.catName == '10 hours per day') {
            $('.plusminus').attr("disabled", true);
            $('.add-button').addClass('d-none');
