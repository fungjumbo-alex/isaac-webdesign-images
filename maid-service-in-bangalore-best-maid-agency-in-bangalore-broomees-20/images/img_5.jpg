let performanceresponseID = 0;
let performance_campaign = () => {

    $.ajax({
        type: "POST",
        url: "/api/savePerformanceParameter",
        data: {
            edit: 0,
            utm_source: ``,
            utm_medium: ``,
            utm_campaign: ``,
            utm_content: ``,
            fullurl: `broomees.com/maid-service-bangalore`,
        },
        success: function(data) {
            if (data) {
                performanceresponseID = data.data;
                localStorage.setItem('performanceID', performanceresponseID)
            }
        },
        error: function(e) {
            console.log(e.message);
        }
    })
};

function updatePerformanceParameter(bId) {
    return $.ajax({
        type: "POST",
        url: "api/updatePerformanceParameter",
        data: {
            // edit: performanceresponseID,
            edit: localStorage.getItem('performanceID'),
            bookingId: bId
        },
        success: function() {
            if (status = "success") {
                console.log("booking update");
                localStorage.removeItem('performanceID')
            }
        },
        error: function(e) {
            console.log(e.message);
        }
    })
}

