let lastState = '';
let throttleTimer = null;

$(window).on('scroll', () => {
  if (throttleTimer) return; // prevent excessive firing

  throttleTimer = setTimeout(() => {
    throttleTimer = null;
    const scrollY = Math.floor($(window).scrollTop());
    const headerHeight = Math.floor($('#header').outerHeight());
    const bookingCont = $('#bookingCont');
    const bookingTop = Math.floor(bookingCont.offset().top);
    const bookingBottom = bookingTop + Math.floor(bookingCont.outerHeight());
    const isDesktop = $(window).width() > 525;

    let newState = '';
    const buffer = 10; // prevent jitter at boundaries

    if (isDesktop) {
      if (scrollY >= bookingTop - buffer && scrollY <= bookingBottom - headerHeight - buffer) {
        newState = 'inside';
      } else if (scrollY > bookingBottom - headerHeight - buffer) {
        newState = 'below';
      } else if (scrollY > scrollBtnWeb - headerHeight - buffer) {
        newState = 'middle';
      } else {
        newState = 'top';
      }

      if (newState !== lastState) {
        lastState = newState;
        const btn = $('#bookingbtn');

        switch (newState) {
          case 'inside':
            $('#header, #d-header').stop(true, true).fadeOut(100);
            btn.css({ 'position': 'unset' });
            break;
          case 'below':
          case 'middle':
            $('#header').stop(true, true).fadeOut(100);
            $('#d-header').stop(true, true).fadeIn(100);
            btn.css({
              'position': 'fixed',
              'top': '15px',
              'right': '35px',
              'z-index': '6',
              'padding': '8px 17px'
            });
            break;
          case 'top':
            $('#header').stop(true, true).fadeIn(100);
            $('#d-header').stop(true, true).fadeOut(100);
            btn.css({ 'position': 'unset' });
            break;
        }
      }
    } else {
      const btn = $('#btn-2');
      if (scrollY >= bookingTop + buffer && scrollY <= bookingBottom - headerHeight - buffer) {
        newState = 'inside';
      } else if (scrollY > bookingBottom - headerHeight - buffer) {
        newState = 'below';
      } else if (scrollY > scrollBtnMobile - headerHeight - buffer) {
        newState = 'middle';
      } else {
        newState = 'top';
      }

      if (newState !== lastState) {
        lastState = newState;
        switch (newState) {
          case 'inside':
            $('#header, #d-header').stop(true, true).fadeOut(100);
            btn.css({ 'position': 'unset', 'width': '100%', 'margin-top': '40px' });
            break;
          case 'below':
          case 'middle':
            $('#header').stop(true, true).fadeOut(100);
            $('#d-header').stop(true, true).fadeIn(100);
            btn.css({
              'position': 'fixed',
              'top': '12px',
              'z-index': '6',
              'width': '42%',
              'right': '10px',
              'margin': '0',
              'padding': '8px 15px',
              'outline': 'none'
            });
            break;
          case 'top':
            $('#header').stop(true, true).fadeIn(100);
            $('#d-header').stop(true, true).fadeOut(100);
            btn.css({ 'position': 'unset', 'width': '100%', 'margin-top': '40px' });
            break;
        }
      }
    }
  }, 500); // ← smooth throttle
});







