}

#ribbon-container:before {
    top: 3px;
    left: 0;
    border-top: 29px solid rgba(0, 0, 0, .3);
    border-bottom: 29px solid rgba(0, 0, 0, .3);
    border-right: 29px solid rgba(0, 0, 0, .3)
}

#ribbon-container:after {
    content: "";
    height: 3px;
    background: rgba(0, 0, 0, .3);
    display: block;
    position: absolute;
    bottom: -3px;
    left: 58px;
    right: 3px
}

#ribbon-container a {
    display: block;
    padding: 12px 20px;
    position: relative;
    background: #673ab7;
    overflow: visible;
    height: 58px;
    margin-left: 29px;
    color: #fff;
    text-decoration: none
}

#ribbon-container a:after {
    content: "";
    height: 0;
    width: 0;
    display: block;
    position: absolute;
    bottom: -15px;
    right: 0;
    border-top: 15px solid #4527a0;
    border-right: 15px solid transparent
}

#ribbon-container a:before {
    top: 0;
    left: -29px;
    border-top: 29px solid #673ab7;
    border-bottom: 29px solid #673ab7;
    border-right: 29px solid transparent
}

/*#ribbon-container a:hover{background:#009ff1}#ribbon-container a:hover:before{border-top:29px solid #009ff1;border-bottom:29px solid #009ff1}*/

