@keyframes rotate360 {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}

.rotate-animation {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    animation: rotate360 3s linear infinite;
}

.rotating-text {
    font-size: 20px !important;
    font-weight: 400 !important;
    ;
    margin-left: 6px;
}

.loading-text {
    font-weight: 300;
    padding-top: 5px;
    font-size: 15px !important;
}

