function proCommission(workerSalary) {
  const defaultPercent = 0.12;  // 12% default commission
  const commission = workerSalary * defaultPercent;

  if (commission >= 750) {
    // Return 1 + 12% → multiplier 1.12
    return 1 + parseFloat(defaultPercent.toFixed(3));
  } else {
    // Calculate minimum percentage needed to reach 500 commission
    const percent = 750 / workerSalary;
    return 1 + parseFloat(percent.toFixed(3));
  }
}

// new auto code
function roundToHundred(amount) {
    if (amount % 100 >= 50) {
        // Round up to the next hundred
        return Math.ceil(amount / 100) * 100;
    }
    return Math.round(amount); // Return the number as is if it's less than 50 to the next hundred
}







