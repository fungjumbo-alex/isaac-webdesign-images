.custom-radio {
    display: flex;
    align-items: center;
    margin-top: 5px;
}

.custom-radio input[type="radio"] {
    display: none;
}

.custom-radio label {
    cursor: pointer;
    display: flex;
    align-items: center;
    margin-left: 10px;
    color: #000000ba;
    border-radius: 10px;
    position: relative;
    display: flex !important;
    gap: 10px;
    transition: .3s all;
    background-color: #fff;
    justify-content: center;
    padding: 10px 20px 10px 11px;
    border: 2px solid lightgray;
}

.custom-radio .radio-icon {
    font-size: 12px;
}

.custom-radio .radio-text {
    margin-right: 5px;
}

.custom-radio input[type="radio"]:checked+label {
    background: #fff3e0;
    border: 2px var(--primary-color) solid;
}

.map-container .location-pin {
    position: absolute;
    width: 45px;
    top: calc(50% - 33px);
    left: 50%;
    padding: 5px;
    transform: translate(-50%, -50%);
}

.autocomplete-container {
    display: flex;
    font-size: 12px;
}

.autocomplete-container #pac-input {
    flex: 1 1 73%;
    width: 70%;
    border: 1px solid #BDBDBD;
    border-radius: 7px !important;
    padding: 10px 15px;
    margin-bottom: 5px;
}

.autocomplete-container .currentlocation {
    display: flex;
    gap: 8px;
    align-items: center;
    flex: 1 1 auto;
    margin-left: 15px;
    color: var(--primary-color);
    text-decoration: underline;
    cursor: pointer;
}

.address-inp-container{display: flex;flex-wrap: wrap;gap: 10px;}
.inp-container{flex: 1 1 auto; min-width: calc(50% - 20px);}


/* ---- MAP ADDRESS ---- */
</style>
