<!-- FORGOT PRE -->
<div class='login-modal' id='preForgotModal'>
    <div class='inner-box'>
        <h3 style='text-align:center'>Forgot Password</h3>
        <form method='post' class='form1' action='#'>
            <ul>
                <li class='otp'>
                    <input class='form-control' type='tel' placeholder='Mobile No.' id='mobileF' name='mobileF'
                        oninput='javascript: if (this.value.length > 10) this.value = this.value.slice(0, 10);' />
                    <span id='mobileFErr' class='form-error-msg'></span>
                    <span id='mobileFSucc' style='color:green'></span>
                    <a class='send-otp' href='javascript:void(0)' onclick='return sentOtpF(0)'>Send OTP</a>
                </li>
                <li>
                    <input class='form-control' type='number' placeholder='OTP' id='otpF' name='otpF'
                        oninput='javascript: if (this.value.length > 6) this.value = this.value.slice(0,6);'
                        autocomplete='off' maxlength='12' />
                    <span id='otpFErr' class='form-error-msg'></span>
                </li>
                <li class='text-center'>
                    <a href='javascript:void(0)' class='button2' onclick='return proceedForgot()'>Proceed</a>
                </li>
                <!-- <li class = 'text-center'>
<a href = 'javascript:void(0)' onclick = 'showLoginModal()' class = 'or-sign-up'><span>Or</span> login </a>
</li> -->
            </ul>
        </form>
    </div>
</div>

<!-- RESET PASSWORD MODAL -->
<div class='login-modal' id='resetPasswordModal'>
    <div class='inner-box'>
        <h3 style='text-align:center'>Change Password</h3>
        <form method='post' class='form1' action='#'>
            <ul>
                <li class='password'>
                    <input class='form-control' type='password' placeholder='New Password' id='passwordTempF'
                        maxlength='24' autocomplete='off' />
                    <a class='close-eye' href='javascript:void(0)' onclick='showPass(this)' data-toggle-status='0'></a>
                    <span id='passwordTempFErr' class='form-error-msg'></span>
                </li>
                <li class='password'>
                    <input class='form-control' type='password' placeholder='Confirm Password' id='passwordF'
                        maxlength='24' autocomplete='off' />
                    <span id='passwordFErr' class='form-error-msg'></span>
                </li>
                <li class='text-center'>
                    <a href='javascript:void(0)' class='button2' onclick='return validateReset()'>Change Password</a>
                </li>
                <!-- <li class = 'text-center'>
<a href = '#' class = 'or-sign-up'><span>Or</span> sign up </a>
</li> -->
            </ul>
        </form>
    </div>
</div>

