function getZones() {
    $.ajax({
        type: 'GET', // http method
        url: '/api/serviceZones',
        async: false,
        data: {
            id: dataMain.serviceZones
        },
        dataType: 'json',
        success: function(data, status, xhr) {
            if (status == "success") {
                if (data.status) {
                    dataMain.zonesData = data.data;

                    if (data.data[0].cityId == 6) {
                        $('#langPrefDiv').addClass('d-flex');        
                        $('#langPrefDiv').removeClass('d-none');                        
                    }else{

                        if($('#languagePreference').prop('checked')) {
                            $('#languagePreference').trigger('click');            
                        }

                        $('#langPrefDiv').removeClass('d-flex');        
                        $('#langPrefDiv').addClass('d-none');
                    }                    

                    console.log('zones => ', dataMain.zonesData);

                } else {
                    console.log("Error, Please Rerty!");
                }
            } else {
                alert("Upload Failed");
            }
        },
        error: function(jqXhr, textStatus, errorMessage) {
            console.log(jqXhr.responseJSON.message);
        }
    });
}





