function termsPopup() {
    $(".errorDisplay").hide();
    $('.popup-back').show();
    $('.popup-page-2').animate({
        top: '20%'
    });
    $("#package").prev().children('h6').text('Terms & Conditions');
    $('#package').hide();
    $('#tnc').show();
}
// List Address
$('#changeAddress').on('click', function() {
    $('.errorDisplay').css('display', 'none');
    if ($('#loginName').html() != '') {
        $('.popup-back').show();
        $('.popup-page-3').animate({
            top: '20%'
        });
    } else {
        showLoginModal();
    }
});

// Close bottom sheets
$('.close').on('click', function() {
    $('.popup-back').fadeOut();
    $('.popup-page-2').animate({
        top: '100%'
    });
    $('.popup-page-3').animate({
        top: '100%'
    });
})

