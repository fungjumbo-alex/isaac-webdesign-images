function pincodeDiscountSet() {
    // console.log('adddd1')
    // console.log(typeof currentAddressData);
    if (typeof currentAddressData != 'undefined') {

        //  hsr pincode temporary stop as per requirement founder saurav for pricing, now use only for not availaible 10 hr all rounder        
        // 560102
        if (currentAddressData.pincode == '560102') {
            hsrPincode = 1;
            // showFinalPricing();
        } else {
            hsrPincode = 0;
            // showFinalPricing();
        }

        // console.log('adddd2')
        pincodeDataArr = JSON.parse(dataMain.pincodeDiscount);
        pincodeDiscountArr = pincodeDataArr.filter(elem => elem.pincode == currentAddressData.pincode);

        if ((currentAddressData.city == 'Pune' || currentAddressData.city == 'Bengaluru') && $('#religiousPreference')
            .prop('checked')) {
            // $('#religiousPreference').trigger('click');
            // currentPreferenceData.religiousPreference = $("#religiousPreference").is(':checked');
        }

        if (pincodeDiscountArr.length != 0) {
            pincodeDiscountMultiplier = pincodeDiscountArr[0]['multiplier'];
            // calcDynamicPrice();
            showFinalPricing();
        } else {
            pincodeDiscountMultiplier = 0;
            showFinalPricing();
        }

        // Show location confirm popoup
        console.log('$(page-4)', $('.page-4').css('display'));
        if ($('.page-4').css('display') === 'block') {
            console.log('Element is visible');

            if (($(".box-img.active").children('.box-img-child').attr('data-city-name')).toLowerCase() == (
                    currentAddressData.city).toLowerCase()) {

                confirmLocationBasedCharges();
            }


        }

    }
}


