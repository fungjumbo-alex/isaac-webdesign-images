<style type="text/css">
	@font-face {
      font-family: 'Geometria';
      src: url('https://llp-assets.meetsoci.com/live/assets/daltile/local/fonts/Geometria.woff') format('woff'),url('https://llp-assets.meetsoci.com/live/assets/daltile/local/fonts/Geometria.woff2') format('woff2');
      font-weight: normal;
      font-style: normal;
      font-display: fallback
   }
	.itemlist {float: left; width: 20%; padding-bottom:10px; }
	#content{
		font-size: 20px;
		margin:auto;
		width: 1150px;
		padding-top:200px;
		padding-bottom: 50px;
		padding-left: 20px;
		padding-right: 20px;
	}
	@media screen and (max-width: 768px){ 
		#content {padding:5%;}
		.itemlist {width:100%;}
		#content {	
			margin-top: 140px; 
			width:100%;
		}
	}
	.social-area{float: left!important;}
	.nav-bar-styling.navigation-main .rel-level1.submenu > .navigation-title a {
		text-transform: uppercase;
	}
	@media(max-width:500px){
      #navbarSupportedContent{display: none !important;}
      .headnav>div.component-content>.column-splitter:nth-child(1){display: flex !important;}
   }

	@media (min-width: 769px) and (max-width: 841px) {
		.content-title {
			display: flex;
		}
		.itemlist {
			width: 50%;
		}
	}
	@media (min-width: 841px) and (max-width: 1020px) {
		.itemlist {
			width: 30%;
		}
	}
</style>

