<!-- GDPR Cookie Consent + Load GTM only after consent -->
<style>
  :root { --cb-overlay-z: 9998; --cb-modal-z: 10000; }

  .cb-overlay{
    position: fixed; inset: 0;
    background: rgba(0,0,0,.45);
    display: none;
    z-index: var(--cb-overlay-z);
  }

  .cb-modal{
    position: fixed; inset: 0;
    display: none;           /* shown by JS */
    z-index: var(--cb-modal-z);
    align-items: center;
    justify-content: center;
  }

  .cb-modal-inner{
    background:#fff;
    border-radius:14px;
    border:1px solid rgba(0,0,0,.12);
    box-shadow:0 14px 60px rgba(0,0,0,.25);
    padding:20px;
    max-width:720px;
    width:90%;
    position:relative;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
  }

  .cb-title{ font-weight:700; font-size:16px; margin:0 0 6px 0; }
  .cb-text{ margin:0; font-size:14px; line-height:1.45; color:rgba(0,0,0,.78); }

  .cb-row{
    display:flex; gap:12px; justify-content:space-between; align-items:flex-start;
    padding:12px 0; border-top:1px solid rgba(0,0,0,.08);
  }
  .cb-row:first-of-type{ border-top:none; padding-top:0; }

  .cb-row h4{ margin:0 0 4px 0; font-size:14px; }
  .cb-row p{ margin:0; font-size:13px; color:rgba(0,0,0,.72); line-height:1.4; max-width:520px; }

  .cb-switch{ display:flex; align-items:center; gap:8px; user-select:none; font-size:13px; font-weight:600; }
  .cb-switch input{ width:18px; height:18px; }

  .cb-actions{ margin-top:14px; display:flex; gap:10px; flex-wrap:wrap; }
  .cb-btn{
    appearance:none; border:1px solid rgba(0,0,0,.18);
    background:#fff; padding:10px 12px; border-radius:10px;
    cursor:pointer; font-size:14px; font-weight:600;
  }
  .cb-btn.primary{ background:#111; color:#fff; border-color:#111; }
  .cb-btn.secondary{ background:#fff; color:#111; }

  .cb-close{
    position:absolute; top:10px; right:12px;
    border:none; background:transparent; cursor:pointer;
    font-size:18px; line-height:1; padding:6px 8px; border-radius:8px;
  }
</style>

<div class="cb-overlay" id="cbOverlay" aria-hidden="true"></div>

<div class="cb-modal" id="cbModal" role="dialog" aria-modal="true" aria-label="Cookie settings">
  <div class="cb-modal-inner">
    <button class="cb-close" id="cbClose" type="button" aria-label="Close">✕</button>

    <p class="cb-title" style="margin-top:2px;">Cookie settings</p>
    <p class="cb-text">Choose which cookies you allow. Necessary cookies are always on.</p>

    <div class="cb-row">
      <div>
        <h4>Strictly necessary</h4>
        <p>Required for core site features (security, forms, and Webflow e-commerce checkout/cart).</p>
      </div>
      <div class="cb-switch" aria-label="Necessary cookies always enabled">
        <input type="checkbox" checked disabled />
        <span>Always on</span>
      </div>
    </div>

    <div class="cb-row">
      <div>
        <h4>Analytics (Google Analytics)</h4>
        <p>Helps us understand site traffic and improve the website. No advertising pixels are used.</p>
      </div>
      <label class="cb-switch">
        <input type="checkbox" id="cbAnalyticsToggle" />
        <span>Allow</span>
      </label>
    </div>

    <div class="cb-actions">
      <button class="cb-btn primary" id="cbSave" type="button">Save choices</button>
      <button class="cb-btn secondary" id="cbReject" type="button">Reject analytics</button>
    </div>
  </div>
</div>

<script>
(function(){
  // ===== CONFIG =====
  var GTM_ID = "GTM-TWQCWKLZ";
  var CONSENT_KEY = "site_cookie_consent_v1";
  var gtmLoaded = false;

  function getConsent(){
    try { return JSON.parse(localStorage.getItem(CONSENT_KEY) || "null"); }
    catch(e){ return null; }
  }

  function setConsent(consent){
    try { localStorage.setItem(CONSENT_KEY, JSON.stringify(consent)); }
    catch(e){}
  }

  function openModal(){
    document.getElementById("cbOverlay").style.display = "block";
    document.getElementById("cbModal").style.display = "flex";
  }

  function closeModal(){
    document.getElementById("cbModal").style.display = "none";
    document.getElementById("cbOverlay").style.display = "none";
  }

  // Load GTM only after analytics consent
  function loadGTM(){
    if (gtmLoaded) return;
    if (!GTM_ID) return;

    gtmLoaded = true;
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({'gtm.start': new Date().getTime(), event:'gtm.js'});

    var f = document.getElementsByTagName('script')[0];
    var j = document.createElement('script');
    j.async = true;
    j.src = 'https://www.googletagmanager.com/gtm.js?id=' + encodeURIComponent(GTM_ID);
    f.parentNode.insertBefore(j, f);
  }

 function applyConsent(consent){
  // If no consent yet, treat as denied
  var analyticsGranted = !!(consent && consent.analytics === true);

  var base = {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    functionality_storage: 'granted',
    personalization_storage: 'denied',
    security_storage: 'granted'
  };

  gtag('consent', 'update', Object.assign({}, base, {
    analytics_storage: analyticsGranted ? 'granted' : 'denied'
  }));

  if (analyticsGranted) loadGTM();
}

  function saveChoices(){
    var analytics = !!document.getElementById("cbAnalyticsToggle").checked;
    var c = { necessary:true, analytics:analytics, timestamp:new Date().toISOString(), version:"v1" };
    setConsent(c);
    closeModal();
    applyConsent(c);
  }

 function rejectAnalytics(){
  var c = { necessary:true, analytics:false, timestamp:new Date().toISOString(), version:"v1" };
  setConsent(c);
  closeModal();

  gtag('consent', 'update', {
    analytics_storage: 'denied',
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied'
  });

  // do not load GTM
}

  // ===== INIT =====
  var existing = getConsent();
  if (existing && typeof existing.analytics === "boolean"){
    document.getElementById("cbAnalyticsToggle").checked = !!existing.analytics;
    applyConsent(existing);
  } else {
    // first visit: default OFF + show modal
    document.getElementById("cbAnalyticsToggle").checked = false;
    openModal();
  }

  document.getElementById("cbClose").addEventListener("click", closeModal);
  document.getElementById("cbSave").addEventListener("click", saveChoices);
  document.getElementById("cbReject").addEventListener("click", rejectAnalytics);

  // Footer link: call CookieSettings.open() from a button/link
  window.CookieSettings = {
    open: function(){
      var c = getConsent();
      document.getElementById("cbAnalyticsToggle").checked = c ? !!c.analytics : false;
      openModal();
    },
    reset: function(){
      try { localStorage.removeItem(CONSENT_KEY); } catch(e){}
      gtmLoaded = false;
      document.getElementById("cbAnalyticsToggle").checked = false;
      openModal();
    }
  };
})();
</script>
</body></html>