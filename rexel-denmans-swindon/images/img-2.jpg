					data-provide="typeahead" 
					autocomplete="off" 
					data-options='{"targetURL" : "https://web.eu.dif.rexel.com/uki/typeAhead", "displayAddToCart" : "true", "autocompleteUrl" : "/uki/search/autocomplete/SearchBoxResponsiveComponent","minCharactersBeforeRequest" : "3","waitTimeBeforeRequest" : "500","displayProductImages" : true,"baynoteAutoCompleteUrl" : "/uki/baynoteProductAutoComplete.json", "baynoteProductSize" : "4", "baynoteProductVisible" : "false","maxSearchTerm" : "10","storeSearchTerm" : "true"}' />
					<div id="noResultTypeaheadAnym" class="d-none font-12 justify-content-end align-items-center"><span class="text-gray-500 position-absolute mr-3">0 please try another search</span></div>
