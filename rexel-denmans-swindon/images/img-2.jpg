					{{for categoryData}} 
					{{if visibleOnHomepage eq true }}
  						<li class="brand-dropdown-list {{:tabletBrowseProductsClass}}" id="cat_{{:#getIndex()}}">
							<a class="category-links dropdown-item personalized-catogory-link"  
								href="/uki{{:url}}" 
								data-category-code="{{:code}}"
