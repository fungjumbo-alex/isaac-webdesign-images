	<div class="seo-collapse no-transition seo-cropped collapse"></div>
	<div class="seo-collapse no-transition seo-full collapse show"><p>Rexel UK is a leading wholesale electrical distributor connecting electricians, contractors and industrial organisations with the best electrical products, site supplies and solutions. We carry wide ranges from the UK’s leading suppliers, from lighting and circuit protection to electrical wiring, industrial controls, safety and workwear, as well as power tools and site equipment. We’re easily accessible via our online store and our 200+ branch locations across the UK offer a flexible personal service, expert advice and everything you need for all your electrical projects, large or small.</p>
</div>
	<script  type="text/javascript">
	var seoContainer = document.getElementById('seoContainer');
	if (seoContainer) {
	    var seoCropped = seoContainer.querySelector('div.seo-cropped');
	    if (seoCropped) {
	    	var contentHtml =  '<p>Rexel UK is a leading wholesale electrical distributor connecting electricians, contractors and industrial organisations with the best electrical products, site supplies and solutions. We carry wide ranges from the UK’s leading suppliers&#8230;';
	        seoCropped.innerHTML = contentHtml;
	        seoCropped.classList.add("show");
	    } 
	    var seoFull = seoContainer.querySelector('div.seo-full');
	    if (seoFull) {
	        seoFull.classList.remove("show");
	    } 
	}
	
	
	</script>
	
