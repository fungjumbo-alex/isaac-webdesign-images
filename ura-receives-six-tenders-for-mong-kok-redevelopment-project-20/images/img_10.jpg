,\"srcset\":\"https://image.hkstandard.com.hk/f/1920p0/0x0/100/none/4bdab248ea60163346871e77d95aa902/2026-04/2023-10-29T021953Z_1767661825_RC2Z14ASW1OH_RTRMADP_3_ATHLETICS-BEIJING-MARATHON.JPG 1920w,https://image.hkstandard.com.hk/f/1440p0/0x0/100/none/fd153a1fbf1c5f6a4db111d7b9d3138d/2026-04/2023-10-29T021953Z_1767661825_RC2Z14ASW1OH_RTRMADP_3_ATHLETICS-BEIJING-MARATHON.JPG 1440w,https://image.hkstandard.com.hk/f/1024p0/0x0/100/none/d5cbdc84e2980062360d79240bcaceff/2026-04/2023-10-29T021953Z_1767661825_RC2Z14ASW1OH_RTRMADP_3_ATHLETICS-BEIJING-MARATHON.JPG 1024w,https://image.hkstandard.com.hk/f/640p0/0x0/100/none/afdb7b97133cc93eb759861f6d6e0d9c/2026-04/2023-10-29T021953Z_1767661825_RC2Z14ASW1OH_RTRMADP_3_ATHLETICS-BEIJING-MARATHON.JPG 640w\"},\"article_type\":\"basic\",\"url\":\"/property/article/329185/A-district-in-Chinas-Nanjing-offers-up-to-100000-yuan-housing-subsidies-to-marathon-runners\",\"redirect_url\":null,\"title\":\"A district in China's Nanjing offers up to 100,000 yuan housing subsidies to marathon runners\",\"digest\":\"A district in China's Nanjing is offering housing subsidies of up to 100,000 yuan to marathon runners, the latest efforts by local governments in the country to revive the property market that has been sluggish for more than five years.\",\"channel_rect\":{\"background_color\":\"C90027\",\"icon\":null,\"name\":\"Property\",\"url\":\"/property\"},\"channel_name\":\"Property\",\"channel_url\":\"/property\",\"video_id\":\"\",\"video_path\":\"\",\"video_title\":\"\",\"video_cover_img\":\"\",\"video_duration\":null,\"publish_at\":1776083885,\"updated_at\":1776083885,\"live_id\":null,\"m3u8_live_url\":null,\"byline\":[]},{\"article_id\":\"329180\",\"key_image\":{\"alt_text\":\"Central Residence By The Park, co-developed by PCPD and CSI Properties\",\"caption\":\"Central Residence By The Park, co-developed by PCPD and CSI Properties\",\"src\":\"https://image.hkstandard.com.hk/f/1024p0/0x0/100/none/ed5bdd4f07a47c390256265f468b5e8c/2026-04/P