_clicked">Privacy Policy</a> </li></ul> </nav></div> </div> </div> </header><div id="r5002" role="main" class="row designRow"> <div class="container container-fluid"><div class="col col-sm-12"><div id="r4922" class="row "> <div class="container container-fixed"><div id="c9472" class="col col-lg-5 col-sm-12"><div id="m4412" class="module text"><p class="custom4">A Team of Roofers<br>You Can Trust</p></div> <a id="m4335" class="module button" href="/our-work"  title="" role="button" data-track-event="click" data-track-action="internal_link_clicked"> <span class="buttonLabel labelRight">Our Previous Works</span> </a></div> <div class="col col-sm-7 hidden-sm hidden-md"></div> </div> </div> <div id="r4041" class="row "> <div class="container container-fixed colsStack"><div id="c2733" class="col col-sm-12"><div id="m1271" class="module text"><h1 class="darkspottext" style="text-align: center;">A Reliable Roofing Company that Caters to Your Needs in Chatham, Kent</h1></div> </div> <div id="c4828" class="col col-lg-4 col-sm-12 flexCol"><div class="flexWrap"> <a href="/roofing-services"  title="" aria-label="" class="imageModuleWrap" id="w_m1015" data-track-event="click" data-track-action="internal_link_clicked"> <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVQYV2NgAAIAAAUAAarVyFEAAAAASUVORK5CYII=" alt="Roof Over Door" data-author="" width="540" height="540" fetchpriority="high"/> <noscript data-lazyload-src="/uploads/RlNTgEvz/320x0_320x0/Image00002__msi___jpg.webp" data-lazyload-id="m1015" data-lazyload-class="module image" data-lazyload-alt="Roof Over Door" data-req="" data-settings="enablehover=false,showelement=,hovertransition="> <img id="m1015" class="module image" src="/uploads/RlNTgEvz/320x0_320x0/Image00002__msi___jpg.webp" alt="Roof Over Door" width="540" height="540" data-author="" fetchpriority="high"/> </noscript> </a> <div id="m3675" class="module text"><p class="bodytext" style="text-align: center;">As specialists in all aspects of roofing, our skilled experts are able to tackle an array of jobs. No matter the size of the project, we're here to provide a solution which is tailored to your needs.</p></div> </div> <div id="m2191" class="module autospacer"></div> <div class="flexWrap"> <a id="m2938" class="module button" href="/roofing-services"  title="" role="button" data-track-event="click" data-track-action="internal_link_clicked"> <span class="buttonLabel labelRight">A Range of Roofing Services</span> </a></div> </div> <div id="c3791" class="col col-lg-4 col-sm-12 flexCol"><div class="flexWrap"> <a href="/roof-repairs"  title="" aria-label="" class="imageModuleWrap" id="w_m3602" data-track-event="click" data-track-action="internal_link_clicked"> <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVQYV2NgAAIAAAUAAarVyFEAAAAASUVORK5CYII=" alt="Front of House" data-author="" width="323" height="323" fetchpriority="high"/> <noscript data-lazyload-src="/uploads/ZKRzPpls/320x0_320x0/Image00003__msi___jpg.webp" data-lazyload-id="m3602" data-lazyload-class="module image" data-lazyload-alt="Front of House" data-req="" data-settings="enablehover=false,showelement=,hovertransition="> <img id="m3602" class="module image" src="/uploads/ZKRzPpls/320x0_320x0/Image00003__msi___jpg.webp" alt="Front of House" width="323" height="323" data-author="" fetchpriority="high"/> </noscript> </a> <div id="m4223" class="module text"><p class="bodytext" style="text-align: center;">When your roof becomes damaged, it's important for you to get it seen to quickly. We offer an assortment of repairs and maintenance services, restoring your roof's condition.</p></div> </div> <div id="m3941" class="module autospacer"></div> <div class="flexWrap"> <a id="m1136" class="module button" href="/roof-repairs"  title="" role="button" data-track-event="click" data-track-action="internal_link_clicked"> <span class="buttonLabel labelRight">Roof Repairs and Maintenance</span> </a></div> </div> <div id="c4280" class="col col-lg-4 col-sm-12 flexCol"><div class="flexWrap"> <a href="/guttering"  title="" aria-label="" class="imageModuleWrap" id="w_m3866" data-track-event="click" data-track-action="internal_link_clicked"> <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVQYV2NgAAIAAAUAAarVyFEAAAAASUVORK5CYII=" alt="Top of Roof" data-author="" width="266" height="266" fetchpriority="high"/> <noscript data-lazyload-src="/uploads/PY8Fn4rH/266x0_266x0/Image00004__msi___jpg.webp" data-lazyload-id="m3866" data-lazyload-class="module image" data-lazyload-alt="Top of Roof" data-req="" data-settings="enablehover=false,showelement=,hovertransition="> <img id="m3866" class="module image" src="/uploads/PY8Fn4rH/266x0_266x0/Image00004__msi___jpg.webp" alt="Top of Roof" width="266" height="266" data-author="" fetchpriority="high"/> </noscript> </a> <div id="m3385" class="module text"><p class="bodytext" style="text-align: center;">When it comes to guttering, fascias, and soffits, they need to be handled with careful hands. We are a devoted company that aims to help enhance the true elegance of your property.</p></div> </div> <div id="m4043" class="module autospacer"></div> <div class="flexWrap"> <a id="m2896" class="module button" href="/guttering"  title="" role="button" data-track-event="click" data-track-action="internal_link_clicked"> <span class="buttonLabel labelRight">Guttering, Fascias, and Soffits</span> </a></div> </div> </div> </div> <div id="r3447" class="row bgfilter"> <div class="container container-fixed"><div class="col col-sm-12"><div id="m3728" class="module text"><p class="custom4">Provide your roof with some much-needed attention.</p></div> <div id="m4190" class="module text"><p class="custom5">Call <a href="tel:07779 866773" data-track-event="click" data-track-action="phone_link"><span class="monoglobalWrap">07779 866773</span></a> or <a data-global="phone"  href="tel:01634660828" data-track-event="click" data-track-action="phone_link"><span class="monoglobalWrap">01634 660 828</span></a></p></div> </div> </div> </div> <div class="row "> <div class="container container-fixed"><div class="col col-sm-12"><div id="m3925" class="module text"><h2 class="subtitle" style="text-align: center;">About Us</h2></div> <div id="m1079" class="module text"><p class="bodytext" style="text-align: center;">For a roofing company that provides a first-rate service at all times, look no further than our highly regarded business. At Gary Martin Roofing Contractors, in Chatham, Kent, our dedicated team of roofers are on hand to cater to your needs. From <a href="/roofing-services" data-track-event="click" data-track-action="internal_link_clicked">roofing</a> to <a href="/guttering" data-track-event="click" data-track-action="internal_link_clicked">guttering</a>, we utilise our skills and expertise to provide you with the best possible service. Backed by more than 30 years of experience, we offer effective solutions to homeowners and commercial property owners in Medway and its surrounding areas. Renowned for our outstanding reputation, we are recognised for providing quality services at affordable prices, all while being totally professional every step of the way.</p></div> <div id="m2116" class="module text"><p class="bodytext" style="text-align: center;"><span style="font-weight: bold;"><a href="/contact" data-track-event="click" data-track-action="internal_link_clicked">Contact</a> our highly skilled roofers today, in Chatham, Kent, to acquire more details about the wide-ranging services available at our roofing company.</span></p></div> </div> </div> </div> <div id="r4687" class="row "> <div class="container container-fixed"><div id="c6049" class="col col-lg-6 col-sm-12"><div id="m3462" class="module text"><h2 class="subtitle">Contact</h2></div> <div id="m4708" class="module text"><p class="bodytext">Thank you for your interest. For questions or comments, please use the information listed here. We look forward to hearing from you soon.</p></div> <div id="m2556" class="module text"><p class="bodytext"><span style="font-weight: bold;">Mobile</span></p></div> <div id="m2317" class="module text"><p class="bodytext"><a href="tel:07779 866773" data-track-event="click" data-track-action="phone_link"><span class="monoglobalWrap">07779 866773</span></a></p></div> <div id="m1123" class="module text"><p class="bodytext"><span style="font-weight: bold;">Phone</span></p></div> <div id="m2134" class="module text"><p class="bodytext"><a data-global="phone"  href="tel:01634660828" data-track-event="click" data-track-action="phone_link"><span class="monoglobalWrap">01634 660 828</span></a></p></div> <div id="m2547" class="module text"><p class="bodytext"><span style="font-weight: bold;">Address</span></p></div> <div id="m2432" class="module text"><p class="bodytext">18 Hill Chase Walderslade<br>Chatham, Kent ME5 9HE</p></div> <div id="m4426" class="module text"><p class="bodytext"><span style="font-weight: bold;">Service Area</span></p></div> <div id="m3918" class="module text"><p class="bodytext">Medway, Maidstone, and Kent</p></div> <div id="m3995" class="module text"><p class="bodytext"><span style="font-weight: bold;">Share</span></p></div> <ul id="m3945" class="module socialmedia"> <li class=" "> <a class="" href="http://www.facebook.com/share.php?u=garymartinroofing.co.uk/" target="_blank" rel="noopener" title="Facebook Share" data-track-event="click" data-track-action="social_link"> <span class="fa fa-facebook"></span> </a> </li> <li class=" "> <a class="" href="http://www.twitter.com/home?status=garymartinroofing.co.uk/" target="_blank" rel="noopener" title="Twitter Share" data-track-event="click" data-track-action="social_link"> <span class="fa fa-twitter"></span> </a> </li> <li class=" "> <a class="" href="http://www.linkedin.com/shareArticle?mini=true&url=garymartinroofing.co.uk/" target="_blank" rel="noopener" title="LinkedIn Share" data-track-event="click" data-track-action="social_link"> <span class="fa fa-linkedin"></span> </a> </li> </ul></div> <div class="col col-lg-6 col-sm-12 flexCol"><div id="m1753" class="module autospacer"></div> <div class="flexWrap"> <div class="imageModuleWrap" id="w_m4462"> <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVQYV2NgAAIAAAUAAarVyFEAAAAASUVORK5CYII=" alt="Logo" data-author="" width="375" height="125" fetchpriority="high"/> <noscript data-lazyload-src="/uploads/tjdZis9m/375x0_375x0/119216725__ms__msi___png.webp" data-lazyload-id="m4462" data-lazyload-class="module image" data-lazyload-alt="Logo" data-req="" data-settings="enablehover=false,showelement=,hovertransition="> <img id="m4462" class="module image" src="/uploads/tjdZis9m/375x0_375x0/119216725__ms__msi___png.webp" alt="Logo" width="375" height="125" data-author="" fetchpriority="high"/> </noscript> </div></div> <div id="m4060" class="module autospacer"></div> </div> </div> </div> </div> </div> </div> <footer><div id="r4851" class="row "> <div class="container container-fixed"><div id="c5420" class="col col-sm-12"><div id="m1131" class="module text"><p class="custom3"><a href="/" data-track-event="click" data-track-action="internal_link_clicked"><span class="monoglobalWrap">Gary Martin Roofing Contractors</span></a></p></div> <div id="m4709" class="module text"><p class="footertext"><a href="/" data-track-event="click" data-track-action="internal_link_clicked">Home</a> &nbsp; &nbsp; &nbsp;<a href="/roofing-services" data-track-event="click" data-track-action="internal_link_clicked">Roofing</a>&nbsp; &nbsp; &nbsp; <a href="/roof-repairs" data-track-event="click" data-track-action="internal_link_clicked">Repairs &amp; Maintenance</a> &nbsp; &nbsp; &nbsp;<a href="/guttering" data-track-event="click" data-track-action="internal_link_clicked">Guttering, Fascias &amp; Soffits</a>&nbsp; &nbsp; &nbsp; <a href="/our-work" data-track-event="click" data-track-action="internal_link_clicked">Our Work</a> 