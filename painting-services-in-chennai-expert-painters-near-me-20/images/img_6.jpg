 <script type="text/javascript">
 	function go_back() {
 		$('.stage2').css('display', 'none');
 		$('.stage1').css('display', 'block');
 		$('.stage2').html($('.lead-step-2').html())

 	}
 	document.addEventListener("DOMContentLoaded", function() {
 		$('.city-popover').hide()
 		$(document).on('submit', '.submit_visit_detail', function(e) {
 			e.preventDefault();
 			$(".popover").hide();
 			let lead_data = '';
 			let name = $(this).find(".request_name")
 			let phone = $(this).find(".request_phone")
 			let city = $(this).find(".request_city")

 			if (0 >= name.val().trim().length) {
 				name.focus();
 				name.popover("show");
 				return false;
 			}

 			if (!phone.val().match(/^([0-9]{10})$/)) {
 				phone.popover("show");
 				phone.focus();
 				return false;
 			}

 			// city validation
 			$('.city-popover').remove()
 			if ("" == city.val()) {
 				$('html, body').animate({
 					scrollTop: $(this).offset().top
 				}, 100);

 				let city_error = '<h5 class="city-popover" style="color: red;">Select your city to continue*</h5>'
 				$(this).find('.select-items').after(city_error)
 				return false
 			}

 			// $('#overlay').css('display', 'flex');
 			let url = 'https://aapkapainter.com/index/save_appointment'

 			// generate form data
 			form_data = $(this).serialize()

 			// add extra param to the form data
 			form_data += '&json_response=TRUE';
 			$(this).find('.loader-overlay').css('display', 'flex');
 			setTimeout(() => {
 				$('.stage2').html($('.lead-step-2').html())
 				$('.stage1').css('display', 'none')
 				$('.stage2').css('display', 'block')
 				$('.stage2').find('.request_city').val(city.val());
 				init_calendar()
 				init_select()
 				$(this).find('.loader-overlay').css('display', 'none');
 			}, 500);

 			$.ajax({
 				data: form_data,
 				url: url,
 				method: "post",
 				success: function(data) {
 					if (!isValidJson(data)) {
 						lead_form_error_notification(form_data, data)
 						return false;
 					}
 					response = JSON.parse(data);
 					if (response.status == true) {
 						$('.enc_lead_id').val(response['lead']['enc_lead_id'])
 						$(this).find(".request_house_no").focus()

 						// ads - fire conversion pixels
 						if (response.channel !== undefined) {
 							conversion_pixel(response.channel, response.enc_lead_id)
 						}
 						fbq('trackCustom', 'LeadAug24');
 						gtag('event', 'lead_form_conversion', {
 							'event_category': 'Lead Form',
 							'event_label': 'Form Submit',
 							'phone': phone.val(),
 							'name': name.val(),
 							'city': city.val()
 						});
 					} else {
 						lead_form_error_notification(form_data, data)
 					}
 				},
 				error: function(request) {
 					lead_form_error_notification(form_data, `${request.statusText} : ${request.responseText}`)
 					alert(request.statusText);
 				}
 			});
 		});

 		$(document).ready(function() {

 			// update lead form custom tags
 			if ($('.lead-form-tag').length) {
 				$('.lead-form-tag').each(function(index, element) {
 					let tags = $(element).find('[name="tags"]')
 					new_tag = $(element).data('form-tag') + ' | ' + tags.val()
 					tags.val(new_tag)
 				})
 			}

 			if ('0' == 1) {
 				$('.stage2').html($('.lead-step-2').html())
 				init_calendar()
 				init_select()
 				$('.stage1').css('display', 'none');
 				$('.stage2').css('display', 'block');
 			}

 			// Event handler for form submission
 			$(document).on('submit', '.submit_house_detail', function(e) {
 				e.preventDefault();
 				$(".popover").hide();

 				// generate form data
 				form_data = $(this).serialize();
 				form_data += '&tags=lead-form-2-step-2';

 				// Assuming 'a' is defined elsewhere in your code
 				a = $(this).data('form-id');
 				house_no = $(this).find(".request_house_no")
 				apartment_name = $(this).find(".request_apartment_name")
 				locality = $(this).find(".request_locality")
 				pincode = $(this).find(".request_pincode")
 				city = $(this).find(".request_city")
 				visit_date = $(this).find(".request_visit_date")
 				if (0 >= house_no.val().trim().length) {
 					house_no.focus();
 					house_no.popover("show");
 					return false;
 				}
 				if (0 >= apartment_name.val().trim().length) {
 					apartment_name.focus();
 					apartment_name.popover("show");
 					return false;
 				}
 				if (0 >= locality.val().trim().length) {
 					locality.focus();
 					locality.popover("show");
 					return false;
 				}
 				let pincode_regex = /^\d{6}$/;
 				if (!pincode_regex.test(pincode.val())) {
 					pincode.focus();
 					pincode.popover("show");
 					return false;
 				}

 				if (city.length) {
 					if ("" == city.val()) {
 						city.focus();
 						city.popover("show");
 						return false;
 					}
 				}

 				$('.request_visit_date').popover({
 					trigger: 'manual', // Use manual trigger to control visibility
 					placement: 'top'
 				});

 				let hasShownPopover = false;

 				$('.request_visit_date').on('focus', function() {
 					if (!hasShownPopover) {
 						$(this).popover('show');
 						hasShownPopover = true;
 					}
 				});

 				$('.request_visit_date').on('blur', function() {
 					$(this).popover('hide');
 				});

 				if (0 >= visit_date.val().trim().length) {
 					visit_date.focus();
 					visit_date.popover("show");
 					return false;
 				}

 				// $('#overlay').css('display', 'flex');
 				enc_lead_id = $('.enc_lead_id').val()
 				let url = 'https://aapkapainter.com/index/update_appointment_detail/' + enc_lead_id;
 				$(this).find('.loader-overlay').css('display', 'flex');
 				setTimeout(() => {
 					$('.stage3').html($('.lead-step-3').html())
 					$('.stage2').css('display', 'none')
 					$('.stage3').css('display', 'block')
 				}, 500);

 				$.ajax({
 					data: form_data,
 					url: url,
 					method: "post",
 					success: function(data) {
 						response = JSON.parse(data);
 						if (response.status != true) {
 							alert(response.message);
 						}
 					},
 					error: function(request) {
 						alert(request.statusText);
 					}
 				});
 			});

 			// Event handler for calendar navigation buttons
 			$('.prev-button, .next-button').on('click', function(e) {
 				e.preventDefault();

 				// Proceed with calendar navigation logic here
 				// For example, load previous or next month
 			});
 		});

 	}, {
 		passive: true
 	});

 	function upd_fun() {
 		$('.upd_num_outer').css('display', "block");
 		$('#request_phone').focus();
 	}

 	function errorMsg() {
 		$(".popover").hide();
 	}

 	function lead_form_error_notification(form_data, error) {
 		form_data += '&error=' + error;
 		let url = 'https://aapkapainter.com/index/lead_form_error_notification'
 		$.ajax({
 			data: form_data,
 			url: url,
 			method: "post",
 			success: function(data) {
 				response = JSON.parse(data);
 				if (response.status != true) {
 					alert(response.message);
 				}
 			},
 			error: function(request) {
 				alert(request.statusText);
 			}
 		});
 	}
 </script>

 <script>
 	document.addEventListener("DOMContentLoaded", function() {
 		init_select()
 	}, {
 		passive: true
 	});

 	function init_select() {
 		var x, i, j, l, ll, selElmnt, a, b, c;
 		/*look for any elements with the class "custom-select":*/
 		x = document.getElementsByClassName("custom-select");
 		l = x.length;
 		for (i = 0; i < l; i++) {
 			selElmnt = x[i].getElementsByTagName("select")[0];
 			var selectSelectedDiv = selElmnt.closest('.custom-select').querySelector('.select-selected'); // Find the child with class "select-selected"
 			if (selectSelectedDiv) {
 				selectSelectedDiv.remove(); // Remove the .select-selected element if it exists
 			}

 			ll = selElmnt.length;
 			/*for each element, create a new DIV that will act as the selected item:*/
 			a = document.createElement("DIV");
 			a.setAttribute("class", "select-selected");
 			a.innerHTML = selElmnt.options[selElmnt.selectedIndex].innerHTML;
 			x[i].appendChild(a);
 			/*for each element, create a new DIV that will contain the option list:*/
 			b = document.createElement("DIV");
 			b.setAttribute("class", "select-items select-hide");
 			for (j = 1; j < ll; j++) {
 				/*for each option in the original select element,
 				create a new DIV that will act as an option item:*/
 				c = document.createElement("DIV");
 				c.innerHTML = selElmnt.options[j].innerHTML;
 				c.addEventListener("click", function(e) {
 					/*when an item is clicked, update the original select box,
 					and the selected item:*/
 					var y, i, k, s, h, sl, yl;
 					s = this.parentNode.parentNode.getElementsByTagName("select")[0];
 					sl = s.length;
 					h = this.parentNode.previousSibling;
 					for (i = 0; i < sl; i++) {
 						if (s.options[i].innerHTML == this.innerHTML) {
 							s.selectedIndex = i;
 							h.innerHTML = this.innerHTML;
 							y = this.parentNode.getElementsByClassName("same-as-selected");
 							yl = y.length;
 							for (k = 0; k < yl; k++) {
 								y[k].removeAttribute("class");
 							}
 							this.setAttribute("class", "same-as-selected");
 							break;
 						}
 					}
 					h.click();
 				});
 				b.appendChild(c);
 			}
 			x[i].appendChild(b);
 			a.addEventListener("click", function(e) {
 				/*when the select box is clicked, close any other select boxes,
 				and open/close the current select box:*/
 				e.stopPropagation();
 				closeAllSelect(this);
 				$('.city-popover').remove()
 				this.nextSibling.classList.toggle("select-hide");
 				this.classList.toggle("select-arrow-active");
 			});
 		}
 	}

 	function closeAllSelect(elmnt) {
 		/*a function that will close all select boxes in the document,
 		except the current select box:*/
 		var x, y, i, xl, yl, arrNo = [];
 		x = document.getElementsByClassName("select-items");
 		y = document.getElementsByClassName("select-selected");
 		xl = x.length;
 		yl = y.length;
 		for (i = 0; i < yl; i++) {
 			if (elmnt == y[i]) {
 				arrNo.push(i)
 			} else {
 				y[i].classList.remove("select-arrow-active");
 			}
 		}
 		for (i = 0; i < xl; i++) {
 			if (arrNo.indexOf(i)) {
 				x[i].classList.add("select-hide");
 			}
 		}
 	}
 	/*if the user clicks anywhere outside the select box,
 	then close all select boxes:*/
 	document.addEventListener("click", closeAllSelect);
 </script>

 <script>
 	function init_calendar() {
 		// Initialize calendar for each date-picker
 		$('.date-picker').each(function() {
 			const calendar = $(this).find('.calendar');
 			const inputField = $(this).find('.request_visit_date')[0];
 			let currentMonth = new Date().getMonth();
 			let currentYear = new Date().getFullYear();
 			const today = new Date();
 			today.setDate(today.getDate() + 1); // Set to tomorrow

 			const months = [
 				'January', 'February', 'March', 'April', 'May', 'June',
 				'July', 'August', 'September', 'October', 'November', 'December'
 			];

 			const monthYear = calendar.find('.month-year');
 			const prevButton = calendar.find('.prev-button');
 			const nextButton = calendar.find('.next-button');
 			const monthElement = monthYear.find('.month');
 			const yearElement = monthYear.find('.year');

 			function renderCalendar(month, year) {
 				const firstDayOfMonth = new Date(year, month, 1).getDay();
 				const daysInMonth = new Date(year, month + 1, 0).getDate();
 				const validStartDate = new Date(today);
 				validStartDate.setDate(validStartDate.getDate() - 1); // Recalculate validStartDate
 				const validEndDate = new Date(today);
 				validEndDate.setDate(validEndDate.getDate() + 6); // Recalculate validEndDate
 				const currentDate = new Date(); // Highlight current date with different color
 				let emptyDate = '';
 				for (let i = 0; i < firstDayOfMonth; i++) {
 					emptyDate += '<div class="calendar-date disabled"></div>';
 				}
 				calendar.find('.calendar-dates').html(emptyDate);
 				let dateElement = '';
 				for (let day = 1; day <= daysInMonth; day++) {
 					const date = new Date(year, month, day);
 					const disabled = (date < validStartDate || date > validEndDate) ? 'disabled' : '';
 					// Highlight today's date and current date with different CSS
 					let todayClass = ''; // Corrected variable name to follow camelCase convention
 					if (
 						day === today.getDate() &&
 						month === today.getMonth() &&
 						year === today.getFullYear()
 					) {
 						todayClass = 'today';
 					} else if (
 						day === currentDate.getDate() &&
 						month === currentDate.getMonth() &&
 						year === currentDate.getFullYear()
 					) {
 						todayClass = 'current-day'; // Highlight current day with different CSS
 					}
 					dateElement += `<div class="calendar-date ${disabled} ${todayClass}" data-val="${months[month]} ${day}, ${year}">${day}</div>`;
 				}
 				calendar.find('.calendar-dates').append(dateElement);
 				monthElement.html(months[month]);
 				yearElement.html(year);
 			}

 			prevButton.on('click', (e) => {
 				e.preventDefault(); // Prevent form submission
 				currentMonth--;
 				if (currentMonth < 0) {
 					currentMonth = 11;
 					currentYear--;
 				}
 				renderCalendar(currentMonth, currentYear);
 			});

 			nextButton.on('click', (e) => {
 				e.preventDefault(); // Prevent form submission
 				currentMonth++;
 				if (currentMonth > 11) {
 					currentMonth = 0;
 					currentYear++;
 				}
 				renderCalendar(currentMonth, currentYear);
 			});

 			calendar.on('click', '.calendar-date', function() {
 				if ($(this).hasClass('disabled')) {
 					return false;
 				}
 				// Check if the date is already selected
 				if (inputField.value !== $(this).data('val')) {
 					inputField.value = $(this).data('val');
 					$('.today').removeClass('today');
 					$(this).addClass('today');
 				}
 				calendar.css('display', 'none');
 			});

 			inputField.addEventListener('click', function() {
 				calendar.css('display', 'block');
 			});

 			renderCalendar(currentMonth, currentYear);
 		});
 	}
 </script>
