	<script>
	document.addEventListener("DOMContentLoaded", function() {
		var channelName = 'aapkapainter.com';
		$(document).ready(function() {
			setTimeout(function() {
				load_texture_video();
			}, 8000);
			$('#csmr_slider4').on('click', '.item .play', function() {
				var videoId = $(this).parents('.item').data('id');
				var iframe = document.createElement("iframe");
				iframe.setAttribute("src", "https://www.youtube.com/embed/" + videoId + "?autoplay=1&mute=1");
				iframe.setAttribute("frameborder", "0");
				iframe.setAttribute("allowfullscreen", "1");
				this.parentNode.replaceChild(iframe, this);
			})
		});
	}, {
		passive: true
	});

	function load_texture_video() {
		var Bangalore = "PLRsOyitGnHPsJWm407WcVe59rebYUCGAS";
		var Mumbai = "PLRsOyitGnHPuOCl6fcau5ccXBHq8GWN3J";
		var Thane = "PLRsOyitGnHPuOCl6fcau5ccXBHq8GWN3J";
		var NaviMumbai = "PLRsOyitGnHPuOCl6fcau5ccXBHq8GWN3J";
		var Hyderabad = "PLSptyWQ2M4CYpWpy61kFEiyeJVzIWHh_N";
		var Pune = "PLRsOyitGnHPubDZPzYFaD9wesuCyxvPWj";
		var Delhi = "PLiUWfsme5Z8IbrlYdkyGJp2okE1XsEyg_";
		var Chennai = "PLHF_fdlwIy4AmBFRz4ycl_fwD7PUU1PjI";
		// var Kolkata = "PLRsOyitGnHPvGwWuhpfDdxAFG1U5pKd-s";
		var Noida = "PLRsOyitGnHPubDZPzYFaD9wesuCyxvPWj";
		var Gurgaon = "PLRsOyitGnHPubDZPzYFaD9wesuCyxvPWj";
		var Faridabad = "PLRsOyitGnHPubDZPzYFaD9wesuCyxvPWj";
		var Ghaziabad = "PLRsOyitGnHPubDZPzYFaD9wesuCyxvPWj";
		var city = "";
		if (1) {
			var city = Chennai;
		} else if (0) {
			let city_id = {};
			city_id[1] = Bangalore;
			city_id[2] = Mumbai;
			city_id[3] = Hyderabad;
			city_id[4] = Pune;
			city_id[5] = Delhi;
			city_id[6] = Chennai;
			// city_id[31] = Kolkata;
			city_id[52] = Ghaziabad;
			city_id[189] = Faridabad;
			city_id[486] = Noida;
			city_id[1486] = Gurgaon;
			city_id[42] = Thane;
			city_id[310] = NaviMumbai;
			var city = city_id[0];
		} else {
			var city = "PLRsOyitGnHPubDZPzYFaD9wesuCyxvPWj";
		}
		$.get(
			"https://www.googleapis.com/youtube/v3/playlistItems", {
				part: 'snippet',
				playlistId: city,
				maxResults: '10',
				key: 'AIzaSyAeWIyHK29tcF2nF11BuNRFiKWEWFypcSg'
			},

			function(data) {
				var output = '';
				$.each(data.items, function(i, item) {
					videTitle = item.snippet.title;
					videoId = item.snippet.resourceId.videoId;

					$('#csmr_slider4').append(generateVideoHTML(videoId, videTitle));
				});

				$('#csmr_slider4').owlCarousel({
					loop: true,
					lazyLoad: true,
					margin: 35,
					nav: false,
					center: true,
					dots: true,
					autoplay: true,
					autoplayTimeout: 2000,
					autoplayHoverPause: true,
					navText: ["<img height='20' width='20' src='https://aapkapainter.com/assets/newdesign/images/icon/service_arrow2.png'>", "<img height='20' width='20' src='https://aapkapainter.com/assets/newdesign/images/icon/service_arrow.png'>"],
					responsive: {
						0: {
							items: 1
						},
						600: {
							items: 2
						},
						1000: {
							items: 3
						}
					}
				});
			}
		);
	}


	function generateVideoHTML(videoId, videTitle) {
		return ('<div class="item csmr_sld_bx" data-id="' + videoId + '"><div class="csmr_testimonial_home youtube"><img src="https://i.ytimg.com/vi/' + videoId + '/hqdefault.jpg" width="400" height="300"><div class="play"></div></div><div class="csmr_dtls">' + videTitle + '</div></div>')
	}
</script>

