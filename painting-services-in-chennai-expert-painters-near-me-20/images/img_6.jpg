	.checkbox-custom {
		display: inline-block;
		width: 1.3vw;
		height: 1.3vw;
		background-color: #fff;
		border: 1px solid #CBCBCB;
		border-radius: 50%;
		position: relative;
		vertical-align: middle;
		margin-right: 5px;
	}

	input[type=radio] {
		position: relative;
		top: 3px;
	}

	input[type="checkbox"] {
		display: none;
	}

	input[type="checkbox"] {
		height: 20px;
		margin: 0 5px 0 0;
		width: 20px;
		vertical-align: sub;
	}

	input[type="checkbox"]:checked+.checkbox-custom::after {
		content: "\2713";
		display: block;
		font-size: 17px;
		color: #F12848;
		position: absolute;
		top: 54%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

