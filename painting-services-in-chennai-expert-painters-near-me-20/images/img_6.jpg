<style>
	@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');
	@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap');


	::placeholder {
		color: #8D8D8D !important;
	}

	input::placeholder {
		font-size: 16px;
		/* Adjust the size as needed */
	}

	.stage1 .select-items {
		top: 43px !important;
	}

	.tabs-wrapper {
		overflow-x: scroll;
		/* Enable horizontal scrolling */
		-ms-overflow-style: none;
		/* Internet Explorer 10+ */
		scrollbar-width: none;
		/* Firefox */
	}

	.map-container {
		padding-top: 1rem;
		padding-bottom: 0rem;
		/* position: relative; */
	}

	.map-view {
		width: -webkit-fill-available;
	}

	.accordion-title {
		font-family: 'Montserrat', sans-serif;
		background: #fff;
		font-size: 20px;
		font-weight: 500;
		cursor: pointer;
		color: #000;
		position: relative;
		padding: 17px 20px;
		transition: background-color 0.3s ease;
		opacity: 1;
		margin-bottom: 20px;
		border-radius: 10px;
	}

	.accordion-title::after {
		content: '\25BE';
		position: absolute;
		font-size: 35px;
		top: 50%;
		right: 15px;
		transform: translateY(-50%);
		transition: transform 0.3s ease;
		color: #E5E5E5;
	}

	.accordion-content {
		padding: 0px 20px;
		margin-bottom: 25px;
		display: none;
		font-family: 'Poppins', sans-serif;
		background-color: #F8E6E4;
		color: #5F5F5F;
		font-size: 18px;
		transition: max-height 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), padding 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.2);
	}

	.accordion-item.active .accordion-title {
		background: linear-gradient(269deg, #F2994E, #F06553);
		color: #fff;
		border-radius: 6px;
	}

	.accordion-item.active .accordion-title::after {
		content: '\25BE';
		transform: translateY(-50%) rotate(180deg);
		transition: transform 0.3s ease;
		position: absolute;
		font-size: 35px;
		top: 50%;
		right: 15px;
		color: #fff;
	}

	.accordion-item.active .accordion-content {
		display: block;
	}

	.deep-cleaning-faq {
		margin-top: 5rem;
	}

	.city_block_details {
		font-family: 'Montserrat', sans-serif;
		font-size: 24px;
		text-transform: capitalize;
		letter-spacing: -0.24px;
		color: #01182E;
		font-weight: 500;
		margin-top: 0px !important;
	}

	.city_list p {
		font-size: 24px;
		font-weight: 500;
	}

	.faq-check {
		background: #F8E6E4;
	}

	h2.faq-head {
		text-align: center;
		font-size: 40px;
		letter-spacing: -0.4px;
		line-height: 50px;
		margin-bottom: 60px;
		font-family: 'Montserrat', sans-serif;
	}

	.product-slide .item {
		right: 22rem;
		position: relative;
	}

	.matt_prdts {
		width: 60%;
		display: inline-grid;
		border: 1px solid #D1D1D1;
		justify-content: center;
		border-radius: 28px;
		padding: 4rem 0;
	}

	.text-dtl-btn {
		font-size: 16px !important;
		padding: 5px 5px !important;
		border-radius: 2px !important;
		background-color: transparent !important;
		color: #F16554;
		text-decoration: underline;
		border: unset !important;
	}

	.product-slide .prdt_img {
		width: 100%;
		padding-right: 0px;
	}

	.prdt_dtls {
		width: 100%;
		text-align: center;
	}

	.home h2,
	.paint_block_title h2 {
		font-size: 50px;
		line-height: 63px;
		text-align: center;
		letter-spacing: -0.5px;
		font-family: 'Montserrat', sans-serif;
		margin-bottom: 60px;
		text-transform: capitalize;
		font-weight: bold;
	}



	.homes-section h4 {
		border-radius: 28px;
		line-height: 33px;
		letter-spacing: -0.3px;
		background-color: #4A4A4A;
		color: #fff;
		font-family: 'Montserrat', sans-serif;
		font-weight: 500;
		font-size: 30px;
		padding-top: 35px;
		text-align: center;
		padding-bottom: 35px;
		padding-right: 58px;
		padding-left: 58px;
